---
import Layout from '../layouts/Layout.astro';
import { DOMAIN } from '../data/site';

const assessSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: 'Body Composition Strategy Finder - Free Assessment | BodyCompOS',
	description: 'Get a personalized body composition strategy recommendation — cut, bulk, recomp, or maintain — with calorie targets, protein range, pace estimate, and timeline.',
	url: `${DOMAIN}/assess`,
};
---

<Layout
	title="Body Composition Strategy Finder - Free Assessment | BodyCompOS"
	description="Get a personalized body composition strategy recommendation — cut, bulk, recomp, or maintain — with calorie targets, protein range, pace estimate, and timeline. No account required."
	canonical={`${DOMAIN}/assess`}
	schema={[assessSchema]}
>
	<section class="site-container py-8 lg:py-10">
		<div class="max-w-2xl mx-auto">
			<!-- Breadcrumb -->
			<nav class="flex mb-5 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
				<a class="hover:text-accent transition-colors" href="/">Home</a>
				<span>/</span>
				<span class="text-foreground">Strategy Finder</span>
			</nav>

			<!-- Page Header -->
			<div class="mb-6">
				<span class="badge badge-accent text-[10px]">Free Assessment Tool</span>
				<h1 class="mt-3 text-3xl font-black text-foreground sm:text-4xl">Find Your Body Composition Strategy</h1>
				<p class="mt-2 text-sm text-muted-foreground leading-relaxed">
					Enter your stats below to get a personalized recommendation — whether to cut, bulk, recomp, or maintain — plus calorie and protein targets, pace, and timeline.
				</p>
			</div>

			<!-- Assessment Form Panel -->
			<div class="surface rounded-2xl p-5 sm:p-6">
				<div class="flex items-center justify-between border-b border-border pb-4">
					<div>
						<p class="eyebrow">Interactive Engine</p>
						<h2 class="text-xl font-black text-foreground">Strategy Finder</h2>
					</div>
					<div class="segmented" role="group" aria-label="Measurement units">
						<button type="button" data-strategy-unit="metric" aria-pressed="true">Metric</button>
						<button type="button" data-strategy-unit="imperial" aria-pressed="false">Imperial</button>
					</div>
				</div>

				<form id="strategy-form" class="mt-5 grid gap-3 sm:grid-cols-2">
					<!-- Section: Personal -->
					<div class="sm:col-span-2">
						<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Personal Information</p>
						<div class="border-t border-border/30 mt-1.5"></div>
					</div>

					<div class="field">
						<label for="sex">Biological Sex</label>
						<div class="select-wrap">
							<select id="sex" required>
								<option value="male">Male</option>
								<option value="female">Female</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="age">Age (years)</label>
						<input id="age" type="number" min="18" max="90" placeholder="e.g. 32" required />
					</div>
					<div class="field">
						<label for="height">Height <span data-strategy-height-unit>(cm)</span></label>
						<input id="height" type="number" min="120" max="230" placeholder="e.g. 175" required />
					</div>
					<div class="field">
						<label for="weight">Weight <span data-strategy-weight-unit>(kg)</span></label>
						<input id="weight" type="number" min="35" max="250" step="0.1" placeholder="e.g. 82" required />
					</div>

					<!-- Section: Body Composition -->
					<div class="sm:col-span-2 mt-2">
						<p class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground">Body Composition</p>
						<div class="border-t border-border/30 mt-1.5"></div>
					</div>

					<div class="field sm:col-span-2">
						<label class="flex items-center gap-2.5 font-semibold cursor-pointer">
							<input type="checkbox" id="use-navy-bf" class="rounded border-border text-accent focus:ring-accent" />
							<span class="text-xs text-foreground select-none">Estimate Body Fat using Navy Circumference Method</span>
						</label>
					</div>

					<div id="navy-inputs" class="grid gap-3 grid-cols-2 sm:col-span-2 hidden">
						<div class="field">
							<label for="waist">Waist <span data-strategy-height-unit>(cm)</span></label>
							<input id="waist" type="number" min="40" max="220" step="0.1" placeholder="e.g. 88" />
						</div>
						<div class="field">
							<label for="neck">Neck <span data-strategy-height-unit>(cm)</span></label>
							<input id="neck" type="number" min="20" max="80" step="0.1" placeholder="e.g. 38" />
						</div>
						<div id="hip-field" class="field col-span-2 hidden">
							<label for="hip">Hip <span data-strategy-height-unit>(cm)</span></label>
							<input id="hip" type="number" min="40" max="220" step="0.1" placeholder="e.g. 95" />
						</div>
					</div>

					<div class="field sm:col-span-2">
						<label for="bodyFat">Estimated Body Fat %</label>
						<input id="bodyFat" type="number" min="3" max="60" step="0.1" placeholder="e.g. 22" required />
						<p class="text-xs text-muted-foreground leading-relaxed mt-1">
							Body fat percentage estimates the proportion of your body weight from fat tissue.
							<a href="/calculators/body-fat-calculator" class="text-accent underline font-medium hover:no-underline">Use our Body Fat Calculator</a>
							if you're unsure.
						</p>
						<a href="/calculators/body-fat-calculator"
						   class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent hover:text-accent/80 transition-colors mt-1">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
							Estimate Body Fat
						</a>
					</div>

					<!-- Section: Training & Activity -->
					<div class="sm:col-span-2 mt-2">
					<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Training &amp; Activity</p>
						<div class="border-t border-border/30 mt-1.5"></div>
					</div>

					<div class="field">
						<label for="activity">Daily Activity Level</label>
						<div class="select-wrap">
							<select id="activity" required>
								<option value="sedentary">Sedentary (desk-job)</option>
								<option value="light">Lightly Active (active-job/walks)</option>
								<option value="moderate" selected>Moderately Active (trains 3-5x/week)</option>
								<option value="active">Highly Active (trains 6-7x/week)</option>
								<option value="athlete">Competitive Athlete</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="trainingAge">Lifting Experience</label>
						<div class="select-wrap">
							<select id="trainingAge" required>
								<option value="beginner">Beginner (&lt; 1 year lifting)</option>
								<option value="intermediate">Intermediate (1-3 years lifting)</option>
								<option value="advanced">Advanced (3+ years lifting)</option>
							</select>
						</div>
					</div>

					<!-- Section: Goals -->
					<div class="sm:col-span-2 mt-2">
					<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Goals</p>
						<div class="border-t border-border/30 mt-1.5"></div>
					</div>

					<div class="field">
						<label for="goalBias">Preferred Strategy Direction</label>
						<div class="select-wrap">
							<select id="goalBias" required>
								<option value="fat-loss">Fat Loss Focused</option>
								<option value="recomp" selected>Body Recomposition</option>
								<option value="lean-bulk">Lean Muscle Bulk</option>
								<option value="aggressive-bulk">Aggressive Mass Gain</option>
								<option value="maintain">Weight Maintenance</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="protein">Daily Protein (grams, optional)</label>
						<input id="protein" type="number" min="0" max="400" placeholder="e.g., 140" />
					</div>

					<button class="button-primary sm:col-span-2 mt-2" type="submit">Calculate Strategy Recommendation</button>
				</form>

				<div id="strategy-result" class="result-container mt-6 border-t border-border pt-5" aria-live="polite" tabindex="-1">
					<div class="result-placeholder">
						<svg class="text-muted-foreground" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
						<p class="mt-2 text-sm font-semibold text-foreground">Awaiting Assessment Inputs</p>
						<p class="mt-1 text-xs text-muted-foreground max-w-xs">Fill in your physical statistics and goals to generate your strategic plan.</p>
					</div>
				</div>
			</div>

			<!-- Trust note -->
			<div class="mt-5 text-center text-xs text-muted-foreground">
				All data stays in your browser. No account required. <a href="/privacy-policy" class="underline hover:text-accent">Privacy</a>
			</div>
		</div>
	</section>
</Layout>

<script>
	import {
		mifflin as engineMifflin,
		strategyRecommendation,
		calorieTarget,
		activityFactors as engineActivityFactors,
		goalLabels,
		round,
		clamp,
		calculateNavyBodyFat as engineNavyBF,
	} from '../lib/engines';

	const activityFactors = engineActivityFactors;
	const labels = goalLabels;
	let strategyUnit = 'metric';

	(function() {
		const savedBf = localStorage.getItem('bodycompos.estimatedBodyFat');
		if (savedBf) {
			const input = document.getElementById('bodyFat') as HTMLInputElement;
			if (input && !input.dataset.autofilled) {
				input.value = savedBf;
				input.dataset.autofilled = 'true';
				const msg = document.createElement('p');
				msg.className = 'text-xs text-success font-medium mt-1.5';
				msg.textContent = 'Estimated body fat imported successfully.';
				input.parentElement?.appendChild(msg);
				setTimeout(() => msg.remove(), 4000);
			}
		}
	})();

	function round(n: number, d = 0) { const p = 10 ** d; return Math.round(n * p) / p; }
	function clamp(n: number, min: number, max: number) { return Math.max(min, Math.min(max, n)); }
	function safeJsonParse(value: string | null, fallback: any) {
		try { return value ? JSON.parse(value) : fallback; } catch { return fallback; }
	}

	function kgToLb(kg: number) { return kg * 2.2046226218; }

	function lbToKg(lb: number) { return lb / 2.2046226218; }
	function cmToIn(cm: number) { return cm / 2.54; }
	function inToCm(value: number) { return value * 2.54; }

	function setStrategyUnit(unit) {
		if (unit === strategyUnit) return;
		const form = document.querySelector('#strategy-form') as HTMLFormElement;
		if (!form) return;

		const height = Number(form.height.value);
		const weight = Number(form.weight.value);
		const waist = Number(form.waist.value);
		const neck = Number(form.neck.value);
		const hip = Number(form.hip.value);

		if (unit === 'imperial') {
			form.height.value = String(round(cmToIn(height), 1));
			form.weight.value = String(round(kgToLb(weight), 1));
			if (waist) form.waist.value = String(round(cmToIn(waist), 1));
			if (neck) form.neck.value = String(round(cmToIn(neck), 1));
			if (hip) form.hip.value = String(round(cmToIn(hip), 1));
			form.height.min = '47';
			form.height.max = '91';
			form.weight.min = '77';
			form.weight.max = '551';
			form.waist.min = '16';
			form.waist.max = '87';
			form.neck.min = '8';
			form.neck.max = '31';
			form.hip.min = '16';
			form.hip.max = '87';
		} else {
			form.height.value = String(round(inToCm(height), 1));
			form.weight.value = String(round(lbToKg(weight), 1));
			if (waist) form.waist.value = String(round(inToCm(waist), 1));
			if (neck) form.neck.value = String(round(inToCm(neck), 1));
			if (hip) form.hip.value = String(round(inToCm(hip), 1));
			form.height.min = '120';
			form.height.max = '230';
			form.weight.min = '35';
			form.weight.max = '250';
			form.waist.min = '40';
			form.waist.max = '220';
			form.neck.min = '20';
			form.neck.max = '80';
			form.hip.min = '40';
			form.hip.max = '220';
		}

		strategyUnit = unit;
		document.querySelectorAll('[data-strategy-unit]').forEach((button) => button.setAttribute('aria-pressed', String(button.getAttribute('data-strategy-unit') === unit)));
		document.querySelectorAll('[data-strategy-height-unit]').forEach((label) => label.textContent = unit === 'metric' ? '(cm)' : '(in)');
		document.querySelectorAll('[data-strategy-weight-unit]').forEach((label) => label.textContent = unit === 'metric' ? '(kg)' : '(lb)');
	}

	document.querySelectorAll('[data-strategy-unit]').forEach((button) => {
		button.addEventListener('click', () => setStrategyUnit(button.getAttribute('data-strategy-unit')));
	});

	// Input toggle logic
	const useNavyCheckbox = document.getElementById('use-navy-bf') as HTMLInputElement;
	const navyInputsDiv = document.getElementById('navy-inputs');
	const bodyFatField = document.getElementById('bodyFat')?.closest('.field');

	useNavyCheckbox?.addEventListener('change', () => {
		if (useNavyCheckbox.checked) {
			navyInputsDiv?.classList.remove('hidden');
			bodyFatField?.classList.add('hidden');
			(document.getElementById('bodyFat') as HTMLInputElement).required = false;
			(document.getElementById('waist') as HTMLInputElement).required = true;
			(document.getElementById('neck') as HTMLInputElement).required = true;
		} else {
			navyInputsDiv?.classList.add('hidden');
			bodyFatField?.classList.remove('hidden');
			(document.getElementById('bodyFat') as HTMLInputElement).required = true;
			(document.getElementById('waist') as HTMLInputElement).required = false;
			(document.getElementById('neck') as HTMLInputElement).required = false;
		}
		updateHipVisibility();
	});

	const sexSelect = document.getElementById('sex') as HTMLSelectElement;
	const hipField = document.getElementById('hip-field');

	function updateHipVisibility() {
		const isFemale = sexSelect?.value === 'female';
		const isNavyChecked = useNavyCheckbox?.checked;
		if (isFemale && isNavyChecked) {
			hipField?.classList.remove('hidden');
			(document.getElementById('hip') as HTMLInputElement).required = true;
		} else {
			hipField?.classList.add('hidden');
			(document.getElementById('hip') as HTMLInputElement).required = false;
		}
	}

	sexSelect?.addEventListener('change', updateHipVisibility);

	document.querySelector('#strategy-form')?.addEventListener('submit', (event) => {
		event.preventDefault();
		const form = event.currentTarget as HTMLFormElement;

		const rawInput = {
			sex: form.sex.value,
			age: Number(form.age.value),
			heightCm: strategyUnit === 'metric' ? Number(form.height.value) : inToCm(Number(form.height.value)),
			weightKg: strategyUnit === 'metric' ? Number(form.weight.value) : lbToKg(Number(form.weight.value)),
			bodyFat: Number(form.bodyFat.value || 0),
			activity: form.activity.value,
			trainingAge: form.trainingAge.value,
			goalBias: form.goalBias.value,
			protein: Number(form.protein.value || 0),
		};

		const useNavy = useNavyCheckbox?.checked;
		if (useNavy) {
			const waistCm = strategyUnit === 'metric' ? Number(form.waist.value) : inToCm(Number(form.waist.value));
			const neckCm = strategyUnit === 'metric' ? Number(form.neck.value) : inToCm(Number(form.neck.value));
			const hipCm = strategyUnit === 'metric' ? Number(form.hip.value || 0) : inToCm(Number(form.hip.value || 0));

			rawInput.bodyFat = engineNavyBF({
				sex: rawInput.sex as 'male' | 'female',
				waistCm,
				neckCm,
				hipCm,
				heightCm: rawInput.heightCm
			});
		}

		const proteinAdequate = rawInput.protein ? rawInput.protein >= rawInput.weightKg * 1.6 : false;
		const rec = strategyRecommendation({ ...rawInput, proteinAdequate });
		const bmr = engineMifflin({ sex: rawInput.sex as 'male' | 'female', age: rawInput.age, heightCm: rawInput.heightCm, weightKg: rawInput.weightKg });
		const maintenance = round(bmr * activityFactors[rawInput.activity as keyof typeof activityFactors]);
		const target = calorieTarget(maintenance, rec.recommended);
		const proteinLow = round(rawInput.weightKg * 1.6);
		const proteinHigh = round(rawInput.weightKg * 2.2);

		const saved = { ...rawInput, proteinAdequate, ...rec, maintenance, target, targetBasis: 'recommended', proteinLow, proteinHigh, createdAt: new Date().toISOString() };
		localStorage.setItem('bodycompos.latestAssessment', JSON.stringify(saved));
		localStorage.removeItem('bodycompos.estimatedBodyFat');

		const history = safeJsonParse(localStorage.getItem('bodycompos.assessments'), []);
		history.unshift(saved);
		localStorage.setItem('bodycompos.assessments', JSON.stringify(history.slice(0, 12)));

		let paceText = 'Flat Weight';
		let timelineText = 'Ongoing';
		const rDecay = 0.99;

		if (rec.recommended === 'fat-loss') {
			const pace = -rawInput.weightKg * 0.0075;
			const targetWeightChange = -rawInput.weightKg * 0.08;
			const term = (targetWeightChange * (1 - rDecay)) / pace;
			const etaWeeks = term < 0.99 ? Math.log(1 - term) / Math.log(rDecay) : 16;

			const val = strategyUnit === 'metric' ? `${round(Math.abs(pace), 2)} kg` : `${round(kgToLb(Math.abs(pace)), 2)} lb`;
			paceText = `Lose ~${val}/week`;
			timelineText = `~${round(etaWeeks, 1)} weeks to reach 8% reduction`;
		} else if (rec.recommended === 'lean-bulk') {
			const pace = rawInput.weightKg * 0.002;
			const targetWeightChange = rawInput.weightKg * 0.04;
			const term = (targetWeightChange * (1 - rDecay)) / pace;
			const etaWeeks = term < 0.99 ? Math.log(1 - term) / Math.log(rDecay) : 24;

			const val = strategyUnit === 'metric' ? `${round(pace, 2)} kg` : `${round(kgToLb(pace), 2)} lb`;
			paceText = `Gain ~${val}/week`;
			timelineText = `~${round(etaWeeks, 1)} weeks to build 4% lean mass`;
		} else if (rec.recommended === 'aggressive-bulk') {
			const pace = rawInput.weightKg * 0.004;
			const targetWeightChange = rawInput.weightKg * 0.06;
			const term = (targetWeightChange * (1 - rDecay)) / pace;
			const etaWeeks = term < 0.99 ? Math.log(1 - term) / Math.log(rDecay) : 16;

			const val = strategyUnit === 'metric' ? `${round(pace, 2)} kg` : `${round(kgToLb(pace), 2)} lb`;
			paceText = `Gain ~${val}/week`;
			timelineText = `~${round(etaWeeks, 1)} weeks to target weight`;
		} else if (rec.recommended === 'recomp') {
			paceText = 'Parity (Flat scale)';
			timelineText = '12 - 16 weeks (recommended phase block)';
		}

		const outputContainer = document.querySelector('#strategy-result');
		if (outputContainer) {
			outputContainer.classList.add('has-result');
			outputContainer.innerHTML = `
				<div class="result-content grid gap-4 text-left">
					<div class="flex items-start justify-between gap-3">
						<div>
							<p class="text-xs font-bold uppercase text-accent tracking-wider">Assessment Result</p>
							<p class="mt-1 text-2xl font-black text-foreground">${labels[rec.recommended]}</p>
						</div>
						<span class="badge badge-accent shrink-0 mt-1">${rec.confidence}% Confidence</span>
					</div>

					<div class="grid gap-3 sm:grid-cols-2">
						<div class="result-card">
							<p class="text-[10px] font-bold uppercase text-muted-foreground">Alternative Strategy</p>
							<p class="mt-1 text-base font-bold text-foreground">${labels[rec.alternative]}</p>
							<div class="flex items-center gap-2 mt-1.5">
								<span class="text-[10px] text-muted-foreground">Confidence: ${rec.alternativeConfidence}%</span>
								<div class="mini-bar flex-1 max-w-20"><span style="width:${rec.alternativeConfidence}%"></span></div>
							</div>
						</div>
						<div class="result-card">
							<p class="text-[10px] font-bold uppercase text-muted-foreground">Strategy Confidence</p>
							<p class="mt-1 text-xl font-black text-foreground">${rec.confidence}%</p>
							<div class="mini-bar mt-2"><span style="width:${rec.confidence}%"></span></div>
						</div>
					</div>

					<div class="grid gap-3 sm:grid-cols-2">
						<div class="result-card bg-accent/5 border-accent/20">
							<p class="text-[10px] font-bold uppercase text-accent tracking-wider">Starting Calories</p>
							<p class="mt-1 text-xl font-black text-foreground">${target} <span class="text-[10px] font-normal text-muted-foreground">kcal/day</span></p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Maintenance TDEE: ${maintenance} kcal</p>
						</div>
						<div class="result-card bg-success/5 border-success/20">
							<p class="text-[10px] font-bold uppercase text-success tracking-wider">Protein Range</p>
							<p class="mt-1 text-xl font-black text-foreground">${proteinLow} - ${proteinHigh} <span class="text-[10px] font-normal text-muted-foreground">g/day</span></p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Based on 1.6 - 2.2 g/kg weight</p>
						</div>
					</div>

					<div class="grid gap-3 sm:grid-cols-2">
						<div class="result-card">
							<p class="text-[10px] font-bold uppercase text-muted-foreground">Estimated Weekly Pace</p>
							<p class="mt-1 text-base font-black text-foreground">${paceText}</p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Accounts for metabolic adaptation</p>
						</div>
						<div class="result-card">
							<p class="text-[10px] font-bold uppercase text-muted-foreground">Adaptation Timeline</p>
							<p class="mt-1 text-base font-black text-foreground">${timelineText}</p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Compounding velocity decay model</p>
						</div>
					</div>

					<div class="rounded-xl border border-border bg-muted/20 p-4 text-xs">
						<p class="font-bold text-foreground mb-2 flex items-center gap-1.5">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
							Strategic Assessment Details
						</p>
						<ul class="space-y-1.5 pl-5 list-disc text-muted-foreground">
							<li>Estimated body fat is <strong>${rawInput.bodyFat}%</strong>${useNavy ? ' (Calculated via Navy Circumference Method)' : ' (User entered)'}.</li>
							<li>Classified training status: <strong>${rawInput.trainingAge}</strong>.</li>
							<li>${proteinAdequate ? 'Your reported protein intake is sufficient to preserve active muscle tissue.' : 'Your reported protein is low. We advise elevating protein to prevent lean muscle loss.'}</li>
						</ul>
					</div>

					<div class="rounded-xl border border-border bg-card p-4 text-xs">
						<p class="font-bold text-foreground mb-2 flex items-center gap-1.5">
							<svg class="text-accent" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
							Tactical Dietary & Behavioral Guidelines
						</p>
						<div class="grid gap-3 sm:grid-cols-2 text-[11px] text-muted-foreground leading-relaxed">
							<div>
								<p class="font-bold text-foreground mb-0.5">High-Satiety Volume</p>
								Focus on high-fiber whole foods (leafy greens, cruciferous vegetables, berries) to manage hunger signaling during deficit periods.
							</div>
							<div>
								<p class="font-bold text-foreground mb-0.5">Protein Pacing</p>
								Distribute daily protein across 4-5 servings of 30-40g each to maximize muscle protein synthesis.
							</div>
							<div>
								<p class="font-bold text-foreground mb-0.5">Hydration Preloading</p>
								Drink 350-500ml of water 15-30 minutes before main meals to regulate natural satiety signals.
							</div>
							<div>
								<p class="font-bold text-foreground mb-0.5">NEAT Baseline</p>
								Maintain 8,000-10,000 daily steps to defend metabolic rate against adaptive slowdowns.
							</div>
						</div>
						<div class="mt-3 border-t border-border pt-2.5 text-[10px] text-muted-foreground flex gap-1.5 items-start">
							<svg class="shrink-0 text-accent mt-0.5" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
							<span><strong>Reassessment:</strong> If weight does not shift by at least 0.5kg/1lb after 3 weeks of consistent tracking, metabolic adaptation is likely. Adjust targets by 100-150 kcal.</span>
						</div>
					</div>

					<div class="flex flex-col sm:flex-row gap-3 pt-1">
						<a class="button-primary flex-1 text-center text-sm" href="/dashboard">Track Progress & Forecast</a>
						<button id="save-local-btn" class="button-secondary flex-1 text-sm">
							<span id="save-btn-text">Save to local profile</span>
						</button>
					</div>

					<p class="text-center text-xs text-muted-foreground">
						Use as an estimate. Adjust targets only after tracking 2-4 weeks of consistent weight trends.
					</p>
				</div>
			`;

			const saveBtn = document.getElementById('save-local-btn');
			saveBtn?.addEventListener('click', () => {
				const btnText = document.getElementById('save-btn-text');
				if (btnText) {
					btnText.innerHTML = 'Saved Successfully ✓';
					saveBtn.classList.remove('button-secondary');
					saveBtn.classList.add('bg-success', 'text-white', 'border-success');
					setTimeout(() => {
						btnText.innerHTML = 'Save to local profile';
						saveBtn.classList.remove('bg-success', 'text-white', 'border-success');
						saveBtn.classList.add('button-secondary');
					}, 2500);
				}
			});

			outputContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			(outputContainer as HTMLElement).focus();
		}
	});
</script>
