---
import Layout from '../layouts/Layout.astro';
import { SITE, absoluteUrl } from '../data/site';

const pageTitle = 'Contact & Support | BodyCompOS';
const pageDescription = 'Get in touch with BodyCompOS support, report formula corrections, submit bug reports, or apply to join our editorial review board.';
const canonicalUrl = absoluteUrl('/contact');

const schema = {
	'@context': 'https://schema.org',
	'@type': 'ContactPage',
	name: pageTitle,
	description: pageDescription,
	url: canonicalUrl,
};
---

<Layout title={pageTitle} description={pageDescription} canonical={canonicalUrl} schema={schema}>
	<section class="site-container py-10 sm:py-16">
		<!-- Breadcrumbs -->
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<span class="text-foreground">Contact</span>
		</nav>

		<div class="grid gap-12 lg:grid-cols-[1.2fr_1.8fr] items-start animate-fade-in">
			<!-- Left: Support Channels & General Info -->
			<div>
				<p class="eyebrow">Help Desk & Feedback</p>
				<h1 class="mt-3 text-3xl font-black leading-tight sm:text-4xl text-foreground">Get in touch with us</h1>
				<p class="mt-4 text-sm leading-relaxed text-muted-foreground">
					Because BodyCompOS is a privacy-first, local-first application, your calculations, assessments, and trend data reside entirely in your browser cache. We have no backend server containing your personal stats.
				</p>

				<!-- Support Channels list -->
				<div class="mt-8 space-y-6">
					<div class="flex gap-4 p-4 rounded-xl border border-border bg-card/35">
						<div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 bg-accent/10 text-accent">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
						</div>
						<div>
							<h3 class="font-bold text-sm text-foreground">General Support & Inquiries</h3>
							<p class="text-xs text-muted-foreground mt-1">For interface feedback, feature requests, or general usage support.</p>
							<a href="mailto:yadavdivy77@gmail.com?subject=General Support Inquiry" class="text-xs font-bold text-accent hover:underline mt-2 inline-block">Send Message ➔</a>
						</div>
					</div>

					<div class="flex gap-4 p-4 rounded-xl border border-border bg-card/35">
						<div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 bg-success/10 text-success">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
						</div>
						<div>
							<h3 class="font-bold text-sm text-foreground">Formula Corrections & Science Vetting</h3>
							<p class="text-xs text-muted-foreground mt-1">If you identify a mathematical error or wish to submit clinical citations to improve our calculators.</p>
							<a href="mailto:yadavdivy77@gmail.com?subject=Formula Correction Vetting" class="text-xs font-bold text-accent hover:underline mt-2 inline-block">Send Message ➔</a>
						</div>
					</div>

					<div class="flex gap-4 p-4 rounded-xl border border-border bg-card/35">
						<div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 bg-destructive/10 text-destructive">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
						</div>
						<div>
							<h3 class="font-bold text-sm text-foreground">Security Vulnerability Reports</h3>
							<p class="text-xs text-muted-foreground mt-1">To report client-side vulnerabilities, package leaks, or configuration exploits.</p>
							<a href="mailto:yadavdivy77@gmail.com?subject=Security Vulnerability Report" class="text-xs font-bold text-accent hover:underline mt-2 inline-block">Send Message ➔</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Right: Interactive Contact Form -->
			<div class="content-panel rounded-2xl border border-border bg-card shadow-soft p-6 sm:p-8" id="contact-container">
				<h2 class="text-xl font-bold text-foreground mb-1">Send a Message</h2>
				<p class="text-xs text-muted-foreground mb-6">Need help? Send us a message directly from your browser. Fields marked * are required.</p>

				<form id="contact-form" class="space-y-5" novalidate>
					<!-- Name Field -->
					<div class="field">
						<label for="contact-name">Full Name *</label>
						<input type="text" id="contact-name" name="name" placeholder="John Doe" autocomplete="name" required />
					</div>

					<!-- Email Field -->
					<div class="field">
						<label for="contact-email">Email Address *</label>
						<input type="email" id="contact-email" name="email" placeholder="john@example.com" autocomplete="email" required />
					</div>

					<!-- Category Selector -->
					<div class="field">
						<label for="contact-category">Inquiry Category *</label>
						<div class="select-wrap">
							<select id="contact-category" name="category" required>
								<option value="general" selected>General Feedback & Support</option>
								<option value="correction">Formula Correction / Science Vetting</option>
								<option value="bug">Bug Report / Technical Issue</option>
								<option value="partnership">Editorial Board Application / Business</option>
							</select>
						</div>
					</div>

					<!-- Subject Field -->
					<div class="field">
						<label for="contact-subject">Subject *</label>
						<input type="text" id="contact-subject" name="subject" placeholder="What are you getting in touch about?" required />
					</div>

					<!-- Message Textarea -->
					<div class="field">
						<label for="contact-message">Message *</label>
						<textarea id="contact-message" name="message" rows="5" placeholder="Please enter at least 20 characters detailing your request..." required></textarea>
					</div>

					<!-- Submit Button -->
					<button type="submit" id="contact-submit" class="button-primary w-full mt-2">
						<span>Send Message</span>
					</button>
				</form>
			</div>
		</div>
	</section>
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const form = document.getElementById('contact-form') as HTMLFormElement | null;
		const container = document.getElementById('contact-container') as HTMLElement | null;
		
		if (!form || !container) return;

		// Validation rules
		const validations = {
			name: (val: string) => val.trim().length >= 2 ? '' : 'Name must be at least 2 characters long.',
			email: (val: string) => {
				const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
				if (!val.trim()) return 'Email is required.';
				return regex.test(val.trim()) ? '' : 'Please enter a valid email address.';
			},
			subject: (val: string) => val.trim().length >= 5 ? '' : 'Subject must be at least 5 characters long.',
			message: (val: string) => val.trim().length >= 20 ? '' : 'Message must be at least 20 characters long.',
		};

		// Helper to render error state
		function showError(input: HTMLInputElement | HTMLTextAreaElement, message: string) {
			removeError(input);
			if (!message) return;

			input.classList.add('border-destructive');
			
			const errorP = document.createElement('p');
			errorP.className = 'error-msg text-xs text-destructive mt-1 font-medium';
			errorP.textContent = message;
			
			// Insert after input element
			input.parentNode?.appendChild(errorP);
		}

		// Helper to clear error state
		function removeError(input: HTMLInputElement | HTMLTextAreaElement) {
			input.classList.remove('border-destructive');
			const siblingError = input.parentNode?.querySelector('.error-msg');
			if (siblingError) {
				siblingError.remove();
			}
		}

		// Attach blur validation event listeners
		const inputs = ['name', 'email', 'subject', 'message'];
		inputs.forEach((fieldName) => {
			const input = form.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | HTMLTextAreaElement | null;
			if (!input) return;

			input.addEventListener('blur', () => {
				const errorMsg = validations[fieldName as keyof typeof validations](input.value);
				showError(input, errorMsg);
			});

			input.addEventListener('input', () => {
				const errorMsg = validations[fieldName as keyof typeof validations](input.value);
				if (!errorMsg) {
					removeError(input);
				}
			});
		});

		// Submit listener
		form.addEventListener('submit', (e) => {
			e.preventDefault();

			let isValid = true;
			inputs.forEach((fieldName) => {
				const input = form.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | HTMLTextAreaElement | null;
				if (!input) return;

				const errorMsg = validations[fieldName as keyof typeof validations](input.value);
				if (errorMsg) {
					isValid = false;
					showError(input, errorMsg);
				}
			});

			if (!isValid) return;

			// Capture values for mailto email draft
			const nameVal = (form.querySelector('[name="name"]') as HTMLInputElement).value.trim();
			const emailVal = (form.querySelector('[name="email"]') as HTMLInputElement).value.trim();
			const categoryVal = (form.querySelector('[name="category"]') as HTMLSelectElement).value;
			const subjectVal = (form.querySelector('[name="subject"]') as HTMLInputElement).value.trim();
			const messageVal = (form.querySelector('[name="message"]') as HTMLTextAreaElement).value.trim();

			// Construct mailto link
			const emailBody = `Name: ${nameVal}\nEmail: ${emailVal}\nCategory: ${categoryVal}\n\nMessage:\n${messageVal}`;
			const mailtoUrl = `mailto:yadavdivy77@gmail.com?subject=${encodeURIComponent(`[BodyCompOS Contact] ${subjectVal}`)}&body=${encodeURIComponent(emailBody)}`;

			// Capture user name for validation summary
			const userNameInput = form.querySelector('[name="name"]') as HTMLInputElement;
			const userName = userNameInput.value.trim();

			// Simulate submission locally
			const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.innerHTML = `
					<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
					Sending...
				`;
			}

			// Open default mail client with prefilled data
			window.location.href = mailtoUrl;

			// Transition to success card after 900ms delay
			setTimeout(() => {
				const randomTicket = 'BC-' + Math.floor(10000 + Math.random() * 90000);
				container.classList.add('animate-scale-in');
				container.innerHTML = `
					<div class="text-center py-6">
						<div class="w-16 h-16 rounded-full bg-success/15 text-success flex items-center justify-center mx-auto mb-6">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="20 6 9 17 4 12"/>
							</svg>
						</div>
						<h2 class="text-2xl font-black text-foreground mb-3">Message Sent Successfully</h2>
						<p class="text-sm text-muted-foreground leading-relaxed max-w-md mx-auto mb-6">
							Thank you, <strong class="text-foreground">${userName}</strong>! We have received your inquiry. A confirmation receipt has been logged locally on your device.
						</p>

						<div class="p-4 bg-muted/40 rounded-xl max-w-sm mx-auto mb-8 border border-border text-left">
							<p class="text-xs text-muted-foreground font-semibold uppercase tracking-wider">Local Support Reference</p>
							<div class="flex justify-between items-center mt-2">
								<span class="text-sm font-black text-foreground">${randomTicket}</span>
								<span class="text-xs font-bold text-success bg-success/10 px-2 py-0.5 rounded-full">Logged</span>
							</div>
							<p class="text-[11px] text-muted-foreground leading-normal mt-2">
								Since BodyCompOS is local-first, no account was created. Please retain this support ID for reference when communicating with our team.
							</p>
						</div>

						<button id="contact-reset" class="button-secondary">Send Another Message</button>
					</div>
				`;

				// Reset listener
				document.getElementById('contact-reset')?.addEventListener('click', () => {
					window.location.reload();
				});
			}, 950);
		});
	});
</script>
