---
import Layout from '../../layouts/Layout.astro';
import { DOMAIN } from '../../data/site';

const title = "Phase Transition Calculator - Cut to Bulk Bridge | BodyCompOS";
const description = "Calculate your transition phase parameters when shifting between calorie deficits (cutting) and surpluses (bulking) to optimize hormone recovery.";
const canonical = `${DOMAIN}/tools/phase-transition`;
---

<Layout title={title} description={description} canonical={canonical}>
	<section class="site-container py-10 sm:py-16">
		<div class="max-w-3xl mx-auto">
			<!-- Breadcrumbs -->
			<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
				<a class="hover:text-accent transition-colors" href="/">Home</a>
				<span>/</span>
				<span class="text-foreground">Phase Transition Guide</span>
			</nav>

			<!-- Header -->
			<div class="text-center sm:text-left border-b border-border pb-6 mb-8">
				<p class="eyebrow">Strategic Transitioning</p>
				<h1 class="text-3xl font-black text-foreground sm:text-5xl mt-2">
					Phase Transition <span class="text-accent bg-gradient-to-r from-accent to-success bg-clip-text text-transparent">Calculator</span>
				</h1>
				<p class="text-sm text-muted-foreground mt-2 leading-relaxed">
					Safely transition between cutting and bulking. Calculate metabolic adaptation recovery times, step-up calorie increments, and maintenance milestones to prevent rapid fat rebound.
				</p>
			</div>

			<!-- Form & Calculator -->
			<div class="grid gap-8 lg:grid-cols-[1fr_320px]">
				<div class="surface rounded-2xl p-6 sm:p-8 border border-border shadow-sm space-y-6">
					<form id="transition-form" class="space-y-4">
						<div class="grid gap-4 sm:grid-cols-2">
							<div class="field">
								<label for="currentCal">Current Daily Intake (kcal)</label>
								<input id="currentCal" type="number" min="1000" max="6000" value="1800" required />
							</div>
							<div class="field">
								<label for="maintenanceCal">Target Maintenance Intake (kcal)</label>
								<input id="maintenanceCal" type="number" min="1000" max="6000" value="2300" required />
							</div>
							<div class="field">
								<label for="duration">Last Phase Duration (weeks)</label>
								<input id="duration" type="number" min="2" max="52" value="16" required />
							</div>
							<div class="field">
								<label for="direction">Transition Direction</label>
								<select id="direction" class="w-full bg-card border border-border rounded-xl px-3 py-2 text-xs">
									<option value="cut-to-bulk">Cutting to Bulking (Bridge Phase)</option>
									<option value="bulk-to-cut">Bulking to Cutting</option>
								</select>
							</div>
						</div>
						<button type="submit" class="button-primary w-full text-xs py-3 justify-center">Generate Transition Schedule</button>
					</form>

					<!-- Schedule Results output -->
					<div id="transition-results" class="hidden space-y-6 pt-6 border-t border-border">
						<!-- Loaded dynamically via JS -->
					</div>
				</div>

				<!-- Educational text -->
				<div class="space-y-6">
					<div class="surface rounded-2xl p-5 border border-border">
						<h3 class="font-bold text-xs uppercase tracking-wider text-foreground mb-2">Why Bridge?</h3>
						<p class="text-[10px] text-muted-foreground leading-relaxed">
							Jumping straight from a long-term calorie deficit to a surplus is a recipe for rapid fat regain. A 2-3 week maintenance bridge allows BMR to recover, thyroid hormones to normalize, and leptin levels to stabilize.
						</p>
					</div>

					<div class="surface rounded-2xl p-5 border border-border">
						<h3 class="font-bold text-xs uppercase tracking-wider text-foreground mb-2">Rule of Thumb</h3>
						<p class="text-[10px] text-muted-foreground leading-relaxed">
							Keep calories at estimated maintenance for at least 14 days before adding further surplus calories.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	const form = document.getElementById('transition-form') as HTMLFormElement;
	const resultsDiv = document.getElementById('transition-results');

	form?.addEventListener('submit', (e) => {
		e.preventDefault();
		const current = Number(form.currentCal.value);
		const maint = Number(form.maintenanceCal.value);
		const duration = Number(form.duration.value);
		const direction = form.direction.value;

		const diff = maint - current;
		const bridgeWeeks = Math.max(2, Math.min(4, Math.round(duration / 6)));
		const stepIncrement = Math.round(diff / bridgeWeeks);

		let html = `
			<div class="border-b border-border pb-4">
				<p class="eyebrow">Calculated Bridge Duration</p>
				<h3 class="text-2xl font-black text-foreground mt-1">${bridgeWeeks} Weeks</h3>
				<p class="text-xs text-muted-foreground mt-0.5">Recommended maintenance transition bridge phase</p>
			</div>

			<div class="space-y-3">
				<h4 class="text-sm font-bold text-foreground">Calorie Increment Schedule</h4>
		`;

		for (let w = 1; w <= bridgeWeeks; w++) {
			const targetCal = current + (stepIncrement * w);
			html += `
				<div class="flex justify-between items-center text-xs border-b border-border/40 pb-2">
					<span class="font-bold text-foreground">Week ${w}</span>
					<span class="text-accent font-semibold">${targetCal} kcal/day</span>
				</div>
			`;
		}

		html += `
			</div>
			<div class="rounded-xl border border-border bg-muted/10 p-4 text-xs text-muted-foreground">
				<p class="font-bold text-foreground mb-1">Transition Phase Directives</p>
				<ul class="list-disc pl-4 space-y-1 mt-1 text-[11px]">
					<li>Maintain high protein intakes to assist in metabolic stabilizing.</li>
					<li>Refrain from starting bulk calorie surpluses until weight stabilizes at target maintenance.</li>
					<li>Expect slight water weight fluctuations (1-2 kg) due to glycogen replenishment.</li>
				</ul>
			</div>
		`;

		if (resultsDiv) {
			resultsDiv.classList.remove('hidden');
			resultsDiv.innerHTML = html;
		}
	});
</script>
