---
import Layout from '../../layouts/Layout.astro';
import { DOMAIN } from '../../data/site';

const title = 'Body Composition Strategy Comparisons | BodyCompOS';
const description = 'Side-by-side strategy comparisons. Understand the tradeoffs of cutting vs. recomposing, lean vs. aggressive bulking, and BMI vs. body fat percentage.';
const canonical = `${DOMAIN}/compare`;

const comparisons = [
	{
		href: '/compare/cut-vs-recomp',
		label: 'Fat Loss vs. Recomposition',
		title: 'Cut vs. Body Recomposition',
		description: 'Decide between a dedicated fat loss phase (calorie deficit) and simultaneous fat loss and muscle gain (maintenance). Compare pacing, difficulty, and protein targets.',
		readTime: '6 min read',
		tags: ['Cut', 'Recomp', 'Calorie Deficit'],
		icon: '🔄',
	},
	{
		href: '/compare/lean-bulk-vs-aggressive-bulk',
		label: 'Muscle Growth Rates',
		title: 'Lean Bulk vs. Aggressive Bulk',
		description: 'Should you gain weight slowly with minimal fat spillover, or maximize muscle growth at the cost of additional fat? Compare surplus ranges and timelines.',
		readTime: '5 min read',
		tags: ['Bulk', 'Surplus', 'Muscle Mass'],
		icon: '⚖️',
	},
	{
		href: '/compare/bmi-vs-body-fat-percentage',
		label: 'Composition Indices',
		title: 'BMI vs. Body Fat Percentage',
		description: 'Understand the difference between a simple height-to-weight ratio and a detailed body composition measurement. Learn which index is appropriate for your goals.',
		readTime: '5 min read',
		tags: ['BMI', 'Body Fat', 'FFMI'],
		icon: '📊',
	},
];

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: title,
		description,
		url: canonical,
		publisher: {
			'@type': 'Organization',
			name: 'BodyCompOS',
			logo: { '@type': 'ImageObject', url: `${DOMAIN}/favicon.svg` },
		},
		hasPart: comparisons.map((c) => ({
			'@type': 'Article',
			headline: c.title,
			description: c.description,
			url: `${DOMAIN}${c.href}`,
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: DOMAIN },
			{ '@type': 'ListItem', position: 2, name: 'Compare', item: canonical },
		],
	},
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
	<section class="site-container py-10 sm:py-14">
		<!-- Breadcrumbs -->
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<span class="text-foreground">Compare</span>
		</nav>

		<!-- Hero -->
		<div class="max-w-3xl">
			<p class="eyebrow">Tradeoff Matrices</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl text-foreground">
				Strategy &amp; Metric <br />
				<span class="text-accent bg-gradient-to-r from-accent to-success bg-clip-text text-transparent">Side-by-Side Comparisons</span>
			</h1>
			<p class="mt-5 text-lg leading-relaxed text-muted-foreground max-w-2xl">
				Every training and diet phase involves tradeoffs. Compare metabolic strategies, energy balances, and indices side-by-side to make an informed, science-backed decision.
			</p>
		</div>

		<!-- Comparisons Cards Grid -->
		<div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
			{comparisons.map((item) => (
				<a href={item.href} class="app-card group relative flex flex-col gap-4 hover:border-accent/50 transition-all duration-200" aria-label={`Compare: ${item.title}`}>
					<div class="flex items-start justify-between gap-3">
						<div class="text-2xl" aria-hidden="true">{item.icon}</div>
						<span class="text-xs font-semibold text-muted-foreground bg-muted px-2 py-0.5 rounded-full whitespace-nowrap">{item.readTime}</span>
					</div>
					<div>
						<p class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{item.label}</p>
						<h2 class="text-base font-bold text-foreground group-hover:text-accent transition-colors leading-snug">{item.title}</h2>
						<p class="mt-2 text-sm text-muted-foreground leading-relaxed line-clamp-3">{item.description}</p>
					</div>
					<div class="flex flex-wrap gap-1.5 mt-auto pt-3 border-t border-border">
						{item.tags.map((tag) => (
							<span class="text-xs font-medium text-muted-foreground bg-muted px-2 py-0.5 rounded">{tag}</span>
						))}
					</div>
					<div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</div>
				</a>
			))}
		</div>

		<!-- CTA -->
		<div class="mt-14 content-panel bg-card border border-border rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6 justify-between">
			<div>
				<p class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Unsure about your stats?</p>
				<h2 class="text-xl font-bold text-foreground">Run the interactive Strategy Finder</h2>
				<p class="mt-2 text-sm text-muted-foreground max-w-md">
					Get a science-backed recommendation based on your bio-metrics, body fat, and experience level.
				</p>
			</div>
			<div class="flex flex-col gap-3 shrink-0">
				<a href="/assess" class="button-primary">Start Assessment</a>
			</div>
		</div>
	</section>
</Layout>
