---
import Layout from '../../layouts/Layout.astro';
import { DOMAIN } from '../../data/site';

const title = 'Body Composition Strategy Comparisons | BodyCompOS';
const description = 'Side-by-side strategy comparisons. Understand the tradeoffs of cutting vs. recomposing, lean vs. aggressive bulking, and BMI vs. body fat percentage.';
const canonical = `${DOMAIN}/compare`;

const comparisons = [
	{
		href: '/compare/cut-vs-recomp',
		label: 'Fat Loss vs. Recomposition',
		title: 'Cut vs. Body Recomposition',
		description: 'Decide between a dedicated fat loss phase (calorie deficit) and simultaneous fat loss and muscle gain (maintenance). Compare pacing, difficulty, and protein targets.',
		readTime: '6 min read',
		tags: ['Cut', 'Recomp', 'Calorie Deficit'],
		iconPath: 'M18 20V10M12 20V4M6 20v-6',
	},
	{
		href: '/compare/lean-bulk-vs-aggressive-bulk',
		label: 'Muscle Growth Rates',
		title: 'Lean Bulk vs. Aggressive Bulk',
		description: 'Should you gain weight slowly with minimal fat spillover, or maximize muscle growth at the cost of additional fat? Compare surplus ranges and timelines.',
		readTime: '5 min read',
		tags: ['Bulk', 'Surplus', 'Muscle Mass'],
		iconPath: 'M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1zM4 22v-7',
	},
	{
		href: '/compare/bmi-vs-body-fat-percentage',
		label: 'Composition Indices',
		title: 'BMI vs. Body Fat Percentage',
		description: 'Understand the difference between a simple height-to-weight ratio and a detailed body composition measurement. Learn which index is appropriate for your goals.',
		readTime: '5 min read',
		tags: ['BMI', 'Body Fat', 'FFMI'],
		iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2',
	},
	{
		href: '/compare/mifflin-vs-katch-mcardle',
		label: 'Metabolic Formulas',
		title: 'Mifflin-St Jeor vs. Katch-McArdle',
		description: 'Compare resting metabolic rate calculations. Learn which formula is best for your current body fat and stats.',
		readTime: '4 min read',
		tags: ['BMR', 'TDEE', 'Mifflin'],
		iconPath: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
	},
	{
		href: '/compare/tdee-vs-bmr',
		label: 'Energy Dynamics',
		title: 'TDEE vs. BMR (Metabolic Burn)',
		description: 'What is the difference between resting cellular survival burn (BMR) and active total daily energy expenditure (TDEE)?',
		readTime: '4 min read',
		tags: ['BMR', 'TDEE', 'Deficit'],
		iconPath: 'M13 2L3 14h9l-1 8 10-10h-9l1-8z',
	},
	{
		href: '/compare/clean-bulking-vs-dirty-bulking',
		label: 'Hypertrophy Strategy',
		title: 'Clean Bulking vs. Dirty Bulking',
		description: 'Tradeoffs of a highly controlled, conservative caloric surplus vs. unconstrained calorie intakes for hypertrophy.',
		readTime: '4 min read',
		tags: ['Hypertrophy', 'Bulk', 'Surplus'],
		iconPath: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
	},
	{
		href: '/compare/cardio-vs-weights-for-loss',
		label: 'Training Modalities',
		title: 'Cardio vs. Weight Lifting for Fat Loss',
		description: 'Which exercise type preserves muscle tissue and maximizes overall metabolic rate in a deficit?',
		readTime: '5 min read',
		tags: ['Weights', 'Cardio', 'EPOC'],
		iconPath: 'M12 22a10 10 0 100-20 10 10 0 000 20zM12 6v6l4 2',
	},
];

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: title,
		description,
		url: canonical,
		publisher: {
			'@type': 'Organization',
			name: 'BodyCompOS',
			logo: { '@type': 'ImageObject', url: `${DOMAIN}/favicon.svg` },
		},
		hasPart: comparisons.map((c) => ({
			'@type': 'Article',
			headline: c.title,
			description: c.description,
			url: `${DOMAIN}${c.href}`,
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: DOMAIN },
			{ '@type': 'ListItem', position: 2, name: 'Compare', item: canonical },
		],
	},
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
	<section class="site-container py-10 sm:py-14">
		<!-- Breadcrumbs -->
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<span class="text-foreground">Compare</span>
		</nav>

		<!-- Hero -->
		<div class="max-w-3xl animate-fade-in-up">
			<p class="eyebrow">Tradeoff Matrices</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl text-foreground">
				Strategy &amp; Metric
				<span style="background: linear-gradient(135deg, var(--accent), var(--success)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Side-by-Side Comparisons</span>
			</h1>
			<p class="mt-5 text-lg leading-relaxed text-muted-foreground max-w-2xl">
				Every training and diet phase involves tradeoffs. Compare metabolic strategies, energy balances, and indices side-by-side to make an informed, science-backed decision.
			</p>
		</div>

		<!-- Stats bar -->
		<div class="mt-8 flex flex-wrap gap-6 text-sm text-muted-foreground border-b border-border pb-8">
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
				{comparisons.length} Comparison Tables
			</span>
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
				Referenced meta-analyses
			</span>
		</div>

		<!-- Comparison Cards Grid -->
		<div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
			{comparisons.map((item) => (
				<a href={item.href} class="app-card group relative flex flex-col gap-4" aria-label={`Compare: ${item.title}`}>
					<div class="flex items-start justify-between gap-3">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: color-mix(in srgb, var(--accent) 10%, var(--card));">
							<svg class="text-accent" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d={item.iconPath}/>
							</svg>
						</div>
						<span class="text-xs font-semibold text-muted-foreground bg-muted px-2 py-0.5 rounded-full whitespace-nowrap">{item.readTime}</span>
					</div>
					<div class="flex-1">
						<p class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{item.label}</p>
						<h2 class="text-base font-bold text-foreground group-hover:text-accent transition-colors leading-snug">{item.title}</h2>
						<p class="mt-2 text-sm text-muted-foreground leading-relaxed line-clamp-3">{item.description}</p>
					</div>
					<div class="flex flex-wrap gap-1.5 mt-auto pt-3 border-t border-border">
						{item.tags.map((tag) => (
							<span class="text-xs font-medium text-muted-foreground bg-muted px-2 py-0.5 rounded">{tag}</span>
						))}
					</div>
					<div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</div>
				</a>
			))}
		</div>

		<!-- CTA -->
		<div class="mt-14 content-panel bg-card border border-border rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6 justify-between"
			style="background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 5%, var(--card)), var(--card));">
			<div>
				<p class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Unsure about your stats?</p>
				<h2 class="text-xl font-bold text-foreground">Run the interactive Strategy Finder</h2>
				<p class="mt-2 text-sm text-muted-foreground max-w-md">
					Get a science-backed recommendation based on your bio-metrics, body fat, and experience level.
				</p>
			</div>
			<div class="flex flex-col gap-3 shrink-0">
				<a href="/assess" class="button-primary">Start Free Assessment</a>
				<a href="/calculators/body-fat-calculator" class="button-secondary text-center text-sm">Estimate Body Fat %</a>
			</div>
		</div>
	</section>
</Layout>
