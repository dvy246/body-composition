---
import Layout from '../../layouts/Layout.astro';
import { SITE, calculators, absoluteUrl } from '../../data/site';

const calorieSlugs = [
	'tdee-calculator',
	'calorie-calculator',
	'calorie-cycling-calculator',
	'maintenance-calorie-calculator',
	'calorie-deficit-calculator',
	'calorie-surplus-calculator',
	'target-calorie-calculator',
	'daily-calorie-needs-calculator',
	'weight-loss-calories-calculator',
	'weight-gain-calories-calculator'
];

const calorieCalculators = calculators.filter(c => calorieSlugs.includes(c.slug));

const canonicalUrl = absoluteUrl('/calculators/calories');

// ItemList schema for SEO
const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Evidence-Based Calorie & Energy Calculators',
	description: 'A dedicated collection of scientific calorie planning, TDEE, BMR, deficit, and surplus calculators for body composition strategy.',
	url: canonicalUrl,
	numberOfItems: calorieCalculators.length,
	itemListElement: calorieCalculators.map((calc, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: calc.title,
		url: absoluteUrl(`/calculators/${calc.slug}`),
		description: calc.description,
	})),
};

const faqEntries = [
	['What is the best formula for calculating calorie needs?', 'For most individuals, the Mifflin-St Jeor equation is highly accurate. For athletes or lean individuals with reliable body fat data, the Katch-McArdle formula is superior as it accounts for Lean Body Mass (LBM) directly.'],
	['How large should my calorie deficit be for fat loss?', 'A moderate deficit of 15% to 20% below maintenance is recommended. This preserves active skeletal muscle tissue and maintains workout performance, whereas extreme deficits trigger muscle catabolism and metabolic adaptation.'],
	['How does activity level affect daily calorie needs?', 'Your Total Daily Energy Expenditure (TDEE) is calculated by multiplying your resting metabolic rate (BMR) by a physical activity factor. Sizing activity accurately prevents overestimating energy budgets.'],
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqEntries.map(([q, a]) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: {
			'@type': 'Answer',
			text: a,
		},
	})),
};
---

<Layout
	title="Calorie & Energy Calculators Hub — Scientific TDEE, Deficit, & Surplus | BodyCompOS"
	description="Discover our dedicated suite of evidence-based calorie calculators. Calculate maintenance calories (TDEE), resting metabolic rate (BMR), weight loss deficits, bulking surpluses, and daily calorie needs."
	canonical={canonicalUrl}
	schema={[itemListSchema, faqSchema]}
>
	<section class="site-container py-12 sm:py-16">
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<a class="hover:text-accent transition-colors" href="/calculators">Calculators</a>
			<span>/</span>
			<span class="text-foreground">Calorie Hub</span>
		</nav>

		<div class="max-w-3xl">
			<p class="eyebrow">Core Content Hub</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl">Calorie & Energy Calculators</h1>
			<p class="mt-5 text-lg leading-8 text-muted-foreground">
				Construct your nutritional strategy with our dedicated calorie calculators. Isolate resting metabolism (BMR), Total Daily Energy Expenditure (TDEE), cycling splits, and target rates of change.
			</p>
		</div>

		<!-- Calculators Grid -->
		<div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{calorieCalculators.map((calc) => (
				<a class="app-card block group" href={`/calculators/${calc.slug}`}>
					<div class="flex justify-between items-start">
						<h3 class="font-bold text-sm text-foreground group-hover:text-accent transition-colors">
							{calc.title}
						</h3>
						<svg class="text-muted-foreground group-hover:text-accent transition-colors shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</div>
					<p class="mt-2 text-xs text-muted-foreground leading-relaxed line-clamp-3">
						{calc.description}
					</p>
					<div class="mt-4 flex flex-wrap gap-1">
						{calc.primaryInputs.slice(0, 3).map((input) => (
							<span class="text-xs font-semibold text-muted-foreground bg-muted px-1.5 py-0.5 rounded">
								{input}
							</span>
						))}
						{calc.primaryInputs.length > 3 && (
							<span class="text-xs font-semibold text-muted-foreground bg-muted px-1.5 py-0.5 rounded">
								+{calc.primaryInputs.length - 3} more
							</span>
						)}
					</div>
				</a>
			))}
		</div>

		<!-- Deep Scientific Pillar Content (YMYL & E-E-A-T Optimization) -->
		<div class="prose-lite mt-16 content-panel bg-card border border-border p-6 sm:p-10 rounded-2xl shadow-sm">
			<div class="border-b border-border pb-5 mb-5 flex flex-col sm:flex-row justify-between sm:items-end gap-3">
				<div>
					<h2 class="text-2xl font-black text-foreground">Calorie Calculation Science</h2>
					<p class="text-xs text-muted-foreground mt-1 font-sans">Scientific physiology review for calorie targeting</p>
				</div>
				<div class="text-left sm:text-right shrink-0 font-sans">
					<p class="text-xs font-semibold text-foreground">Reviewed by BodyCompOS Review Board</p>
					<p class="text-[10px] text-muted-foreground mt-0.5">Last updated: June 27, 2026</p>
				</div>
			</div>

			<div class="text-sm leading-relaxed text-muted-foreground space-y-6">
				<p class="text-foreground font-medium text-base">
					To optimize body composition, energy balance remains the fundamental physical constraint. Sizing your daily calorie budget correctly represents the single most critical factor in driving fat mobilization or providing the energy needed to build muscle tissue.
				</p>

				<h3 class="text-lg font-black text-foreground pt-4 border-t border-border/40 font-sans">1. Baseline Metabolism: Mifflin-St Jeor vs. Katch-McArdle</h3>
				<p>
					All daily energy calculations begin with your <strong>Basal Metabolic Rate (BMR)</strong> — the energy required for cellular maintenance at complete rest. BodyCompOS implements two validated models:
				</p>
				<ul class="list-disc pl-5 space-y-2">
					<li><strong>Mifflin-St Jeor:</strong> Derived from population statistics (using sex, age, height, and weight). It is the clinical gold standard for the general public, carrying a small predictive error margin.</li>
					<li><strong>Katch-McArdle:</strong> Bypasses biological averages by using <strong>Lean Body Mass (LBM)</strong> directly. For individuals with highly developed muscle mass or low body fat, this formula prevents underestimating metabolic requirements.</li>
				</ul>

				<h3 class="text-lg font-black text-foreground pt-4 border-t border-border/40 font-sans">2. Energy Budgets: Deficits, Surpluses, & Satiety</h3>
				<p>
					Once your TDEE is calculated, target calories are adjusted depending on strategy:
				</p>
				<ul class="list-disc pl-5 space-y-2">
					<li><strong>Fat Loss (Cut):</strong> Sized at a moderate 15-20% deficit below maintenance to mobilize adipose tissue while protecting active skeletal muscle.</li>
					<li><strong>Muscle Gain (Lean Bulk):</strong> Sized at a conservative 5-8% surplus to support muscle protein synthesis without triggering excess fat storage.</li>
					<li><strong>Body Recomposition:</strong> Near maintenance (typically a minor 2% deficit) to build muscle and lose fat simultaneously, ideal for beginners or returnees.</li>
				</ul>

				<h3 class="text-lg font-black text-foreground pt-4 border-t border-border/40 font-sans">3. Preventing Metabolic Adaptation</h3>
				<p>
					Extended calorie restriction causes metabolic adaptation — a biological reduction in daily energy expenditure to protect survival. Tracking daily metrics, keeping protein high, and incorporating structured calorie cycling splits (higher calorie training days; lower calorie rest days) protects your hormonal profile and ensures long-term progress.
				</p>
			</div>

			<!-- FAQ Section -->
			<div class="mt-12 border-t border-border pt-8">
				<h3 class="text-xl font-black text-foreground mb-6 flex items-center gap-2 font-sans">
					<svg class="text-accent shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
					Frequently Asked Questions
				</h3>
				<div class="space-y-4">
					{faqEntries.map(([q, a]) => (
						<div class="rounded-xl border border-border bg-muted/10 p-5 hover:border-border/80 transition-colors">
							<h4 class="text-sm font-bold text-foreground flex items-start gap-1.5 leading-snug font-sans">
								<span class="text-accent shrink-0 mt-0.5">Q:</span>
								{q}
							</h4>
							<p class="text-xs text-muted-foreground mt-2 leading-relaxed pl-5">{a}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>
</Layout>
