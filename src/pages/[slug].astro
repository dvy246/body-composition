---
import Layout from '../layouts/Layout.astro';
import { calculators, infoPages, DOMAIN } from '../data/site';
import Author from '../components/Author.astro';

export function getStaticPaths() {
	return infoPages.map((page) => ({
		params: { slug: page.slug },
		props: { page },
	}));
}

const { page } = Astro.props;

// Compile dynamic structured schemas
const schemas = [];

if (page.type === 'Article') {
	schemas.push({
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: page.title,
		description: page.description,
		datePublished: '2026-06-24',
		dateModified: '2026-06-24',
		author: {
			'@type': 'Organization',
			name: 'BodyCompOS',
			url: `${DOMAIN}/about`,
		},
		reviewer: {
			'@type': 'Organization',
			name: 'BodyCompOS Scientific Review Board',
			url: `${DOMAIN}/about`,
		},
		publisher: {
			'@type': 'Organization',
			name: 'BodyCompOS',
			url: `${DOMAIN}`,
			logo: {
				'@type': 'ImageObject',
				url: `${DOMAIN}/favicon.svg`,
				width: 32,
				height: 32,
			},
		},
	});
} else if (page.type === 'FAQPage' && page.faqs && page.faqs.length > 0) {
	schemas.push({
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: page.faqs.map(([q, a]) => ({
			'@type': 'Question',
			name: q,
			acceptedAnswer: {
				'@type': 'Answer',
				text: a,
			},
		})),
	});
} else if (page.type === 'ContactPage') {
	schemas.push({
		'@context': 'https://schema.org',
		'@type': 'ContactPage',
		name: page.title,
		description: page.description,
		url: `${DOMAIN}/${page.slug}`,
	});
}
---

<Layout 
	title={`${page.title} | BodyCompOS`} 
	description={page.description} 
	canonical={`${DOMAIN}/${page.slug}`}
	schema={schemas}
>
	<section class="site-container py-10 sm:py-12">
		<!-- Breadcrumbs -->
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<span class="text-foreground">{page.title}</span>
		</nav>

		<!-- Content Hero -->
		<div class="max-w-3xl">
			<p class="eyebrow">Information Hub</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl text-foreground">{page.title}</h1>
			<p class="mt-5 text-lg leading-relaxed text-muted-foreground">{page.description}</p>
		</div>

		<!-- Main editorial body -->
		<div class="mt-10 max-w-4xl content-panel bg-card border border-border">
			<div class="prose-lite space-y-8">
				{page.sections.map(([heading, body]) => (
					<section class="border-b border-border last:border-b-0 pb-6 last:pb-0">
						<h2 class="text-xl font-bold text-foreground mb-3">{heading}</h2>
						{body.includes(' | ') ? (
							<ul class="list-disc pl-5 space-y-2.5">
								{body.split(' | ').map((item) => (
									<li class="text-sm leading-relaxed text-muted-foreground">{item}</li>
								))}
							</ul>
						) : (
							<p class="text-sm leading-relaxed text-muted-foreground">{body}</p>
						)}
					</section>
				))}
			</div>
		</div>

		{page.slug === 'about' && (
			<div class="mt-10 max-w-4xl">
				<h2 class="text-xl font-bold text-foreground mb-5">Meet the Founder</h2>
				<Author />
			</div>
		)}

		<!-- FAQs list inside FAQ Hub page -->
		{page.slug === 'faq' && (
			<div class="mt-10 max-w-4xl">
				<h2 class="text-xl font-bold text-foreground mb-5">Frequently Asked Questions</h2>
				<div class="space-y-3">
					{page.faqs.map(([q, a]) => (
						<div class="rounded-xl border border-border bg-card p-5">
							<h3 class="font-bold text-sm text-foreground">{q}</h3>
							<p class="mt-2 text-xs leading-relaxed text-muted-foreground">{a}</p>
						</div>
					))}
				</div>

				<h3 class="text-lg font-bold text-foreground mt-10 mb-4">Jump Directly to Supporting Calculators</h3>
				<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
					{calculators.slice(0, 6).map((calc) => (
						<a class="app-card block group" href={`/calculators/${calc.slug}`}>
							<div class="flex justify-between items-center">
								<span class="text-sm font-bold text-foreground group-hover:text-accent transition-colors">
									{calc.title}
								</span>
								<svg class="text-muted-foreground group-hover:text-accent transition-colors shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
							</div>
							<p class="mt-2 text-xs text-muted-foreground leading-relaxed line-clamp-2">
								{calc.description}
							</p>
						</a>
					))}
				</div>
			</div>
		)}
	</section>
</Layout>
