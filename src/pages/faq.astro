---
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../data/site';

const canonicalUrl = absoluteUrl('/faq');

const faqList = [
	{
		q: "What is a calorie deficit and how does it cause weight loss?",
		a: "A calorie deficit occurs when you consume fewer calories than your body burns to sustain life and activity. To cover the energy deficit, your body mobilizes stored fat and glycogen, leading to weight loss. Sizing a moderate deficit (15% to 20% below your maintenance calories) protects muscle tissue and prevents metabolic adaptation."
	},
	{
		q: "How do you calculate maintenance calories (TDEE)?",
		a: "To calculate maintenance calories, first estimate your Basal Metabolic Rate (BMR) using variables like sex, age, height, and weight via the Mifflin-St Jeor formula (or Katch-McArdle if body fat is known). Then multiply BMR by your physical activity factor (ranging from 1.2 for sedentary up to 1.9 for athletes)."
	},
	{
		q: "How much protein do I need per day?",
		a: "Active individuals should target 1.6 to 2.2 grams of protein per kilogram of body weight (0.73 to 1.0 gram per pound) daily. If you are in a calorie deficit (cutting), leaning toward the higher end (2.2g/kg) is recommended to satisfy hunger and defend muscle mass from catabolism."
	},
	{
		q: "What is body recomposition and how does it work?",
		a: "Body recomposition is the process of building muscle while losing fat at the same time. It works by eating near maintenance calories (typically a tiny 2% deficit), keeping protein high (2.2 g/kg), and training with heavy resistance to stimulate hypertrophy. It works best for beginners or those returning from a break."
	},
	{
		q: "How do you measure and calculate body fat percentage?",
		a: "The most practical at-home method is the US Navy Circumference Method. Wrap a tape measure horizontally around your neck and waist (and hips for females) under consistent morning conditions. The calculator applies logarithmic density equations to estimate body fat percentage within a ±3-4% margin."
	},
	{
		q: "What is a healthy body fat percentage for men and women?",
		a: "A healthy range for adult males is generally 10% to 20% (athletic range is 8% to 15%). For adult females, the healthy range is 18% to 28% (athletic range is 14% to 22%). Dropping below these ranges (e.g. <8% for men, <15% for women) triggers hormonal fatigue and health risks."
	},
	{
		q: "What is FFMI and how is it used?",
		a: "FFMI stands for Fat-Free Mass Index, which measures muscle mass relative to height. Unlike BMI, it differentiates between muscle and fat. The calculation divides lean body mass in kg by height in meters squared and applies a height correction. It is used to gauge muscular development and natural genetic limits."
	},
	{
		q: "What is BMI and is it accurate?",
		a: "BMI (Body Mass Index) is a simple weight-to-height screening ratio. While useful for general population statistics, it is inaccurate for individuals who carry high amounts of muscle tissue, as it classifies them as 'overweight' or 'obese' despite low body fat. Interpret it alongside body fat measurements."
	},
	{
		q: "How to gain muscle mass efficiently?",
		a: "To maximize muscle gain, consume a controlled calorie surplus (5% to 10% above maintenance, or 200-400 kcal) to supply building blocks without excessive fat storage, consume adequate protein (1.6-2.2 g/kg), lift with progressive overload, and get 7-9 hours of quality sleep."
	},
	{
		q: "Can I lose fat and build muscle at the same time?",
		a: "Yes, this process is called body recomposition. It is highly effective for beginners, individuals returning from a lay-off, or people with a higher initial body fat percentage. To achieve this, maintain a small calorie deficit or eat at maintenance, hit daily protein targets of 1.6 to 2.2 grams per kilogram, and lift weights with progressive overload."
	},
	{
		q: "Why does scale weight stall when my body shape is changing?",
		a: "Muscle tissue is significantly denser than fat tissue. When you build muscle and burn fat at the same time, your body composition improves and your waist shrinks, but your net weight on the scale may remain completely stable. Rely on waist circumference measurements and progress photos instead of the scale."
	}
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqList.map(item => ({
		"@type": "Question",
		"name": item.q,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": `<p>${item.a}</p>`
		}
	}))
};
---

<Layout
	title="Frequently Asked Questions — Science-Backed Body Composition FAQ | BodyCompOS"
	description="Find answers to all your body composition questions. Clear, evidence-based answers covering calorie deficits, protein targets, TDEE, body fat, recomposition, and BMI."
	canonical={canonicalUrl}
	schema={[faqSchema]}
>
	<section class="site-container py-12 sm:py-16">
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<span class="text-foreground">FAQ</span>
		</nav>

		<div class="max-w-3xl mb-12">
			<p class="eyebrow">Platform Knowledge Base</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl text-foreground">Frequently Asked Questions</h1>
			<p class="mt-4 text-base sm:text-lg leading-relaxed text-muted-foreground">
				Evidence-based physiological answers to the most common questions regarding calorie deficits, macronutrient splits, body fat, muscle building, and metabolic rate calculations.
			</p>
		</div>

		<!-- FAQs Categories -->
		<div class="grid gap-8 lg:grid-cols-2">
			<div class="space-y-4">
				{faqList.slice(0, Math.ceil(faqList.length / 2)).map((item, idx) => (
					<details class="group rounded-xl border border-border bg-card p-5 transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
						<summary class="flex cursor-pointer items-center justify-between gap-1.5 text-foreground">
							<h3 class="font-bold text-sm text-foreground group-hover:text-accent transition-colors font-sans leading-snug">
								{item.q}
							</h3>
							<span class="shrink-0 rounded-full bg-muted p-1 text-muted-foreground group-open:rotate-180 transition-transform duration-300">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
							</span>
						</summary>
						<p class="mt-3 text-xs text-muted-foreground leading-relaxed border-t border-border/40 pt-3">
							{item.a}
						</p>
					</details>
				))}
			</div>

			<div class="space-y-4">
				{faqList.slice(Math.ceil(faqList.length / 2)).map((item, idx) => (
					<details class="group rounded-xl border border-border bg-card p-5 transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
						<summary class="flex cursor-pointer items-center justify-between gap-1.5 text-foreground">
							<h3 class="font-bold text-sm text-foreground group-hover:text-accent transition-colors font-sans leading-snug">
								{item.q}
							</h3>
							<span class="shrink-0 rounded-full bg-muted p-1 text-muted-foreground group-open:rotate-180 transition-transform duration-300">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
							</span>
						</summary>
						<p class="mt-3 text-xs text-muted-foreground leading-relaxed border-t border-border/40 pt-3">
							{item.a}
						</p>
					</details>
				))}
			</div>
		</div>

		<!-- Bottom callout -->
		<div class="mt-16 content-panel p-6 rounded-2xl border border-border text-center max-w-2xl mx-auto bg-muted/10">
			<h4 class="font-bold text-foreground text-sm font-sans">Have a more specific question?</h4>
			<p class="text-xs text-muted-foreground mt-1 leading-relaxed">
				Run a full strategy assessment to get tailored caloric targets, protein guides, and progress timelines.
			</p>
			<div class="mt-4 flex flex-wrap justify-center gap-3">
				<a href="/assess" class="button-primary text-xs">Run Strategy Finder ➔</a>
				<a href="/calculators" class="button-secondary text-xs">Browse Calculators</a>
			</div>
		</div>
	</section>
</Layout>
