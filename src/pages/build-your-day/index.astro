---
import Layout from '../../layouts/Layout.astro';
import { DOMAIN } from '../../data/site';

const title = 'Build Your Day – Daily Nutrition Strategy for Body Composition | BodyCompOS';
const description = 'Translate your calorie and protein targets into real meals. Get strategy-specific food guidance, portion estimates, and a daily checklist for cutting, bulking, recomp, or maintenance.';
const canonical = `${DOMAIN}/build-your-day`;

const strategies = [
	{
		href: '/build-your-day/cutting',
		label: 'Fat Loss',
		title: 'Cutting Nutrition Guide',
		description: 'Structured nutrition for a calorie deficit. High-protein, high-volume foods that maximize satiety while preserving muscle mass.',
		tags: ['Cutting', 'Fat Loss', 'Deficit'],
		iconPath: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
		color: 'text-accent',
	},
	{
		href: '/build-your-day/lean-bulk',
		label: 'Muscle Gain',
		title: 'Lean Bulk Nutrition Guide',
		description: 'Controlled surplus nutrition for steady muscle growth. Calorie-dense, nutrient-rich foods that support training performance and recovery.',
		tags: ['Lean Bulk', 'Muscle Gain', 'Surplus'],
		iconPath: 'M13 2L3 14h9l-1 8 10-10h-9l1-8z',
		color: 'text-success',
	},
	{
		href: '/build-your-day/aggressive-bulk',
		label: 'Aggressive Muscle Gain',
		title: 'Aggressive Bulk Nutrition Guide',
		description: 'Higher surplus nutrition for maximum muscle growth. Energy-dense foods with strategic meal timing for those with very low body fat.',
		tags: ['Aggressive Bulk', 'Mass', 'Surplus'],
		iconPath: 'M12 2L2 7l10 5 10-5-10-5M2 17l10 5 10-5M2 12l10 5 10-5',
		color: 'text-warning',
	},
	{
		href: '/build-your-day/recomp',
		label: 'Recomposition',
		title: 'Body Recomp Nutrition Guide',
		description: 'Simultaneous fat loss and muscle gain nutrition. Protein-focused, balanced macronutrients for those maintaining near-maintenance calories.',
		tags: ['Recomp', 'Body Recomposition', 'Maintenance'],
		iconPath: 'M18 20V10M12 20V4M6 20v-6',
		color: 'text-accent',
	},
	{
		href: '/build-your-day/maintain',
		label: 'Maintenance',
		title: 'Maintenance Nutrition Guide',
		description: 'Sustainable nutrition for weight stability. Balanced macronutrients with flexible meal timing for long-term adherence.',
		tags: ['Maintain', 'Maintenance', 'Stable'],
		iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2',
		color: 'text-accent',
	},
];

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: title,
		description,
		url: canonical,
		publisher: {
			'@type': 'Organization',
			name: 'BodyCompOS',
			logo: { '@type': 'ImageObject', url: `${DOMAIN}/favicon.svg` },
		},
		hasPart: strategies.map((s) => ({
			'@type': 'Article',
			headline: s.title,
			description: s.description,
			url: `${DOMAIN}${s.href}`,
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: DOMAIN },
			{ '@type': 'ListItem', position: 2, name: 'Build Your Day', item: canonical },
		],
	},
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
	<section class="site-container py-10 sm:py-14">
		<!-- Breadcrumbs -->
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<span class="text-foreground">Build Your Day</span>
		</nav>

		<!-- Hero -->
		<div class="max-w-4xl animate-fade-in-up">
			<p class="eyebrow">Personalized Nutrition Framework</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl text-foreground">
				Build Your Day
				<span style="background: linear-gradient(135deg, var(--accent), var(--success)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Daily Nutrition Strategy</span>
			</h1>
			<p class="mt-5 text-lg leading-relaxed text-muted-foreground max-w-3xl">
				You know your calorie and protein targets. Now see what that looks like in real food. Choose your strategy below for strategy-specific food guidance, meal distribution, and a daily checklist.
			</p>
		</div>

		<!-- Auto-detect banner -->
		<div id="strategy-detected-banner" class="mt-8 hidden rounded-xl border border-accent/20 bg-accent/5 p-5">
			<div class="flex items-start gap-3">
				<svg class="shrink-0 text-accent mt-0.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
				<div>
					<p class="font-bold text-foreground text-sm">Your strategy was detected</p>
					<p class="text-xs text-muted-foreground mt-1">Based on your saved assessment, we recommend starting with <strong id="detected-strategy-name">your strategy</strong>.</p>
					<div class="flex gap-3 mt-3">
						<a id="detected-strategy-link" href="#" class="button-primary text-xs">Open Your Strategy</a>
						<button id="dismiss-banner-btn" class="button-secondary text-xs">Browse All</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Stats Bar -->
		<div class="mt-8 flex flex-wrap gap-6 text-sm text-muted-foreground border-b border-border pb-8">
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
				{strategies.length} Strategy Guides
			</span>
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
				~30 min total reading
			</span>
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
				ISSN & ACSM cited
			</span>
		</div>

		<!-- Strategy Cards Grid -->
		<div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
			{strategies.map((s) => (
				<a href={s.href} class="app-card group relative flex flex-col gap-4 strategy-card" data-strategy={s.label.toLowerCase().replace(/\s+/g, '-')}>
					<div class="flex items-start justify-between gap-3">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: color-mix(in srgb, var(--accent) 10%, var(--card));">
							<svg class={s.color} width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d={s.iconPath}/>
							</svg>
						</div>
					</div>
					<div class="flex-1">
						<p class="text-xs font-bold uppercase tracking-wider {s.color} mb-1">{s.label}</p>
						<h2 class="text-base font-bold text-foreground group-hover:text-accent transition-colors leading-snug">{s.title}</h2>
						<p class="mt-2 text-sm text-muted-foreground leading-relaxed line-clamp-3">{s.description}</p>
					</div>
					<div class="flex flex-wrap gap-1.5 mt-auto pt-3 border-t border-border">
						{s.tags.map((tag) => (
							<span class="text-xs font-medium text-muted-foreground bg-muted px-2 py-0.5 rounded">{tag}</span>
						))}
					</div>
					<div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</div>
				</a>
			))}
		</div>

		<!-- CTA Section -->
		<div class="mt-14 content-panel bg-card border border-border rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6 justify-between"
			style="background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 5%, var(--card)), var(--card));">
			<div>
				<p class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Don't have your targets yet?</p>
				<h2 class="text-xl font-bold text-foreground">Run the Strategy Finder first</h2>
				<p class="mt-2 text-sm text-muted-foreground max-w-md">
					Get your personalized calorie and protein targets in 60 seconds. Then return here to build your day.
				</p>
			</div>
			<div class="flex flex-col gap-3 shrink-0">
				<a href="/assess" class="button-primary">Start Free Assessment</a>
				<a href="/body-composition-strategy-guide" class="button-secondary text-center text-sm">Full Strategy Guide →</a>
			</div>
		</div>
	</section>
</Layout>

<script>
	// Auto-detect user's strategy from localStorage
	const assessment = JSON.parse(localStorage.getItem('bodycompos.latestAssessment') || 'null');
	if (assessment && assessment.recommended) {
		const strategyMap = {
			'fat-loss': { name: 'Cutting', path: '/build-your-day/cutting' },
			'lean-bulk': { name: 'Lean Bulk', path: '/build-your-day/lean-bulk' },
			'aggressive-bulk': { name: 'Aggressive Bulk', path: '/build-your-day/aggressive-bulk' },
			'recomp': { name: 'Body Recomposition', path: '/build-your-day/recomp' },
			'maintain': { name: 'Maintenance', path: '/build-your-day/maintain' },
		};
		const detected = strategyMap[assessment.recommended] || null;
		if (detected) {
			const banner = document.getElementById('strategy-detected-banner');
			const nameEl = document.getElementById('detected-strategy-name');
			const linkEl = document.getElementById('detected-strategy-link') as HTMLAnchorElement;
			if (banner && nameEl && linkEl) {
				nameEl.textContent = detected.name;
				linkEl.href = detected.path;
				banner.classList.remove('hidden');
			}
		}
	}

	// Dismiss banner
	const dismissBtn = document.getElementById('dismiss-banner-btn');
	if (dismissBtn) {
		dismissBtn.addEventListener('click', () => {
			const banner = document.getElementById('strategy-detected-banner');
			if (banner) banner.classList.add('hidden');
		});
	}
</script>
