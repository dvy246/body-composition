---
import Layout from '../../layouts/Layout.astro';
import { DOMAIN, articleSchema } from '../../data/site';
import AuthorAttribution from '../../components/AuthorAttribution.astro';
import Author from '../../components/Author.astro';
import QuickAnswer from '../../components/QuickAnswer.astro';
import TableOfContents from '../../components/TableOfContents.astro';

const tocItems = [
	{ href: '#your-targets', label: 'Your Daily Targets', shortLabel: 'Your Targets' },
	{ href: '#food-focus', label: 'Food Focus for Maintenance', shortLabel: 'Food Focus' },
	{ href: '#meal-distribution', label: 'Meal Distribution', shortLabel: 'Meal Distribution' },
	{ href: '#eating-situations', label: 'Eating Situations', shortLabel: 'Eating Situations' },
	{ href: '#beyond-macros', label: 'Beyond Macros', shortLabel: 'Beyond Macros' },
	{ href: '#checklist', label: "Today's Checklist", shortLabel: 'Checklist' },
	{ href: '#faq', label: 'Frequently Asked Questions', shortLabel: 'FAQ' },
	{ href: '#next-steps', label: 'Next Steps' }
];

const toolLink = {
	href: '/assess',
	label: 'Strategy Finder',
	desc: 'Get personalized calorie and protein targets for your maintenance phase.',
	buttonText: 'Run Strategy Finder'
};

const title = "Maintenance Nutrition Guide – How to Eat at Maintenance Calories | BodyCompOS";
const description = "Personalized maintenance nutrition guide. Learn how to eat at maintenance calories, stay weight stable, and use the daily checklist for long-term adherence.";
const canonical = `${DOMAIN}/build-your-day/maintain`;

const faqEntries = [
	['How many calories do I need for maintenance?', 'Your maintenance TDEE is the number of calories that keeps your weight stable. This changes as your weight changes. Recalculate every 5 kg of weight change using the Calorie Calculator.'],
	['What protein intake is best for maintenance?', 'Target 1.6-2.0 g per kg of body weight. This supports muscle protein synthesis without the higher requirements of a deficit or surplus. You have more flexibility in food choices during maintenance.'],
	['Can I take diet breaks during maintenance?', 'Diet breaks of 2-4 weeks at maintenance are recommended after 12-16 weeks of cutting. They help restore metabolic rate, normalize hunger hormones, and improve long-term adherence.'],
	['How do I know if I am truly at maintenance?', 'Track your weight for 2-3 weeks. If your weekly average stays within ±0.5 kg, you are at maintenance. If it trends up or down, adjust by 100-150 kcal and re-evaluate.'],
	['Do I need to track food during maintenance?', 'Tracking is helpful initially to learn what maintenance looks like. After 4-6 weeks of consistent tracking, many people can maintain without tracking by eating intuitively while monitoring weight trends weekly.'],
];
const schema = [
	articleSchema(title, description, canonical),
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqEntries.map(([q, a]) => ({
			'@type': 'Question',
			name: q,
			acceptedAnswer: {
				'@type': 'Answer',
				text: a,
			},
		})),
	},
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
	<section class="site-container py-10 sm:py-12">
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2 flex-wrap" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors whitespace-nowrap" href="/">Home</a>
			<span>/</span>
			<a class="hover:text-accent transition-colors whitespace-nowrap" href="/build-your-day">Build Your Day</a>
			<span>/</span>
			<span class="text-foreground whitespace-nowrap">Maintain</span>
		</nav>

		<div class="max-w-4xl">
			<p class="eyebrow">Weight Stability</p>
			<h1 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-black leading-tight text-foreground">
				Maintenance Nutrition Guide
				<span class="text-accent bg-gradient-to-r from-accent to-success bg-clip-text text-transparent block sm:inline"> Sustain Your Results</span>
			</h1>
			<p class="mt-5 text-base sm:text-lg leading-relaxed text-muted-foreground">
				For maintenance, eat at your TDEE level with 1.6-2.0 g protein per kg. Focus on dietary variety and flexibility. Maintenance is not a break — it is an active phase of monitoring and adjustment.
			</p>

			<QuickAnswer 
				title="Quick Guide"
				answer="For maintenance, eat at your TDEE level with 1.6-2.0 g protein per kg. Focus on dietary variety and flexibility. Maintenance is not a break — it is an active phase of monitoring and adjustment."
			/>

			<AuthorAttribution 
				role="Reviewed by certified sports nutrition researchers" 
				references="ISSN Position Stand, Aragon et al. 2017" 
				published="June 2026"
				reviewed="June 27, 2026"
			/>
			<p class="mt-4 text-xs text-muted-foreground flex items-center gap-1.5 font-semibold">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
				7 min read
			</p>
		</div>

		<div class="mt-8 lg:mt-12 grid gap-10 lg:grid-cols-[240px_1fr]">
			<TableOfContents items={tocItems} toolLink={toolLink} />

			<div class="content-panel bg-card border border-border p-5 sm:p-10 rounded-2xl max-w-4xl shadow-sm">
				<div class="prose-lite space-y-8 text-sm text-muted-foreground leading-relaxed">

					<!-- 1. Your Targets (reads localStorage) -->
					<section>
						<h2 id="your-targets" class="text-xl font-bold text-foreground mb-3">1. Your Daily Targets</h2>
						<p>Based on your saved assessment, here is how your daily nutrition breaks down:</p>
						<div id="targets-section" class="mt-4 space-y-4">
							<div id="targets-no-data" class="rounded-xl border border-dashed border-border p-6 text-center">
								<p class="text-sm font-bold text-foreground">No assessment data found.</p>
								<p class="text-xs text-muted-foreground mt-1">Run the Strategy Finder to get personalized targets.</p>
								<a href="/assess" class="button-primary text-xs mt-4 inline-block">Run Strategy Finder</a>
							</div>
							<div id="targets-data" class="hidden space-y-4">
								<div class="grid gap-4 sm:grid-cols-2">
									<div>
										<div class="flex justify-between text-xs mb-1"><span class="font-bold text-foreground">Calories</span><span class="text-muted-foreground" id="target-calories">-</span></div>
										<div class="mini-bar"><span id="bar-calories" class="h-full rounded-full" style="width:0%;background:var(--accent)"></span></div>
									</div>
									<div>
										<div class="flex justify-between text-xs mb-1"><span class="font-bold text-foreground">Protein</span><span class="text-muted-foreground" id="target-protein">-</span></div>
										<div class="mini-bar"><span id="bar-protein" class="h-full rounded-full" style="width:0%"></span></div>
									</div>
									<div>
										<div class="flex justify-between text-xs mb-1"><span class="font-bold text-foreground">Carbs</span><span class="text-muted-foreground" id="target-carbs">-</span></div>
										<div class="mini-bar"><span id="bar-carbs" class="h-full rounded-full" style="width:0%"></span></div>
									</div>
									<div>
										<div class="flex justify-between text-xs mb-1"><span class="font-bold text-foreground">Fats</span><span class="text-muted-foreground" id="target-fats">-</span></div>
										<div class="mini-bar"><span id="bar-fats" class="h-full rounded-full" style="width:0%"></span></div>
									</div>
								</div>
								<div class="grid gap-3 sm:grid-cols-3 text-xs pt-2 border-t border-border/40">
									<div class="p-3 rounded-xl bg-accent/5 border border-accent/10"><span class="font-bold text-foreground">Fiber:</span> 25-35 g target</div>
									<div class="p-3 rounded-xl bg-accent/5 border border-accent/10"><span class="font-bold text-foreground">Water:</span> 3-4 L daily</div>
									<div class="p-3 rounded-xl bg-accent/5 border border-accent/10"><span class="font-bold text-foreground">Meals:</span> 3-5 per day</div>
								</div>
							</div>
						</div>
					</section>

					<!-- 2. Food Focus -->
					<section>
						<h2 id="food-focus" class="text-xl font-bold text-foreground mb-3">2. Food Focus for Maintenance</h2>
						<p>When calories are balanced to maintain your weight, focus on dietary variety and flexibility while keeping protein intake adequate.</p>
						<div class="my-5 overflow-x-auto">
							<table class="w-full text-left text-xs border-collapse">
								<thead>
									<tr class="border-b border-border bg-muted/40 font-semibold text-foreground">
										<th class="p-3">Category</th>
										<th class="p-3">Prioritize</th>
										<th class="p-3">Limit</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-border">
									<tr><td class="p-3 font-bold text-foreground">Protein</td><td class="p-3">Variety of lean meats, fish, eggs, dairy, plant proteins</td><td class="p-3">None (maintain balance)</td></tr>
									<tr class="bg-muted/10"><td class="p-3 font-bold text-foreground">Carbs</td><td class="p-3">Whole grains, fruits, vegetables, legumes</td><td class="p-3">Added sugars in excess</td></tr>
									<tr><td class="p-3 font-bold text-foreground">Fats</td><td class="p-3">Avocado, nuts, seeds, olive oil, fatty fish</td><td class="p-3">Saturated fats in excess</td></tr>
									<tr class="bg-muted/10"><td class="p-3 font-bold text-foreground">Flexibility</td><td class="p-3">80% nutrient-dense foods, 20% flexible choices</td><td class="p-3">Rigid food rules</td></tr>
								</tbody>
							</table>
						</div>
						<div class="rounded-xl border-l-4 border-accent bg-accent/5 p-4 text-xs">
							<p class="font-bold text-foreground">Pro Tip</p>
							<p class="mt-1 text-muted-foreground">Maintenance is the hardest phase for many because there is no obvious goal. Focus on performance markers — strength, endurance, recovery — rather than scale weight.</p>
						</div>
					</section>

					<!-- 3. Meal Distribution -->
					<section>
						<h2 id="meal-distribution" class="text-xl font-bold text-foreground mb-3">3. Meal Distribution</h2>
						<p>How you distribute your calories across meals affects satiety, energy levels, and muscle protein synthesis. A balanced approach works best for most people.</p>
						<div class="mt-4 grid gap-3 sm:grid-cols-4 text-center">
							<div class="p-3 rounded-xl border border-border bg-card"><p class="text-xs text-muted-foreground">Breakfast</p><p class="text-lg font-black text-foreground">25%</p><p class="text-[10px] text-muted-foreground">of daily calories</p></div>
							<div class="p-3 rounded-xl border border-border bg-card"><p class="text-xs text-muted-foreground">Lunch</p><p class="text-lg font-black text-foreground">35%</p><p class="text-[10px] text-muted-foreground">of daily calories</p></div>
							<div class="p-3 rounded-xl border border-border bg-card"><p class="text-xs text-muted-foreground">Dinner</p><p class="text-lg font-black text-foreground">30%</p><p class="text-[10px] text-muted-foreground">of daily calories</p></div>
							<div class="p-3 rounded-xl border border-border bg-card"><p class="text-xs text-muted-foreground">Snacks</p><p class="text-lg font-black text-foreground">10%</p><p class="text-[10px] text-muted-foreground">of daily calories</p></div>
						</div>
						<p class="mt-4">Protein should be distributed evenly: aim for 30-40 g per meal. This maximizes muscle protein synthesis throughout the day.</p>
					</section>

					<!-- 4. Eating Situations -->
					<section>
						<h2 id="eating-situations" class="text-xl font-bold text-foreground mb-3">4. Eating Situations</h2>
						<p>Real life does not always allow for perfectly prepared meals. Here is how to handle common situations while staying on track.</p>
						<div class="mt-4 grid gap-3 sm:grid-cols-2">
							<div class="p-4 rounded-xl border border-border bg-card">
								<div class="flex items-center gap-2 mb-2"><svg class="text-accent shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg><h3 class="font-bold text-foreground text-xs">Eating Out</h3></div>
								<ul class="space-y-1 text-xs text-muted-foreground list-disc pl-4"><li>Choose grilled over fried proteins</li><li>Sauces and dressings on the side</li><li>Water or unsweetened beverages</li><li>Estimate portions using hand sizes</li></ul>
							</div>
							<div class="p-4 rounded-xl border border-border bg-card">
								<div class="flex items-center gap-2 mb-2"><svg class="text-accent shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/></svg><h3 class="font-bold text-foreground text-xs">Office Lunch</h3></div>
								<ul class="space-y-1 text-xs text-muted-foreground list-disc pl-4"><li>Pack lunch when possible</li><li>Choose protein-first options from menus</li><li>Watch dressings and hidden calories</li><li>Keep healthy snacks at your desk</li></ul>
							</div>
							<div class="p-4 rounded-xl border border-border bg-card">
								<div class="flex items-center gap-2 mb-2"><svg class="text-accent shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><h3 class="font-bold text-foreground text-xs">Busy Schedule</h3></div>
								<ul class="space-y-1 text-xs text-muted-foreground list-disc pl-4"><li>Batch prep proteins (chicken, eggs, fish) for 3-4 days</li><li>Overnight oats for grab-and-go breakfast</li><li>Protein shakes as meal backup</li><li>Pre-portion snacks into containers</li></ul>
							</div>
							<div class="p-4 rounded-xl border border-border bg-card">
								<div class="flex items-center gap-2 mb-2"><svg class="text-accent shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><h3 class="font-bold text-foreground text-xs">Vegetarian</h3></div>
								<ul class="space-y-1 text-xs text-muted-foreground list-disc pl-4"><li>Combine complementary proteins (rice + beans, tofu + quinoa)</li><li>Target higher total protein (2.0-2.2 g/kg)</li><li>Include soy products (tofu, tempeh, edamame)</li><li>Consider a leucine supplement if needed</li></ul>
							</div>
						</div>
					</section>

					<!-- 5. Beyond Macros -->
					<section>
						<h2 id="beyond-macros" class="text-xl font-bold text-foreground mb-3">5. Beyond Macros</h2>
						<p>Macronutrients get most of the attention, but several other factors determine success during a maintenance phase.</p>
						<div class="mt-4 grid gap-3 sm:grid-cols-2">
							<div class="p-4 rounded-xl border border-border bg-accent/5"><h3 class="font-bold text-foreground text-xs flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>Fiber</h3><p class="text-xs text-muted-foreground mt-1">Target 25-35 g daily from vegetables, fruits, legumes, and whole grains. Fiber slows digestion, improves satiety, and supports gut health during calorie restriction.</p></div>
							<div class="p-4 rounded-xl border border-border bg-accent/5"><h3 class="font-bold text-foreground text-xs flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>Water</h3><p class="text-xs text-muted-foreground mt-1">Drink 3-4 L of water daily. Adequate hydration supports metabolism, reduces hunger signals, and improves training performance. Drink 350-500 ml before meals.</p></div>
							<div class="p-4 rounded-xl border border-border bg-accent/5"><h3 class="font-bold text-foreground text-xs flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>Fruit & Vegetables</h3><p class="text-xs text-muted-foreground mt-1">Aim for 5+ servings of fruits and vegetables daily. They provide micronutrients, antioxidants, and fiber with minimal calorie impact. Prioritize variety across colors.</p></div>
							<div class="p-4 rounded-xl border border-border bg-accent/5"><h3 class="font-bold text-foreground text-xs flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>Meal Frequency</h3><p class="text-xs text-muted-foreground mt-1">3-5 meals per day works for most people. Choose a frequency that fits your schedule and hunger patterns. Protein distribution matters more than meal count.</p></div>
						</div>
					</section>

					<!-- 6. Today's Checklist -->
					<section>
						<h2 id="checklist" class="text-xl font-bold text-foreground mb-3">6. Today's Checklist</h2>
						<p>Use this daily checklist to stay on track. Items reset each day — check them off as you go.</p>
						<div id="checklist-container" class="mt-4 space-y-2">
							<div class="flex items-center gap-3 p-3 min-h-[44px] rounded-xl border border-border bg-card hover:border-accent/30 transition-colors cursor-pointer checklist-item" data-key="hit-protein">
								<div class="w-5 h-5 rounded border-2 border-muted-foreground flex items-center justify-center shrink-0 checkbox-box transition-colors"></div>
								<span class="text-sm text-foreground checklist-label">Hit my protein target (1.6-2.0 g/kg)</span>
							</div>
							<div class="flex items-center gap-3 p-3 min-h-[44px] rounded-xl border border-border bg-card hover:border-accent/30 transition-colors cursor-pointer checklist-item" data-key="stay-consistent">
								<div class="w-5 h-5 rounded border-2 border-muted-foreground flex items-center justify-center shrink-0 checkbox-box transition-colors"></div>
								<span class="text-sm text-foreground checklist-label">Stay consistent with my eating pattern</span>
							</div>
							<div class="flex items-center gap-3 p-3 min-h-[44px] rounded-xl border border-border bg-card hover:border-accent/30 transition-colors cursor-pointer checklist-item" data-key="monitor-weight">
								<div class="w-5 h-5 rounded border-2 border-muted-foreground flex items-center justify-center shrink-0 checkbox-box transition-colors"></div>
								<span class="text-sm text-foreground checklist-label">Check weekly weight trend</span>
							</div>
							<div class="flex items-center gap-3 p-3 min-h-[44px] rounded-xl border border-border bg-card hover:border-accent/30 transition-colors cursor-pointer checklist-item" data-key="eat-veggies">
								<div class="w-5 h-5 rounded border-2 border-muted-foreground flex items-center justify-center shrink-0 checkbox-box transition-colors"></div>
								<span class="text-sm text-foreground checklist-label">Eat vegetables at 2+ meals</span>
							</div>
							<div class="flex items-center gap-3 p-3 min-h-[44px] rounded-xl border border-border bg-card hover:border-accent/30 transition-colors cursor-pointer checklist-item" data-key="stay-active">
								<div class="w-5 h-5 rounded border-2 border-muted-foreground flex items-center justify-center shrink-0 checkbox-box transition-colors"></div>
								<span class="text-sm text-foreground checklist-label">Stay active (maintain training routine)</span>
							</div>
						</div>
						<div class="mt-3 flex items-center justify-between text-xs text-muted-foreground">
							<span id="checklist-progress-text">0 / 5 completed</span>
							<button id="reset-checklist-btn" class="text-accent hover:underline font-semibold">Reset</button>
						</div>
					</section>

					<!-- 7. FAQ -->
					<section>
						<h2 id="faq" class="text-xl font-bold text-foreground mb-3">7. Frequently Asked Questions</h2>
						<div class="space-y-3">
							{faqEntries.map(([question, answer]) => (
								<div class="rounded-xl border border-border bg-card p-4 sm:p-5">
									<h3 class="font-bold text-sm text-foreground">{question}</h3>
									<p class="mt-2 text-xs leading-relaxed text-muted-foreground">{answer}</p>
								</div>
							))}
						</div>
					</section>

					<!-- 8. Next Steps -->
					<section>
						<h2 id="next-steps" class="text-xl font-bold text-foreground mb-3">8. Next Steps</h2>
						<div class="grid gap-3 sm:grid-cols-2">
							<a href="/guides/maintenance-calories" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">1</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Read Maintenance Guide</p>
								<p class="mt-1 text-xs text-muted-foreground">Deep dive into maintenance nutrition science</p>
							</a>
							<a href="/dashboard" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">2</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Track Progress</p>
								<p class="mt-1 text-xs text-muted-foreground">Weekly check-ins and trend analysis</p>
							</a>
							<a href="/body-composition-strategy-guide" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">3</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Read Strategy Guide</p>
								<p class="mt-1 text-xs text-muted-foreground">Full body composition strategy overview</p>
							</a>
							<a href="/assess" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">4</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Run Strategy Finder</p>
								<p class="mt-1 text-xs text-muted-foreground">Get personalized maintenance targets</p>
							</a>
						</div>
					</section>

					<!-- YMYL + Author -->
					<div class="border-t border-border pt-6 text-xs text-muted-foreground">
						<p><strong>Educational Disclaimer:</strong> The information in this guide is for educational purposes only. Calorie restriction and body composition changes may affect hormone levels, metabolic rate, and psychological well-being. Individuals with a history of eating disorders, metabolic conditions, or other clinical concerns should consult a qualified medical professional before starting any calorie-restricted diet.</p>
					</div>
					<div class="border-t border-border pt-6">
						<Author />
					</div>

				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	// Load assessment data
	const assessment = JSON.parse(localStorage.getItem('bodycompos.latestAssessment') || 'null');
	const noData = document.getElementById('targets-no-data');
	const dataSection = document.getElementById('targets-data');

	if (assessment && assessment.target) {
		if (noData) noData.classList.add('hidden');
		if (dataSection) dataSection.classList.remove('hidden');

		const t = assessment.target;
		const pLow = assessment.proteinLow || Math.round(assessment.weightKg * 1.6);
		const pHigh = assessment.proteinHigh || Math.round(assessment.weightKg * 2.0);
		const avgProtein = Math.round((pLow + pHigh) / 2);
		const fatPct = 0.25;
		const fatKcal = Math.round(t * fatPct);
		const fatG = Math.round(fatKcal / 9);
		const proteinKcal = avgProtein * 4;
		const carbKcal = Math.max(0, t - proteinKcal - fatKcal);
		const carbG = Math.round(carbKcal / 4);

		const setText = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
		const setBar = (id, pct) => { const el = document.getElementById(id); if (el) el.style.width = Math.min(100, pct) + '%'; };

		setText('target-calories', t + ' kcal / ' + t + ' kcal');
		setText('target-protein', avgProtein + ' g / ' + pHigh + ' g');
		setText('target-carbs', carbG + ' g');
		setText('target-fats', fatG + ' g');
		setBar('bar-calories', 100);
		setBar('bar-protein', (proteinKcal / t) * 100);
		setBar('bar-carbs', (carbKcal / t) * 100);
		setBar('bar-fats', (fatKcal / t) * 100);
	}

	// Checklist with localStorage persistence
	(function() {
		const STORAGE_KEY = 'bodycompos.buildYourDay.maintain.checklist';
		const CHECKLIST_ITEMS = ['hit-protein', 'stay-consistent', 'monitor-weight', 'eat-veggies', 'stay-active'];
		const today = new Date().toISOString().slice(0, 10);

		let state = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
		if (state.date !== today) {
			state = { date: today, items: {} };
			CHECKLIST_ITEMS.forEach(k => state.items[k] = false);
			localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
		}

		function updateUI() {
			let done = 0;
			CHECKLIST_ITEMS.forEach(key => {
				const item = document.querySelector(`.checklist-item[data-key="${key}"]`);
				const box = item ? item.querySelector('.checkbox-box') : null;
				const label = item ? item.querySelector('.checklist-label') : null;
				const checked = state.items[key] || false;
				if (checked) done++;
				if (box) {
					box.innerHTML = checked ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>' : '';
					box.style.borderColor = checked ? 'var(--accent)' : '';
				}
				if (label) label.style.textDecoration = checked ? 'line-through' : 'none';
			});
			const prog = document.getElementById('checklist-progress-text');
			if (prog) prog.textContent = `${done} / ${CHECKLIST_ITEMS.length} completed`;
		}

		document.querySelectorAll('.checklist-item').forEach(el => {
			el.addEventListener('click', function() {
				const key = this.getAttribute('data-key');
				if (!key) return;
				if (state.date !== today) {
					state = { date: today, items: {} };
					CHECKLIST_ITEMS.forEach(k => state.items[k] = false);
				}
				state.items[key] = !(state.items[key] || false);
				localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
				updateUI();
			});
		});

		const resetBtn = document.getElementById('reset-checklist-btn');
		if (resetBtn) {
			resetBtn.addEventListener('click', function(e) {
				e.stopPropagation();
				state = { date: today, items: {} };
				CHECKLIST_ITEMS.forEach(k => state.items[k] = false);
				localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
				updateUI();
			});
		}

		updateUI();
	})();
</script>

