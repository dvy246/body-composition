<script>
	// Scroll highlight observer for the sticky left Table of Contents
	const outlineNav = document.getElementById('sticky-outline-nav');
	if (outlineNav) {
		const links = outlineNav.querySelectorAll('a[href^="#"]');
		const headings = Array.from(links).map(link => {
			const id = link.getAttribute('href');
			return id ? document.querySelector(id) : null;
		}).filter(Boolean) as Element[];

		const observerOptions = {
			root: null,
			rootMargin: '-10% 0px -75% 0px', // focused in top-middle third
			threshold: 0
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const id = entry.target.getAttribute('id');
					links.forEach(link => {
						const href = link.getAttribute('href');
						if (href === `#${id}`) {
							link.classList.add('active-toc-link');
							link.classList.remove('text-muted-foreground');
							link.classList.add('text-accent');
						} else {
							link.classList.remove('active-toc-link');
							link.classList.add('text-muted-foreground');
							link.classList.remove('text-accent');
						}
					});
				}
			});
		}, observerOptions);

		headings.forEach(h => observer.observe(h));
	}

	// Evidenced-Based Strategy Helper Widget logic
	const helperBtn = document.getElementById('helper-btn');
	const helperSex = document.getElementById('helper-sex') as HTMLSelectElement;
	const helperBf = document.getElementById('helper-bf') as HTMLInputElement;
	const helperResult = document.getElementById('helper-result');
	const helperResultTitle = document.getElementById('helper-result-title');
	const helperResultDesc = document.getElementById('helper-result-desc');

	helperBtn?.addEventListener('click', () => {
		const sex = helperSex?.value || 'male';
		const bf = parseFloat(helperBf?.value || '18');
		let title = '';
		let desc = '';
		let statusClass = '';

		if (sex === 'male') {
			if (bf > 15) {
				title = 'Recommended Strategy: Calorie Deficit (Cut)';
				desc = `With body fat at ${bf}%, your physiological priority is reducing adipose tissue. A moderate deficit of 15% (approx. 350-500 kcal below maintenance) will optimize fat loss while maintaining muscular mass.`;
			} else if (bf >= 10) {
				title = 'Recommended Strategy: Recomposition or Maintenance';
				desc = `At ${bf}% body fat, you are in the ideal transition zone. If you are a beginner or returning from a break, recomposition is recommended. Intermediate lifters should choose based on personal preference.`;
			} else {
				title = 'Recommended Strategy: Calorie Surplus (Lean Bulk)';
				desc = `At ${bf}% body fat, your insulin sensitivity is highly optimized for skeletal hypertrophy. A conservative surplus of 8-10% (approx. 200-300 kcal above maintenance) will prioritize muscle gain while minimizing fat accumulation.`;
			}
		} else {
			if (bf > 24) {
				title = 'Recommended Strategy: Calorie Deficit (Cut)';
				desc = `With body fat at ${bf}%, your physiological priority is fat loss. A moderate deficit of 15% (approx. 300-400 kcal below maintenance) will optimize metabolic health and hormone partition profiles.`;
			} else if (bf >= 18) {
				title = 'Recommended Strategy: Recomposition or Maintenance';
				desc = `At ${bf}% body fat, you are in the ideal zone for either recomposition or a controlled lean bulk phase. Focus on high protein intake (2.0g/kg) and steady training progression.`;
			} else {
				title = 'Recommended Strategy: Calorie Surplus (Lean Bulk)';
				desc = `At ${bf}% body fat, your hormonal state is highly primed for muscle growth. A conservative surplus of 8% (approx. 150-250 kcal above maintenance) will support lean gains without unwanted fat spillover.`;
			}
		}

		if (helperResultTitle && helperResultDesc && helperResult) {
			helperResultTitle.textContent = title;
			helperResultDesc.textContent = desc;
			helperResult.classList.remove('hidden');
			helperResult.classList.add('animate-fade-in-up');
		}
	});
</script>

