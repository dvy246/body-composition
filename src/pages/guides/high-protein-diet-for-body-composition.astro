---
import Layout from '../../layouts/Layout.astro';
import { DOMAIN, articleSchema } from '../../data/site';
import AuthorAttribution from '../../components/AuthorAttribution.astro';
import Author from '../../components/Author.astro';
import QuickAnswer from '../../components/QuickAnswer.astro';
import TableOfContents from '../../components/TableOfContents.astro';

const tocItems = [
	{ href: '#why-high-protein', label: 'Why High Protein Works for Body Composition', shortLabel: 'Why High Protein Works' },
	{ href: '#protein-sources', label: 'Top Protein Sources by Category', shortLabel: 'Protein Sources' },
	{ href: '#meal-distribution', label: 'Protein Meal Distribution', shortLabel: 'Meal Distribution' },
	{ href: '#sample-day', label: 'Sample High-Protein Day', shortLabel: 'Sample Day' },
	{ href: '#faq', label: 'Frequently Asked Questions', shortLabel: 'FAQ' },
	{ href: '#next-steps', label: 'Next Steps' }
];

const toolLink = {
	href: '/build-your-day',
	label: 'Build Your Day',
	desc: 'Get personalized daily nutrition guidance based on your assessment and strategy.',
	buttonText: 'Build Your Day'
};

const title = "High Protein Diet Guide for Body Composition | BodyCompOS";
const description = "A complete guide to high protein nutrition for body composition. Learn which protein sources to prioritize, how to distribute intake across meals, and sample days for cutting, bulking, and maintenance.";
const canonical = `${DOMAIN}/guides/high-protein-diet-for-body-composition`;

const faqEntries = [
	['How much protein do I need for body composition?', 'Active individuals targeting body composition changes should consume 1.6-2.2 g of protein per kg of body weight daily (0.73-1.0 g/lb). During a calorie deficit, increase to 2.0-2.4 g/kg to protect against muscle loss. These ranges are based on the ISSN position stand and supporting meta-analyses.'],
	['Can I get enough protein from plants alone?', 'Yes, but it requires more planning. Plant proteins have lower digestibility scores and are typically incomplete in essential amino acids. Combine complementary sources (rice + beans, tofu + quinoa), target the higher end of the protein range (2.0-2.2 g/kg), and consider a leucine supplement to ensure mTOR activation.'],
	['Is there a limit to how much protein the body can use per meal?', 'Research suggests that 30-40 g of protein per meal is the optimal dose for maximizing muscle protein synthesis in most adults. Doses above 40-50 g produce diminishing returns — the excess amino acids are oxidized for energy rather than used for muscle building. Spread your protein across 4-5 meals.'],
	['Do I need protein shakes to hit my targets?', 'No, whole food sources are preferred because they provide micronutrients and greater satiety. However, whey protein is a convenient tool to reach high daily targets, especially post-workout due to its rapid absorption and high leucine content. Supplements are optional, not required.'],
	['Is a high-protein diet safe for my kidneys?', 'For healthy individuals with normal kidney function, protein intakes up to 2.2 g/kg are safe. The concern about protein causing kidney damage in healthy people has been repeatedly disproven in the literature. Individuals with pre-existing renal disease should consult a medical professional before increasing protein intake.'],
	['When should I eat protein around my workout?', 'The anabolic window is wider than once believed. Consuming protein within 2-4 hours post-workout is sufficient for MPS, provided you meet your total daily protein target. If you ate a protein-containing meal 1-2 hours before training, post-workout protein urgency is minimal.'],
];

const schema = [
	articleSchema(title, description, canonical),
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqEntries.map(([q, a]) => ({
			'@type': 'Question',
			name: q,
			acceptedAnswer: {
				'@type': 'Answer',
				text: a,
			},
		})),
	},
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
	<section class="site-container py-10 sm:py-12">
		<!-- Breadcrumbs -->
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<a class="hover:text-accent transition-colors" href="/guides">Guides</a>
			<span>/</span>
			<span class="text-foreground">High Protein Diet</span>
		</nav>

		<!-- Content Hero -->
		<div class="max-w-4xl">
			<p class="eyebrow">Nutritional Science</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl text-foreground">
				High Protein Diet Guide <br/>
				<span class="text-accent bg-gradient-to-r from-accent to-success bg-clip-text text-transparent">Optimal Protein for Body Composition</span>
			</h1>
			<p class="mt-5 text-lg leading-relaxed text-muted-foreground">
				Protein is the most important macronutrient for modifying body composition. This guide covers the best protein sources by category, how to distribute your intake across meals, and what a high-protein day looks like for cutting, bulking, and maintenance.
			</p>

			<QuickAnswer 
				title="Direct Nutritional Answer"
				answer="To optimize body composition, consume 1.6-2.2 g of protein per kg of body weight daily from a mix of animal and plant sources. Spread this across 4-5 meals of 30-40 g each to maximize muscle protein synthesis. Prioritize complete protein sources like lean meats, eggs, dairy, and soy."
			/>

			<!-- Author / E-E-A-T Attribution -->
			<AuthorAttribution 
				role="Reviewed by certified sports nutrition researchers" 
				references="ISSN Protein Position Stand 2017, Morton et al. 2018, Phillips et al. 2016" 
				published="June 2026"
				reviewed="June 27, 2026"
			/>
			<p class="mt-4 text-xs text-muted-foreground flex items-center gap-1.5 font-semibold">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
				6 min read
			</p>
		</div>

		<!-- Main editorial body with sticky left column -->
		<div class="mt-8 lg:mt-12 grid gap-10 lg:grid-cols-[240px_1fr]">
			<TableOfContents items={tocItems} toolLink={toolLink} />

			<!-- Right column: Main Editorial content -->
			<div class="content-panel bg-card border border-border p-6 sm:p-10 rounded-2xl max-w-4xl shadow-sm">
				<div class="prose-lite space-y-8 text-sm text-muted-foreground leading-relaxed">

					<!-- 1. Why High Protein Works -->
					<section>
						<h2 id="why-high-protein" class="text-xl font-bold text-foreground mb-3">1. Why High Protein Works for Body Composition</h2>
						<p>
							Protein is the structural foundation of your muscles, organs, enzymes, and hormones. When you resistance train, you create mechanical tension that signals your body to repair and reinforce muscle fibers — a process known as Muscle Protein Synthesis (MPS). Without a consistent supply of dietary amino acids, this repair process is incomplete.
						</p>
						<p class="mt-3">
							During a calorie deficit (cutting phase), adequate protein is essential to mitigate muscle protein breakdown. In the absence of sufficient exogenous amino acids, the body increases oxidation of its own contractile tissue to meet its metabolic needs. Research consistently shows that higher protein intakes during a deficit preserve lean mass while allowing preferential loss of adipose tissue.
						</p>
						<p class="mt-3">
							During a calorie surplus (bulking phase), protein provides the raw materials for new muscle accretion. But beyond approximately 1.6 g/kg/day, additional protein does not further increase MPS — the excess nitrogen is simply excreted. The key is finding the intake level that saturates the MPS response without displacing the carbohydrate and fat calories needed for training performance.
						</p>
						<div class="mt-4 rounded-xl border-l-4 border-accent bg-accent/5 p-4 text-xs">
							<p class="font-bold text-foreground flex items-center gap-1.5">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
								Key Insight
							</p>
							<p class="mt-1 text-muted-foreground">
								Protein has a thermic effect of 20-30%, meaning 20-30% of the calories from protein are burned during digestion. A high-protein diet effectively increases your daily energy expenditure by 80-120 kcal compared to a low-protein diet at the same calorie intake.
							</p>
						</div>
					</section>

					<!-- 2. Top Protein Sources by Category -->
					<section>
						<h2 id="protein-sources" class="text-xl font-bold text-foreground mb-3">2. Top Protein Sources by Category</h2>
						<p>
							Different protein sources offer different benefits. Here is a breakdown of the best sources across categories, including protein content per serving and key considerations.
						</p>
						<div class="my-5 overflow-x-auto">
							<table class="w-full text-left text-xs border-collapse">
								<thead>
									<tr class="border-b border-border bg-muted/40 font-semibold text-foreground">
										<th class="p-3">Category</th>
										<th class="p-3">Source</th>
										<th class="p-3">Protein per 100g</th>
										<th class="p-3">Notes</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-border">
									<tr>
										<td class="p-3 font-bold text-foreground" rowspan="3">Animal</td>
										<td class="p-3 font-mono">Chicken breast (cooked)</td>
										<td class="p-3">~31 g</td>
										<td class="p-3">Lean, versatile, high leucine</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-mono">Eggs (whole)</td>
										<td class="p-3">~13 g</td>
										<td class="p-3">Complete protein, vitamin D, choline</td>
									</tr>
									<tr>
										<td class="p-3 font-mono">Greek yogurt (plain)</td>
										<td class="p-3">~10 g</td>
										<td class="p-3">Casein + whey, slow digestion, gut health</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-bold text-foreground" rowspan="2">Fish</td>
										<td class="p-3 font-mono">Salmon (cooked)</td>
										<td class="p-3">~22 g</td>
										<td class="p-3">Omega-3s, vitamin D, high satiety</td>
									</tr>
									<tr>
										<td class="p-3 font-mono">Tuna (canned)</td>
										<td class="p-3">~25 g</td>
										<td class="p-3">Convenient, lean, affordable</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-bold text-foreground" rowspan="3">Plant</td>
										<td class="p-3 font-mono">Tofu (firm)</td>
										<td class="p-3">~8 g</td>
										<td class="p-3">Complete protein (soy), versatile</td>
									</tr>
									<tr>
										<td class="p-3 font-mono">Lentils (cooked)</td>
										<td class="p-3">~9 g</td>
										<td class="p-3">High fiber, iron, pairs with rice</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-mono">Tempeh</td>
										<td class="p-3">~19 g</td>
										<td class="p-3">Fermented soy, gut health, high protein</td>
									</tr>
									<tr>
										<td class="p-3 font-bold text-foreground" rowspan="2">Dairy</td>
										<td class="p-3 font-mono">Cottage cheese</td>
										<td class="p-3">~11 g</td>
										<td class="p-3">Slow-digesting casein, before bed</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-mono">Milk (whole)</td>
										<td class="p-3">~3.4 g</td>
										<td class="p-3">Whey + casein, micronutrients</td>
									</tr>
									<tr>
										<td class="p-3 font-bold text-foreground">Supplement</td>
										<td class="p-3 font-mono">Whey protein isolate</td>
										<td class="p-3">~90 g</td>
										<td class="p-3">Fast absorption, high leucine, convenient</td>
									</tr>
								</tbody>
							</table>
						</div>
						<p>
							Aim to get protein from a variety of sources to ensure a complete amino acid profile and a broad range of micronutrients. Animal sources provide complete proteins with high bioavailability, while plant sources offer fiber and phytonutrients. Combining both maximizes nutritional quality.
						</p>
					</section>

					<!-- 3. Protein Meal Distribution -->
					<section>
						<h2 id="meal-distribution" class="text-xl font-bold text-foreground mb-3">3. Protein Meal Distribution</h2>
						<p>
							Consuming your entire daily protein target in a single meal is measurably less effective than distributing it across multiple feedings. MPS is a saturable process — once it reaches its maximum rate in response to a meal, additional amino acids from that meal are oxidized rather than used for muscle building.
						</p>
						<p class="mt-3">
							To maintain an elevated MPS state throughout the day, distribute your protein across <strong>4 to 5 meals</strong>, each containing <strong>0.4 to 0.55 g/kg of body weight</strong>. For a 75 kg individual, this translates to 30-40 g of protein per meal.
						</p>
						<div class="my-5 overflow-x-auto">
							<table class="w-full text-left text-xs border-collapse">
								<thead>
									<tr class="border-b border-border bg-muted/40 font-semibold text-foreground">
										<th class="p-3">Meal</th>
										<th class="p-3">Protein (75 kg person)</th>
										<th class="p-3">Example Foods</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-border">
									<tr>
										<td class="p-3 font-bold text-foreground">Breakfast</td>
										<td class="p-3 font-mono">~35 g</td>
										<td class="p-3">3 eggs + 1/2 cup oats + 1 scoop whey</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-bold text-foreground">Lunch</td>
										<td class="p-3 font-mono">~40 g</td>
										<td class="p-3">150g chicken + quinoa + vegetables</td>
									</tr>
									<tr>
										<td class="p-3 font-bold text-foreground">Dinner</td>
										<td class="p-3 font-mono">~40 g</td>
										<td class="p-3">150g salmon + sweet potato + broccoli</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-bold text-foreground">Snack</td>
										<td class="p-3 font-mono">~30 g</td>
										<td class="p-3">200g Greek yogurt + berries OR 1 scoop whey</td>
									</tr>
								</tbody>
							</table>
						</div>
						<p>
							The concept of a narrow anabolic window is overstated. Total daily protein intake is more important than precise timing. If you meet your daily target through well-distributed meals, you do not need to stress about post-workout timing.
						</p>
					</section>

					<!-- 4. Sample High-Protein Day -->
					<section>
						<h2 id="sample-day" class="text-xl font-bold text-foreground mb-3">4. Sample High-Protein Day at Different Calorie Levels</h2>
						<p>
							Here are examples of what a high-protein day looks like at different calorie levels. These are educational examples based on standard nutrition guidelines — not personalized prescriptions.
						</p>
						<div class="my-5 overflow-x-auto">
							<table class="w-full text-left text-xs border-collapse">
								<thead>
									<tr class="border-b border-border bg-muted/40 font-semibold text-foreground">
										<th class="p-3">Meal</th>
										<th class="p-3">~1,800 kcal (cutting)</th>
										<th class="p-3">~2,600 kcal (maintenance)</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-border">
									<tr>
										<td class="p-3 font-bold text-foreground">Breakfast</td>
										<td class="p-3">3 eggs + 1 slice whole wheat + spinach</td>
										<td class="p-3">3 eggs + 1 cup oats + 1 scoop whey + banana</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-bold text-foreground">Lunch</td>
										<td class="p-3">150g chicken + 2 cups mixed greens + 1 tbsp vinaigrette</td>
										<td class="p-3">200g chicken + 1 cup brown rice + 2 cups roasted vegetables</td>
									</tr>
									<tr>
										<td class="p-3 font-bold text-foreground">Dinner</td>
										<td class="p-3">150g white fish + 2 cups broccoli + 1/2 sweet potato</td>
										<td class="p-3">200g salmon + 1.5 cups quinoa + asparagus + 1/2 avocado</td>
									</tr>
									<tr class="bg-muted/10">
										<td class="p-3 font-bold text-foreground">Snack</td>
										<td class="p-3">1 scoop whey + water</td>
										<td class="p-3">200g Greek yogurt + berries + 1 tbsp almond butter</td>
									</tr>
									<tr>
										<td class="p-3 font-bold text-foreground">Protein Total</td>
										<td class="p-3 font-mono text-success">~140 g</td>
										<td class="p-3 font-mono text-success">~200 g</td>
									</tr>
								</tbody>
							</table>
						</div>
					</section>

					<!-- 5. FAQ -->
					<section>
						<h2 id="faq" class="text-xl font-bold text-foreground mb-3">5. Frequently Asked Questions</h2>
						<div class="space-y-3">
							{faqEntries.map(([question, answer]) => (
								<div class="rounded-xl border border-border bg-card p-5">
									<h3 class="font-bold text-sm text-foreground">{question}</h3>
									<p class="mt-2 text-xs leading-relaxed text-muted-foreground">{answer}</p>
								</div>
							))}
						</div>
					</section>

					<!-- 6. Next Steps -->
					<section>
						<h2 id="next-steps" class="text-xl font-bold text-foreground mb-3">6. Next Steps</h2>
						<p class="mb-4">Apply what you have learned with these tools and guides:</p>
						<div class="grid gap-3 sm:grid-cols-2">
							<a href="/build-your-day" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">1</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Build Your Day</p>
								<p class="mt-1 text-xs text-muted-foreground">Personalized nutrition based on your strategy</p>
							</a>
							<a href="/calculators/protein-calculator" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">2</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Calculate Your Target</p>
								<p class="mt-1 text-xs text-muted-foreground">Personalized protein range for your weight and goal</p>
							</a>
							<a href="/guides/protein-nutrition" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">3</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Read Full Protein Guide</p>
								<p class="mt-1 text-xs text-muted-foreground">Deep dive into protein science and ISSN guidelines</p>
							</a>
							<a href="/guides/how-to-eat-in-a-calorie-deficit" class="surface border border-border rounded-xl p-4 text-center group hover:border-accent/40 transition-colors">
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold mx-auto">4</span>
								<p class="mt-2 text-xs font-bold text-foreground group-hover:text-accent transition-colors">Eating in a Deficit</p>
								<p class="mt-1 text-xs text-muted-foreground">Fat loss nutrition strategy guide</p>
							</a>
						</div>
						<div class="mt-6 rounded-xl border border-border bg-muted/20 p-5">
							<p class="font-bold text-foreground text-xs mb-2">Related Reading</p>
							<div class="grid sm:grid-cols-2 gap-2 text-xs">
								<a href="/guides/protein-nutrition" class="text-accent hover:underline">Protein Nutrition Guide →</a>
								<a href="/guides/how-to-eat-in-a-calorie-deficit" class="text-accent hover:underline">Eating in a Calorie Deficit →</a>
								<a href="/guides/body-recomposition" class="text-accent hover:underline">Body Recomposition Guide →</a>
								<a href="/guides/should-i-cut-or-bulk" class="text-accent hover:underline">Should I Cut or Bulk Guide →</a>
							</div>
						</div>
					</section>

					<!-- YMYL Disclaimer -->
					<div class="border-t border-border pt-6 text-xs text-muted-foreground">
						<p><strong>Educational Disclaimer:</strong> The information in this guide is for educational purposes only. High protein intakes require healthy renal clearance. Individuals with pre-existing kidney disease, hepatic issues, or other clinical concerns should consult a qualified medical professional before starting a high-protein diet. All protein targets are estimates based on population-level research and may not reflect individual responses.</p>
					</div>

					<!-- Author Bio for EEAT -->
					<div class="border-t border-border pt-6">
						<Author />
					</div>

				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	const outlineNav = document.getElementById('sticky-outline-nav');
	if (outlineNav) {
		const links = outlineNav.querySelectorAll('a[href^="#"]');
		const headings = Array.from(links).map(link => {
			const id = link.getAttribute('href');
			return id ? document.querySelector(id) : null;
		}).filter(Boolean) as Element[];

		const observerOptions = {
			root: null,
			rootMargin: '-10% 0px -75% 0px',
			threshold: 0
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const id = entry.target.getAttribute('id');
					links.forEach(link => {
						const href = link.getAttribute('href');
						if (href === `#${id}`) {
							link.classList.add('active-toc-link');
							link.classList.remove('text-muted-foreground');
							link.classList.add('text-accent');
						} else {
							link.classList.remove('active-toc-link');
							link.classList.add('text-muted-foreground');
							link.classList.remove('text-accent');
						}
					});
				}
			});
		}, observerOptions);

		headings.forEach(h => observer.observe(h));
	}
</script>

<style>
	.active-toc-link {
		border-left-color: var(--accent) !important;
		font-weight: 700;
	}
</style>
