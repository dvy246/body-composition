---
import Layout from '../../layouts/Layout.astro';
import { DOMAIN } from '../../data/site';

const title = 'Body Composition Guides | BodyCompOS';
const description = 'Expert guides on body composition strategy — cut or bulk decisions, body recomposition, protein nutrition, body fat percentage, and maintenance calories. Science-backed, evidence-first.';
const canonical = `${DOMAIN}/guides`;

const guides = [
	{
		href: '/guides/should-i-cut-or-bulk',
		label: 'Strategy Decision',
		title: 'Should I Cut or Bulk?',
		description: 'An evidence-based decision matrix using body fat thresholds, training age, and metabolic signals to determine your optimal strategy.',
		readTime: '12 min read',
		tags: ['Strategy', 'Fat Loss', 'Muscle Gain'],
		iconPath: 'M12 2L2 7l10 5 10-5-10-5M2 17l10 5 10-5M2 12l10 5 10-5',
	},
	{
		href: '/guides/body-recomposition',
		label: 'Recomposition',
		title: 'Body Recomposition Guide',
		description: 'Simultaneous fat loss and muscle gain is real — but it requires specific conditions. Learn who qualifies and how to approach it correctly.',
		readTime: '9 min read',
		tags: ['Recomp', 'Strategy', 'Protein'],
		iconPath: 'M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6',
	},
	{
		href: '/guides/protein-nutrition',
		label: 'Nutrition Science',
		title: 'Protein Nutrition for Body Composition',
		description: 'ISSN guidelines decoded. How much protein you need by goal, timing considerations, and what the research actually says about muscle protein synthesis.',
		readTime: '10 min read',
		tags: ['Nutrition', 'Protein', 'Muscle'],
		iconPath: 'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v11m0 0H5m4 0h6m-6 0v7m6-7v7m6-11v11m0 0h-4m4 0H15',
	},
	{
		href: '/guides/body-fat-percentage',
		label: 'Body Composition',
		title: 'Understanding Body Fat Percentage',
		description: 'What body fat percentage means, how to estimate it accurately, which methods are reliable, and how to use it for strategy selection.',
		readTime: '8 min read',
		tags: ['Assessment', 'Body Fat', 'Metrics'],
		iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2',
	},
	{
		href: '/guides/maintenance-calories',
		label: 'Energy Balance',
		title: 'Maintenance Calories & TDEE Explained',
		description: 'TDEE formulas, activity multipliers, metabolic adaptation, and how to empirically confirm your real maintenance level from trend data.',
		readTime: '8 min read',
		tags: ['Calories', 'TDEE', 'Metabolism'],
		iconPath: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
	},
	{
		href: '/guides/weight-loss-plateau-guide',
		label: 'Metabolic Adaptation',
		title: 'Breaking a Weight Loss Plateau',
		description: 'Stuck in a calorie deficit but not losing weight? Unmask cortisol water retention, calculate NEAT offsets, and break stalls.',
		readTime: '11 min read',
		tags: ['Plateau', 'Deficit', 'Cortisol'],
		iconPath: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
	},
	{
		href: '/guides/how-to-eat-in-a-calorie-deficit',
		label: 'Nutrition Strategy',
		title: 'How to Eat in a Calorie Deficit',
		description: 'Translate your calorie and protein targets into actual meals. Learn what to eat, how to portion, and how to structure your day for sustainable fat loss.',
		readTime: '7 min read',
		tags: ['Nutrition', 'Deficit', 'Fat Loss'],
		iconPath: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
	},
	{
		href: '/guides/high-protein-diet-for-body-composition',
		label: 'Nutrition Science',
		title: 'High Protein Diet for Body Composition',
		description: 'Why high protein is the single most important dietary lever for body composition change — and how to hit your targets with real food.',
		readTime: '6 min read',
		tags: ['Protein', 'Nutrition', 'Muscle'],
		iconPath: 'M13 2L3 14h9l-1 8 10-10h-9l1-8z',
	},
];

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: title,
		description,
		url: canonical,
		publisher: {
			'@type': 'Organization',
			name: 'BodyCompOS',
			logo: { '@type': 'ImageObject', url: `${DOMAIN}/favicon.svg` },
		},
		hasPart: guides.map((g) => ({
			'@type': 'Article',
			headline: g.title,
			description: g.description,
			url: `${DOMAIN}${g.href}`,
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: DOMAIN },
			{ '@type': 'ListItem', position: 2, name: 'Guides', item: canonical },
		],
	},
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
	<section class="site-container py-10 sm:py-14">
		<!-- Breadcrumbs -->
		<nav class="flex mb-6 text-xs font-semibold text-muted-foreground gap-2" aria-label="Breadcrumb">
			<a class="hover:text-accent transition-colors" href="/">Home</a>
			<span>/</span>
			<span class="text-foreground">Guides</span>
		</nav>

		<!-- Hero -->
		<div class="max-w-3xl animate-fade-in-up">
			<p class="eyebrow">Research-Backed Guides</p>
			<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl text-foreground">
				Body Composition
				<span style="background: linear-gradient(135deg, var(--accent), var(--success)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Strategy Guides</span>
			</h1>
			<p class="mt-5 text-lg leading-relaxed text-muted-foreground max-w-2xl">
				Evidence-based guides on the decisions that matter most in body composition. Each guide is built on peer-reviewed research — ISSN, ACSM, and published meta-analyses — designed to cut through the noise.
			</p>
		</div>

		<!-- Stats Bar -->
		<div class="mt-8 flex flex-wrap gap-6 text-sm text-muted-foreground border-b border-border pb-8">
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
				{guides.length} Expert Guides
			</span>
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
				~60 min total reading
			</span>
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
				ISSN & ACSM cited
			</span>
			<span class="trust-strip-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
				Reviewed June 2026
			</span>
		</div>

		<!-- Guide Cards Grid -->
		<div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
			{guides.map((guide) => (
				<a href={guide.href} class="app-card group relative flex flex-col gap-4" aria-label={`Read guide: ${guide.title}`}>
					<div class="flex items-start justify-between gap-3">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: color-mix(in srgb, var(--accent) 10%, var(--card));">
							<svg class="text-accent" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d={guide.iconPath}/>
							</svg>
						</div>
						<span class="text-xs font-semibold text-muted-foreground bg-muted px-2 py-0.5 rounded-full whitespace-nowrap">{guide.readTime}</span>
					</div>
					<div class="flex-1">
						<p class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{guide.label}</p>
						<h2 class="text-base font-bold text-foreground group-hover:text-accent transition-colors leading-snug">{guide.title}</h2>
						<p class="mt-2 text-sm text-muted-foreground leading-relaxed line-clamp-3">{guide.description}</p>
					</div>
					<div class="flex flex-wrap gap-1.5 mt-auto pt-3 border-t border-border">
						{guide.tags.map((tag) => (
							<span class="text-xs font-medium text-muted-foreground bg-muted px-2 py-0.5 rounded">{tag}</span>
						))}
					</div>
					<div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</div>
				</a>
			))}
		</div>

		<!-- CTA Section -->
		<div class="mt-14 content-panel bg-card border border-border rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6 justify-between"
			style="background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 5%, var(--card)), var(--card));">
			<div>
				<p class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Ready to act on it?</p>
				<h2 class="text-xl font-bold text-foreground">Turn knowledge into your personal strategy</h2>
				<p class="mt-2 text-sm text-muted-foreground max-w-md">
					The Strategy Finder translates your inputs — body fat, goal, training age, activity — into a concrete recommendation with calorie and protein targets.
				</p>
			</div>
			<div class="flex flex-col gap-3 shrink-0">
				<a href="/assess" class="button-primary">Start Free Assessment</a>
				<a href="/body-composition-strategy-guide" class="button-secondary text-center text-sm">Full Strategy Guide →</a>
			</div>
		</div>
	</section>
</Layout>
