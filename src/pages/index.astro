---
import Layout from '../layouts/Layout.astro';
import StrategyFinder from '../components/StrategyFinder.astro';
import { calculators, absoluteUrl } from '../data/site';

const webAppSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'BodyCompOS',
	applicationCategory: 'HealthApplication',
	operatingSystem: 'Web',
	url: absoluteUrl(),
	description: 'A local-first body composition strategy platform for assessment, targets, forecasting, and reassessment.',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
};
---

<Layout
	title="BodyCompOS - Body Composition Strategy Platform"
	description="Start with a body composition assessment, get a strategy recommendation, estimate calories and protein, then track whether the plan is working."
	canonical={absoluteUrl()}
	schema={webAppSchema}
>
	<StrategyFinder />

	<!-- Operating Loop -->
	<section class="site-container py-16 border-t border-border">
		<div class="max-w-3xl">
			<p class="eyebrow">Operating Loop</p>
			<h2 class="mt-2 text-3xl font-black tracking-tight text-foreground sm:text-4xl">From assessment to reassessment</h2>
			<p class="mt-4 text-base leading-7 text-muted-foreground">
				BodyCompOS links assessments with strategy guidance, calorie setting, and progressive monitoring to answer: <span class="text-foreground font-semibold">is your strategy actually working?</span>
			</p>
		</div>
		
		<div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{[
				['01', 'Assessment', 'Enter sex, age, height, weight, activity levels, and lifting background to define your physical base.'],
				['02', 'Strategy Choice', 'Identify your optimal current strategy (cut, bulk, maintenance, or recomp) and view confidence levels.'],
				['03', 'Calorie & Protein Targets', 'Get personalized starting nutrition targets using conservative metabolic rate formulas.'],
				['04', 'Weekly Check-Ins', 'Log daily weigh-ins and tracking adherence percentages locally without uploading sensitive data.'],
				['05', 'Progress Forecasting', 'Let the local forecast engine estimate your weeks-to-target weight and rate of change.'],
				['06', 'Trend Reassessment', 'Compare actual rates of change against predicted progress and adjust calorie targets automatically.'],
			].map(([step, title, body]) => (
				<div class="app-card flex flex-col justify-between group hover:shadow-soft">
					<div>
						<span class="text-xs font-black text-accent tracking-widest bg-accent/10 px-2 py-0.5 rounded">{step}</span>
						<h3 class="mt-4 text-base font-bold text-foreground">{title}</h3>
						<p class="mt-2 text-sm leading-6 text-muted-foreground">{body}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- Calculators Quick Links -->
	<section class="site-container py-16 border-t border-border">
		<div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
			<div class="max-w-xl">
				<p class="eyebrow">Calculators</p>
				<h2 class="mt-2 text-3xl font-black tracking-tight text-foreground sm:text-4xl">Supporting Strategy Tools</h2>
				<p class="mt-4 text-sm leading-6 text-muted-foreground">
					Dive deeper into custom metrics, formula breakdowns, and biological indexes once you have defined your primary direction.
				</p>
			</div>
			<a class="button-secondary shrink-0" href="/calculators">
				Browse All 19 Calculators
				<svg class="inline-block ml-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
			</a>
		</div>
		
		<div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{calculators.slice(0, 6).map((calc) => (
				<a class="app-card block group" href={`/calculators/${calc.slug}`}>
					<div class="flex justify-between items-start">
						<p class="font-bold text-foreground group-hover:text-accent transition-colors">{calc.title}</p>
						<svg class="text-muted-foreground group-hover:text-accent transition-colors" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</div>
					<p class="mt-2 text-sm leading-6 text-muted-foreground">{calc.description}</p>
				</a>
			))}
		</div>
	</section>

	<!-- Trust Foundations -->
	<section class="site-container py-16 border-t border-border">
		<div class="grid gap-8 lg:grid-cols-[1.2fr_1.8fr] lg:items-center rounded-xl border border-border bg-muted/20 p-6 sm:p-8">
			<div>
				<p class="eyebrow">Trust Foundations</p>
				<h2 class="mt-2 text-2xl font-bold text-foreground">Transparent calculations, local privacy</h2>
				<p class="mt-3 text-sm text-muted-foreground leading-relaxed">
					Formulas shown, tracking stays local, editorial policy in place. No fabricated claims, no server uploads.
				</p>
			</div>
			<div class="grid gap-3 sm:grid-cols-3">
				<a class="button-secondary text-center text-sm" href="/methodology">Formula Methodology</a>
				<a class="button-secondary text-center text-sm" href="/editorial-policy">Editorial Standards</a>
				<a class="button-secondary text-center text-sm" href="/privacy-policy">Privacy & Local Data</a>
			</div>
		</div>
	</section>
</Layout>
