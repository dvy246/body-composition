---
import '../styles/global.css';
import { SITE, absoluteUrl } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	type?: string;
	noindex?: boolean;
	schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = 'BodyCompOS - Body Composition Strategy Platform',
	description = SITE.description,
	canonical,
	type = 'website',
	noindex = false,
	schema = [],
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '');
const canonicalUrl = canonical || absoluteUrl(pathname);
const imageUrl = absoluteUrl('/og-image.png');
const schemaItems = Array.isArray(schema) ? schema : [schema];
const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE.name,
	url: SITE.origin,
	logo: {
		'@type': 'ImageObject',
		url: absoluteUrl('/favicon.svg'),
		width: 32,
		height: 32,
	},
	image: imageUrl,
	foundingDate: '2026',
	description: SITE.description,
	contactPoint: {
		'@type': 'ContactPoint',
		email: 'hello@bodystrategyhub.com',
		contactType: 'customer support',
		areaServed: 'US',
		availableLanguage: 'English',
	},
	sameAs: [
		'https://twitter.com/bodycompos',
	],
};

const breadcrumbSchema = pathname ? {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: pathname.split('/').filter(Boolean).map((part, index, arr) => {
		const urlPath = '/' + arr.slice(0, index + 1).join('/');
		const acronyms = new Set(['tdee', 'bmi', 'ffmi', 'bmr', 'lbm', 'whtr', 'bf', 'ffmi', 'eta', 'neat']);
		const name = part
			.split('-')
			.map((word) => acronyms.has(word) ? word.toUpperCase() : word.charAt(0).toUpperCase() + word.slice(1))
			.join(' ');
		return {
			'@type': 'ListItem',
			position: index + 1,
			name: name === 'Calculators' ? 'Calculators Hub' : name,
			item: absoluteUrl(urlPath),
		};
	}),
} : null;

const finalSchema = [organizationSchema, breadcrumbSchema, ...schemaItems].filter(Boolean);

interface NavItem {
	href: string;
	label: string;
	items?: { href: string; label: string }[];
}

const nav: NavItem[] = [
	{ href: '/', label: 'Strategy Finder' },
	{ 
		href: '/guides', 
		label: 'Guides',
		items: [
			{ href: '/guides/body-fat-percentage', label: 'Body Fat Percentage' },
			{ href: '/guides/body-recomposition', label: 'Body Recomposition' },
			{ href: '/guides/maintenance-calories', label: 'Maintenance Calories' },
			{ href: '/guides/protein-nutrition', label: 'Protein Nutrition' },
			{ href: '/guides/should-i-cut-or-bulk', label: 'Should I Cut or Bulk' },
			{ href: '/guides/weight-loss-plateau-guide', label: 'Weight Loss Plateaus' },
			{ href: '/guides/how-to-eat-in-a-calorie-deficit', label: 'Eating in a Deficit' },
			{ href: '/guides/high-protein-diet-for-body-composition', label: 'High Protein Diet' },
		]
	},
	{ 
		href: '/calculators', 
		label: 'Calculators',
		items: [
			{ href: '/calculators/calories', label: 'Calorie & Energy Hub' },
			{ href: '/calculators/tdee-calculator', label: 'TDEE Calculator' },
			{ href: '/calculators/bmr-calculator', label: 'BMR Calculator' },
			{ href: '/calculators/calorie-calculator', label: 'Calorie Calculator' },
			{ href: '/calculators/protein-calculator', label: 'Protein Calculator' },
			{ href: '/calculators/body-fat-calculator', label: 'Body Fat Calculator' },
			{ href: '/calculators/body-composition-calculator', label: 'Body Composition' },
			{ href: '/calculators/ffmi-calculator', label: 'FFMI Calculator' },
			{ href: '/calculators/macro-calculator', label: 'Macro Calculator' },
			{ href: '/calculators/ideal-weight-calculator', label: 'Ideal Weight' },
			{ href: '/calculators/bmi-calculator', label: 'BMI Calculator' },
		]
	},
	{ 
		href: '/compare', 
		label: 'Compare',
		items: [
			{ href: '/compare/mifflin-vs-katch-mcardle', label: 'Mifflin vs Katch' },
			{ href: '/compare/tdee-vs-bmr', label: 'TDEE vs BMR' },
			{ href: '/compare/clean-bulking-vs-dirty-bulking', label: 'Clean vs Dirty Bulking' },
			{ href: '/compare/cardio-vs-weights-for-loss', label: 'Cardio vs Weights' },
			{ href: '/compare/bmi-vs-body-fat-percentage', label: 'BMI vs Body Fat %' },
			{ href: '/compare/cut-vs-recomp', label: 'Cut vs Recomp' },
			{ href: '/compare/lean-bulk-vs-aggressive-bulk', label: 'Lean vs Aggressive Bulk' },
			{ href: '/compare/lean-bulk-vs-maingaining', label: 'Lean Bulk vs Maingaining' },
		]
	},
	{
		href: '/build-your-day',
		label: 'Build Your Day',
		items: [
			{ href: '/build-your-day', label: 'Strategy Overview' },
			{ href: '/build-your-day/cutting', label: 'Cutting Protocols' },
			{ href: '/build-your-day/lean-bulk', label: 'Lean Bulk Protocols' },
			{ href: '/build-your-day/recomp', label: 'Recomposition Protocols' },
			{ href: '/build-your-day/maintain', label: 'Maintenance Protocols' },
			{ href: '/build-your-day/aggressive-bulk', label: 'Aggressive Bulk Protocols' },
		]
	},
	{ href: '/body-composition-strategy-guide', label: 'How It Works' },
	{ href: '/dashboard', label: 'Strategy Dashboard' },
	{ href: '/faq', label: 'FAQ' },
	{ href: '/about', label: 'About Us' },
	{ href: '/contact', label: 'Contact Us' },
];

function isCurrent(href: string) {
	if (href === '/') return pathname === '';
	return pathname === href || pathname.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-G6X21LS8KB"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-G6X21LS8KB');
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
		<noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" /></noscript>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{noindex && <meta name="robots" content="noindex,follow" />}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="BodyCompOS — Body Composition Strategy Platform" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@bodycompos" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<meta name="twitter:image:alt" content="BodyCompOS — Body Composition Strategy Platform" />
		<meta name="theme-color" content="#0891b2" />
		<script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
		<script is:inline>
			const storedTheme = localStorage.getItem('bodycompos.theme');
			const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			document.documentElement.dataset.theme = storedTheme || (systemDark ? 'dark' : 'light');
		</script>
		{SITE.adsenseId && (
			<>
				<script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseId}`} crossorigin="anonymous"></script>
				<meta name="google-adsense-account" content={SITE.adsenseId} />
			</>
		)}
	</head>
	<body>
		<a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-card focus:px-4 focus:py-3 focus:shadow-lg" href="#main">Skip to content</a>
		<header class="sticky top-0 z-40 border-b border-border bg-background/88 backdrop-blur">
			<div class="site-container flex min-h-16 items-center justify-between gap-4">
				<a href="/" class="flex items-center gap-3 font-bold">
					<span class="brand-mark" aria-label="BodyCompOS">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="13.5" cy="7.5" r="1.8" fill="currentColor"/>
							<line x1="12.8" y1="10.7" x2="11.6" y2="14.3" />
							<line x1="12.8" y1="10.7" x2="8.5" y2="7.9" />
							<line x1="12.8" y1="10.7" x2="17.6" y2="10.9" />
							<line x1="11.6" y1="14.3" x2="8.3" y2="19.0" />
							<line x1="11.6" y1="14.3" x2="12.8" y2="20.7" />
						</svg>
					</span>
					<span>BodyCompOS</span>
				</a>
				<nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
					{nav.map((item) => {
						if (item.items) {
							return (
								<div class="nav-dropdown group">
									<a class="nav-link flex items-center gap-1" aria-current={isCurrent(item.href) ? 'page' : undefined} href={item.href}>
										{item.label}
										<svg width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform group-hover:rotate-180">
											<path d="M1 1l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/>
										</svg>
									</a>
									<div class="dropdown-menu">
										<div class="dropdown-menu-container">
											{item.items.map((subItem) => (
												<a class="dropdown-item" href={subItem.href}>{subItem.label}</a>
											))}
										</div>
									</div>
								</div>
							);
						}
						return (
							<a class="nav-link" aria-current={isCurrent(item.href) ? 'page' : undefined} href={item.href}>{item.label}</a>
						);
					})}
				</nav>
				<div class="flex items-center gap-3">
					<div class="theme-toggle" aria-label="Color theme">
						<button type="button" data-theme-choice="light" aria-label="Use light theme" aria-pressed="false">
							<svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"></path></svg>
						</button>
						<button type="button" data-theme-choice="dark" aria-label="Use dark theme" aria-pressed="false">
							<svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 14.5A8.5 8.5 0 0 1 9.5 4a7 7 0 1 0 10.5 10.5Z"></path></svg>
						</button>
					</div>
					<a class="button-primary hidden sm:inline-flex" href="/assess">Start assessment</a>
					<button id="mobile-menu-toggle" class="lg:hidden p-2 rounded-md hover:bg-muted text-muted-foreground hover:text-foreground" aria-label="Toggle navigation menu" aria-expanded="false">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
					</button>
				</div>
			</div>
		</header>
		<div id="mobile-menu" class="fixed inset-0 top-16 z-30 hidden overflow-y-auto bg-background/98 backdrop-blur lg:hidden" aria-hidden="true" tabindex="-1">
			<nav class="flex flex-col gap-2 p-6 text-lg font-bold" aria-label="Mobile navigation">
				{nav.map((item) => {
					if (item.items) {
						return (
							<div class="flex flex-col border-b border-border py-2">
								<a class="nav-link text-lg font-extrabold text-foreground" href={item.href}>{item.label}</a>
								<div class="mt-1.5 flex flex-col gap-1 pl-4 mb-2">
									{item.items.map((subItem) => (
										<a class="text-sm font-semibold text-muted-foreground hover:text-foreground py-1.5 transition-colors" href={subItem.href}>{subItem.label}</a>
									))}
								</div>
							</div>
						);
					}
					return (
						<a class="nav-link text-lg py-3 border-b border-border" href={item.href}>{item.label}</a>
					);
				})}
				<a class="button-primary mt-6 text-center" href="/assess">Start assessment</a>
			</nav>
		</div>
		<main id="main">
			<slot />
		</main>
		<footer class="mt-20 border-t border-border" style="background: var(--card);">
			<div class="site-container py-12">
				<!-- Footer brand + trust strip -->
				<div class="grid gap-10 md:grid-cols-[1.4fr_2fr]">
					<div>
						<a href="/" class="flex items-center gap-2.5 font-bold text-foreground mb-3">
							<span class="brand-mark" aria-hidden="true">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="13.5" cy="7.5" r="1.8" fill="currentColor"/>
									<line x1="12.8" y1="10.7" x2="11.6" y2="14.3" />
									<line x1="12.8" y1="10.7" x2="8.5" y2="7.9" />
									<line x1="12.8" y1="10.7" x2="17.6" y2="10.9" />
									<line x1="11.6" y1="14.3" x2="8.3" y2="19.0" />
									<line x1="11.6" y1="14.3" x2="12.8" y2="20.7" />
								</svg>
							</span>
							BodyCompOS
						</a>
						<p class="text-sm leading-6 text-muted-foreground max-w-xs">Evidence-based body composition strategy platform. Fully local — no data leaves your device. Not medical advice.</p>
						<!-- Trust badges -->
						<div class="mt-5 flex flex-col gap-2">
							<div class="trust-strip-item">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
								Peer-reviewed formulas (ISSN, ACSM)
							</div>
							<div class="trust-strip-item">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
								100% private — no account required
							</div>
							<div class="trust-strip-item">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
