					<div class="grid gap-6 text-sm text-muted-foreground grid-cols-1 min-[500px]:grid-cols-2 sm:grid-cols-4">
						<div class="flex flex-col gap-2">
							<p class="font-bold text-foreground text-xs uppercase tracking-wider mb-1">Platform</p>
