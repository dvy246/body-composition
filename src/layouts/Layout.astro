---
import '../styles/global.css';
import { SITE, absoluteUrl } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	type?: string;
	noindex?: boolean;
	schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = 'BodyCompOS - Body Composition Strategy Platform',
	description = SITE.description,
	canonical,
	type = 'website',
	noindex = false,
	schema = [],
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '');
const canonicalUrl = canonical || absoluteUrl(pathname);
const imageUrl = absoluteUrl('/og-image.png');
const schemaItems = Array.isArray(schema) ? schema : [schema];
const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE.name,
	url: SITE.origin,
	logo: imageUrl,
	contactPoint: {
		'@type': 'ContactPoint',
		email: 'hello@bodycompos.com',
		contactType: 'customer support',
	},
};

const breadcrumbSchema = pathname ? {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: pathname.split('/').filter(Boolean).map((part, index, arr) => {
		const urlPath = '/' + arr.slice(0, index + 1).join('/');
		const acronyms = new Set(['tdee', 'bmi', 'ffmi', 'bmr', 'lbm', 'whtr', 'bf', 'ffmi', 'eta', 'neat']);
		const name = part
			.split('-')
			.map((word) => acronyms.has(word) ? word.toUpperCase() : word.charAt(0).toUpperCase() + word.slice(1))
			.join(' ');
		return {
			'@type': 'ListItem',
			position: index + 1,
			name: name === 'Calculators' ? 'Calculators Hub' : name,
			item: absoluteUrl(urlPath),
		};
	}),
} : null;

const finalSchema = [organizationSchema, breadcrumbSchema, ...schemaItems].filter(Boolean);

const nav = [
	{ href: '/', label: 'Assessment' },
	{ href: '/body-composition-strategy-guide', label: 'Strategy Guide' },
	{ href: '/calculators', label: 'Calculators' },
	{ href: '/guides', label: 'Guides' },
	{ href: '/methodology', label: 'Methodology' },
	{ href: '/dashboard', label: 'Dashboard' },
];

function isCurrent(href: string) {
	if (href === '/') return pathname === '';
	return pathname === href || pathname.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{noindex && <meta name="robots" content="noindex,follow" />}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:image" content={imageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
		<script is:inline>
			const storedTheme = localStorage.getItem('bodycompos.theme');
			const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			document.documentElement.dataset.theme = storedTheme || (systemDark ? 'dark' : 'light');
		</script>
	</head>
	<body>
		<a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-card focus:px-4 focus:py-3 focus:shadow-lg" href="#main">Skip to content</a>
		<header class="sticky top-0 z-40 border-b border-border bg-background/88 backdrop-blur">
			<div class="site-container flex min-h-16 items-center justify-between gap-4">
				<a href="/" class="flex items-center gap-3 font-bold">
					<span class="brand-mark" aria-label="BodyCompOS">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="8" r="3.5"/>
							<path d="M5 21v-3a7 7 0 0 1 14 0v3"/>
							<line x1="8" y1="11" x2="5" y2="15"/>
							<line x1="16" y1="11" x2="19" y2="15"/>
						</svg>
					</span>
					<span>BodyCompOS</span>
				</a>
				<nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
					{nav.map((item) => (
						<a class="nav-link" aria-current={isCurrent(item.href) ? 'page' : undefined} href={item.href}>{item.label}</a>
					))}
				</nav>
				<div class="flex items-center gap-3">
					<div class="theme-toggle" aria-label="Color theme">
						<button type="button" data-theme-choice="light" aria-label="Use light theme" aria-pressed="false">
							<svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"></path></svg>
						</button>
						<button type="button" data-theme-choice="dark" aria-label="Use dark theme" aria-pressed="false">
							<svg aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 14.5A8.5 8.5 0 0 1 9.5 4a7 7 0 1 0 10.5 10.5Z"></path></svg>
						</button>
					</div>
					<a class="button-primary hidden sm:inline-flex" href="/assess">Start assessment</a>
					<button id="mobile-menu-toggle" class="lg:hidden p-2 rounded-md hover:bg-muted text-muted-foreground hover:text-foreground" aria-label="Toggle navigation menu" aria-expanded="false">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
					</button>
				</div>
			</div>
		</header>
		<div id="mobile-menu" class="fixed inset-0 top-16 z-30 hidden bg-background/98 backdrop-blur lg:hidden" aria-hidden="true" tabindex="-1">
			<nav class="flex flex-col gap-4 p-6 text-lg font-bold" aria-label="Mobile navigation">
				{nav.map((item) => (
					<a class="nav-link text-xl py-3 border-b border-border" href={item.href}>{item.label}</a>
				))}
				<a class="button-primary mt-6 text-center" href="/assess">Start assessment</a>
			</nav>
		</div>
		<main id="main">
			<slot />
		</main>
		<footer class="mt-20 border-t border-border bg-card">
			<div class="site-container grid gap-8 py-10 md:grid-cols-[1.2fr_2fr]">
				<div>
					<p class="font-bold">BodyCompOS</p>
					<p class="mt-3 max-w-md text-sm leading-6 text-muted-foreground">Local-first body composition strategy, targets, forecasting, and reassessment. Full boundaries live in the methodology and disclaimer.</p>
				</div>
				<div class="grid gap-6 text-sm text-muted-foreground sm:grid-cols-4">
					<div class="flex flex-col gap-2">
						<p class="font-bold text-foreground text-xs uppercase tracking-wider mb-1">Platform</p>
						<a href="/about">About Us</a>
						<a href="/contact">Feedback & Contact</a>
						<a href="/editorial-policy">Editorial Policy</a>
					</div>
					<div class="flex flex-col gap-2">
						<p class="font-bold text-foreground text-xs uppercase tracking-wider mb-1">Trust & Legal</p>
						<a href="/disclaimer">Disclaimer</a>
						<a href="/privacy-policy">Privacy Policy</a>
						<a href="/terms">Terms & Conditions</a>
					</div>
					<div class="flex flex-col gap-2">
						<p class="font-bold text-foreground text-xs uppercase tracking-wider mb-1">Resources</p>
						<a href="/calculators">Calculators Hub</a>
						<a href="/guides">Guides Hub</a>
						<a href="/compare">Comparisons Hub</a>
						<a href="/faq">FAQ Hub</a>
						<a href="/methodology">Methodology & Science</a>
					</div>
					<div class="flex flex-col gap-2">
						<p class="font-bold text-foreground text-xs uppercase tracking-wider mb-1">Strategic Guides</p>
						<a href="/guides/should-i-cut-or-bulk" class="hover:text-accent">Should I Cut or Bulk?</a>
						<a href="/guides/body-recomposition" class="hover:text-accent">Body Recomposition</a>
						<a href="/guides/protein-nutrition" class="hover:text-accent">Protein Nutrition</a>
						<a href="/guides/body-fat-percentage" class="hover:text-accent">Body Fat Percentage</a>
						<a href="/guides/maintenance-calories" class="hover:text-accent">Maintenance Calories</a>
					</div>
				</div>
			</div>
			<!-- Footer Bottom Bar -->
			<div class="border-t border-border mt-8 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 text-xs text-muted-foreground">
				<p>© {new Date().getFullYear()} BodyCompOS. Educational estimates only — not medical advice.</p>
				<div class="flex gap-4">
					<a href="/privacy-policy" class="hover:text-accent transition-colors">Privacy</a>
					<a href="/terms" class="hover:text-accent transition-colors">Terms</a>
					<a href="/disclaimer" class="hover:text-accent transition-colors">Disclaimer</a>
					<a href="/contact" class="hover:text-accent transition-colors">Contact</a>
				</div>
			</div>
		</footer>
		<script>
			function syncThemeButtons() {
				const theme = document.documentElement.dataset.theme || 'light';
				document.querySelectorAll('[data-theme-choice]').forEach((button) => {
					button.setAttribute('aria-pressed', String(button.dataset.themeChoice === theme));
				});
			}
			document.querySelectorAll('[data-theme-choice]').forEach((button) => {
				button.addEventListener('click', () => {
					const theme = button.dataset.themeChoice;
					document.documentElement.dataset.theme = theme;
					localStorage.setItem('bodycompos.theme', theme);
					syncThemeButtons();
				});
			});
			syncThemeButtons();

			// Mobile navigation toggle handler
			const menuToggle = document.getElementById('mobile-menu-toggle');
			const mobileMenu = document.getElementById('mobile-menu');
			const menuLinks = mobileMenu?.querySelectorAll('a');
			
			function openMobileMenu() {
				menuToggle?.setAttribute('aria-expanded', 'true');
				mobileMenu?.classList.remove('hidden');
				mobileMenu?.setAttribute('aria-hidden', 'false');
				document.body.classList.add('overflow-hidden');
				const firstLink = menuLinks?.[0] as HTMLElement | undefined;
				firstLink?.focus();
			}
			
			function closeMobileMenu() {
				menuToggle?.setAttribute('aria-expanded', 'false');
				mobileMenu?.classList.add('hidden');
				mobileMenu?.setAttribute('aria-hidden', 'true');
				document.body.classList.remove('overflow-hidden');
				menuToggle?.focus();
			}
			
			menuToggle?.addEventListener('click', () => {
				const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
				isExpanded ? closeMobileMenu() : openMobileMenu();
			});
			
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && mobileMenu?.classList.contains('hidden') === false) {
					closeMobileMenu();
				}
			});
			
			mobileMenu?.addEventListener('keydown', (e) => {
				if (e.key !== 'Tab' || !menuLinks?.length) return;
				const firstLink = menuLinks[0] as HTMLElement;
				const lastLink = menuLinks[menuLinks.length - 1] as HTMLElement;
				if (e.shiftKey && document.activeElement === firstLink) {
					e.preventDefault();
					lastLink.focus();
				} else if (!e.shiftKey && document.activeElement === lastLink) {
					e.preventDefault();
					firstLink.focus();
				}
			});

			// Close mobile menu on nav link clicks
			menuLinks?.forEach((link) => {
				link.addEventListener('click', closeMobileMenu);
			});
		</script>

		<!-- Cookie / AdSense Consent Banner -->
		<div id="cookie-banner" class="cookie-banner" role="alertdialog" aria-label="Cookie consent" aria-live="polite" hidden>
			<div class="cookie-banner__inner">
				<p class="cookie-banner__text">
					We use cookies and may display ads to keep BodyCompOS free. No personal data is sold.
					<a href="/privacy-policy" class="cookie-banner__link">Privacy Policy</a>
				</p>
				<div class="cookie-banner__actions">
					<button id="cookie-accept" class="cookie-banner__btn cookie-banner__btn--accept">Accept</button>
					<button id="cookie-decline" class="cookie-banner__btn cookie-banner__btn--decline">Decline</button>
				</div>
			</div>
		</div>
		<script>
			(function() {
				const consent = localStorage.getItem('bodycompos.cookie-consent');
				const banner = document.getElementById('cookie-banner');
				if (!consent && banner) banner.removeAttribute('hidden');
				document.getElementById('cookie-accept')?.addEventListener('click', () => {
					localStorage.setItem('bodycompos.cookie-consent', 'accepted');
					if (banner) banner.setAttribute('hidden', '');
				});
				document.getElementById('cookie-decline')?.addEventListener('click', () => {
					localStorage.setItem('bodycompos.cookie-consent', 'declined');
					if (banner) banner.setAttribute('hidden', '');
				});
			})();
		</script>
	</body>
</html>
