---
const steps = [
	['Assess', 'Your stats & body composition'],
	['Analyze', 'Algorithm weighs inputs'],
	['Recommend', 'Personalized strategy'],
	['Track', 'Weekly check-ins'],
	['Improve', 'Reassess & adjust'],
];
const features = [
	'Personalized Strategy', 
	'Confidence & Alternative',
	'Calorie Targets', 
	'Protein Range',
	'Estimated Timeline', 
	'Progress Tracking',
];
---

<section class="site-container py-8 lg:py-10">
	<div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-10">
		<!-- Hero Content -->
		<div class="flex flex-col justify-center max-w-xl">
			<div class="inline-flex mb-5">
				<span class="badge badge-accent">Evidence-Based Strategy Engine</span>
			</div>
			<h1 class="text-4xl font-black leading-[1.08] tracking-tight text-foreground sm:text-5xl lg:text-6xl">
				Your Body Doesn't Need Another Calculator.<br/>
				<span class="text-accent">It Needs the Right Strategy.</span>
			</h1>
			<p class="mt-6 text-base sm:text-lg leading-relaxed text-muted-foreground">
				BodyCompOS is a local-first strategy platform. Map your metrics, determine your optimal phase direction (cut, bulk, recomp, maintain), and track your progress locally without uploading sensitive data.
			</p>

			<!-- Simplified Trust/Feature Grid -->
			<div class="mt-8 grid grid-cols-2 gap-4 text-xs font-semibold text-muted-foreground border-t border-border pt-6">
				<div class="flex items-center gap-2">
					<svg class="text-accent" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					<span>100% Private local-storage</span>
				</div>
				<div class="flex items-center gap-2">
					<svg class="text-accent" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
					<span>Science-backed formulas</span>
				</div>
				<div class="flex items-center gap-2">
					<svg class="text-accent" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
					<span>No account or sign-up</span>
				</div>
				<div class="flex items-center gap-2">
					<svg class="text-accent" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
					<span>Free planning resources</span>
				</div>
			</div>

			<div class="mt-8 flex flex-wrap items-center gap-3">
				<a class="button-primary" href="/assess">Start Free Assessment</a>
				<a class="button-ghost text-sm" href="/body-composition-strategy-guide">
					How It Works
					<svg class="inline-block ml-1" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
				</a>
			</div>
		</div>

		<!-- Right Column: Simplified Interactive Calculator -->
		<div class="flex flex-col gap-4">
			<div class="surface rounded-2xl p-5">
				<div class="flex items-center justify-between border-b border-border pb-3">
					<div>
						<p class="eyebrow">Interactive Engine</p>
						<h2 class="text-base font-black text-foreground">Strategy Finder</h2>
					</div>
					<div class="segmented" role="group" aria-label="Measurement units">
						<button type="button" data-strategy-unit="metric" aria-pressed="true">Metric</button>
						<button type="button" data-strategy-unit="imperial" aria-pressed="false">Imperial</button>
					</div>
				</div>

				<form id="strategy-form" class="mt-3 grid gap-2.5 sm:grid-cols-2">
					<div class="sm:col-span-2">
						<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Personal</p>
						<div class="border-t border-border/30 mt-1"></div>
					</div>

					<div class="field">
						<label for="sex">Biological Sex</label>
						<div class="select-wrap">
							<select id="sex" required>
								<option value="male">Male</option>
								<option value="female">Female</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="age">Age</label>
						<input id="age" type="number" min="18" max="90" placeholder="e.g. 32" required />
					</div>
					<div class="field">
						<label for="height">Height <span data-strategy-height-unit>(cm)</span></label>
						<input id="height" type="number" min="120" max="230" placeholder="e.g. 175" required />
					</div>
					<div class="field">
						<label for="weight">Weight <span data-strategy-weight-unit>(kg)</span></label>
						<input id="weight" type="number" min="35" max="250" step="0.1" placeholder="e.g. 82" required />
					</div>

					<div class="sm:col-span-2 mt-0.5">
						<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Body Composition</p>
						<div class="border-t border-border/30 mt-1"></div>
					</div>

					<div class="field sm:col-span-2">
						<label for="bodyFat">Estimated Body Fat %</label>
						<input id="bodyFat" type="number" min="3" max="60" step="0.1" placeholder="e.g. 22" required />
						<p class="text-[11px] text-muted-foreground leading-relaxed mt-1">
							Body fat percentage estimates the proportion of your body weight from fat tissue.
							If you're unsure, you can estimate it using our
							<a href="/calculators/body-fat-calculator" class="text-accent underline font-medium hover:no-underline">Body Fat Calculator</a>.
						</p>
						<a href="/calculators/body-fat-calculator"
						   class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent hover:text-accent/80 transition-colors mt-1">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
							Estimate Body Fat
						</a>
					</div>

					<div class="sm:col-span-2 mt-0.5">
						<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Training &amp; Goals</p>
						<div class="border-t border-border/30 mt-1"></div>
					</div>

					<div class="field">
						<label for="activity">Activity Level</label>
						<div class="select-wrap">
							<select id="activity" required>
								<option value="sedentary">Sedentary (desk-job)</option>
								<option value="light">Lightly Active (active-job/walks)</option>
								<option value="moderate" selected>Moderately Active (trains 3-5x/week)</option>
								<option value="active">Highly Active (trains 6-7x/week)</option>
								<option value="athlete">Competitive Athlete</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="goalBias">Goal Direction</label>
						<div class="select-wrap">
							<select id="goalBias" required>
								<option value="fat-loss">Fat Loss Focused</option>
								<option value="recomp" selected>Body Recomposition</option>
								<option value="lean-bulk">Lean Muscle Bulk</option>
								<option value="aggressive-bulk">Aggressive Mass Gain</option>
								<option value="maintain">Weight Maintenance</option>
							</select>
						</div>
					</div>

					<button class="button-primary sm:col-span-2 mt-0.5" type="submit">Start Assessment</button>
				</form>

				<div id="strategy-result" class="result-container mt-4 border-t border-border pt-4" aria-live="polite" tabindex="-1">
					<div class="result-placeholder">
						<svg class="text-muted-foreground" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
						<p class="mt-2 text-sm font-semibold text-foreground">Awaiting Inputs</p>
						<p class="mt-1 text-xs text-muted-foreground">Enter stats to get your personalized strategy.</p>
					</div>
				</div>
			</div>

			<p class="text-center text-xs text-muted-foreground">
				Need more detail?
				<a href="/assess" class="underline hover:text-accent font-medium">Use the Full Assessment</a>
			</p>
		</div>
	</div>
</section>

<script>
	import {
		mifflin as engineMifflin,
		strategyRecommendation,
		calorieTarget,
		activityFactors,
		goalLabels,
		round,
		clamp,
		calculateNavyBodyFat,
		paceAndTimeline,
	} from '../lib/engines';
	import { autoFillBodyFat, setStrategyUnit as setUnit, saveAssessment } from '../lib/strategyForm';

	let strategyUnit = 'metric';

	autoFillBodyFat();

	document.querySelectorAll('[data-strategy-unit]').forEach((button) => {
		button.addEventListener('click', () => {
			const form = document.querySelector('#strategy-form') as HTMLFormElement;
			strategyUnit = setUnit(button.getAttribute('data-strategy-unit') ?? 'metric', strategyUnit, form);
		});
	});
	
	document.querySelector('#strategy-form')?.addEventListener('submit', (event) => {
		event.preventDefault();
		const form = event.currentTarget as HTMLFormElement;
		
		const rawInput = {
			sex: form.sex.value as 'male' | 'female',
			age: Number(form.age.value),
			heightCm: strategyUnit === 'metric' ? Number(form.height.value) : inToCm(Number(form.height.value)),
			weightKg: strategyUnit === 'metric' ? Number(form.weight.value) : lbToKg(Number(form.weight.value)),
			bodyFat: Number(form.bodyFat.value || 0),
			activity: form.activity.value as keyof typeof activityFactors,
			trainingAge: 'intermediate' as const,
			goalBias: form.goalBias.value as any,
			protein: 0,
		};

		const proteinAdequate = false;
		const rec = strategyRecommendation({ ...rawInput, proteinAdequate });
		const bmr = engineMifflin({ sex: rawInput.sex, age: rawInput.age, heightCm: rawInput.heightCm, weightKg: rawInput.weightKg });
		const maintenance = round(bmr * activityFactors[rawInput.activity]);
		const target = calorieTarget(maintenance, rec.recommended);
		const proteinLow = round(rawInput.weightKg * 1.6);
		const proteinHigh = round(rawInput.weightKg * 2.2);
		
		const saved = { ...rawInput, proteinAdequate, ...rec, maintenance, target, proteinLow, proteinHigh, createdAt: new Date().toISOString() };
		saveAssessment(saved);
		
		// Compute pace text — respects unit toggle for display
		const { paceText, timelineText } = paceAndTimeline(rec.recommended, rawInput.weightKg, strategyUnit as 'metric' | 'imperial');
		
		const outputContainer = document.querySelector('#strategy-result');
		if (outputContainer) {
			outputContainer.classList.add('has-result');
			outputContainer.innerHTML = `
				<div class="result-content grid gap-3 text-left animate-fade-in-up">
					<div class="flex items-start justify-between gap-3">
						<div>
							<p class="text-xs font-bold uppercase text-accent tracking-wider">Assessment Result</p>
							<p class="mt-1 text-lg font-black text-foreground">${goalLabels[rec.recommended]}</p>
						</div>
						<span class="badge badge-accent shrink-0 mt-1">${rec.confidence}%</span>
					</div>
					
					<div class="grid gap-2.5 sm:grid-cols-2">
						<div class="result-card">
							<p class="text-xs font-bold uppercase text-muted-foreground">Alternative</p>
							<p class="mt-1 text-xs font-bold text-foreground">${goalLabels[rec.alternative]} (${rec.alternativeConfidence}%)</p>
						</div>
						<div class="result-card bg-accent/5 border-accent/20">
							<p class="text-xs font-bold uppercase text-accent tracking-wider">Calories</p>
							<p class="mt-1 text-base font-black text-foreground">${target} <span class="text-xs font-normal text-muted-foreground">kcal</span></p>
						</div>
					</div>

					<div class="grid gap-2.5 sm:grid-cols-2">
						<div class="result-card bg-success/5 border-success/20">
							<p class="text-xs font-bold uppercase text-success tracking-wider">Protein</p>
							<p class="mt-1 text-base font-black text-foreground">${proteinLow} - ${proteinHigh} <span class="text-xs font-normal text-muted-foreground">g</span></p>
						</div>
						<div class="result-card">
							<p class="text-xs font-bold uppercase text-muted-foreground">Timeline</p>
							<p class="mt-1 text-xs font-black text-foreground">${timelineText}</p>
						</div>
					</div>

					<div class="flex flex-col sm:flex-row gap-2.5 pt-0.5">
						<a class="button-primary flex-1 text-center text-xs" href="/dashboard">Track Progress</a>
						<a class="button-secondary flex-1 text-center text-xs" href="/assess">Full Assessment</a>
					</div>
					<p class="mt-2 text-xs font-medium text-warning">Educational estimates — consult a healthcare professional before starting.</p>
				</div>
			`;
			
			outputContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			(outputContainer as HTMLElement).focus();
		}
	});
</script>
