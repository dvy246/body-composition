---
const steps = [
	['Assess', 'Your stats & body composition'],
	['Analyze', 'Algorithm weighs inputs'],
	['Recommend', 'Personalized strategy'],
	['Track', 'Weekly check-ins'],
	['Improve', 'Reassess & adjust'],
];
const features = [
	'Personalized Strategy',
	'Confidence & Alternative',
	'Calorie Targets',
	'Protein Range',
	'Estimated Timeline',
	'Progress Tracking',
];
---

<section class="site-container py-8 lg:py-10">
	<div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-10">
		<!-- Hero Content -->
		<div class="flex flex-col justify-center">
			<div class="inline-flex mb-5">
				<span class="badge badge-accent">Evidence-Based Strategy Engine</span>
			</div>
			<h1 class="text-4xl font-black leading-[1.08] tracking-tight text-foreground sm:text-5xl lg:text-6xl">
				Your Body Doesn't Need Another Calculator.<br/>
				<span class="text-accent">It Needs the Right Strategy.</span>
			</h1>

			<!-- Benefit bullets (scannable, replaces dense paragraph) -->
			<ul class="mt-5 grid gap-2.5 max-w-lg">
				<li class="flex items-start gap-3 text-sm sm:text-base text-muted-foreground">
					<svg class="mt-0.5 shrink-0 text-accent" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					<span>Assess your current body composition and training status.</span>
				</li>
				<li class="flex items-start gap-3 text-sm sm:text-base text-muted-foreground">
					<svg class="mt-0.5 shrink-0 text-accent" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					<span>Receive a personalized strategy recommendation — cut, bulk, recomp, or maintain.</span>
				</li>
				<li class="flex items-start gap-3 text-sm sm:text-base text-muted-foreground">
					<svg class="mt-0.5 shrink-0 text-accent" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					<span>Get calorie and protein targets, pace estimates, and a timeline.</span>
				</li>
				<li class="flex items-start gap-3 text-sm sm:text-base text-muted-foreground">
					<svg class="mt-0.5 shrink-0 text-accent" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					<span>Track weekly check-ins and forecast when you'll reach your goal.</span>
				</li>
			</ul>

			<!-- Strategy Flow Visual -->
			<div class="mt-7 grid grid-cols-5 gap-1 max-w-lg">
				{steps.map(([label], i) => (
					<div class="flex flex-col items-center text-center">
						<div class="flex h-7 w-7 items-center justify-center rounded-full text-[10px] font-bold" style={`background:color-mix(in srgb, var(--accent) ${15 - i * 2}%, transparent);color:var(--accent);border:1.5px solid color-mix(in srgb, var(--accent) ${40 - i * 5}%, var(--border))`}>{i + 1}</div>
						<p class="mt-1 text-[10px] font-bold text-foreground leading-tight">{label}</p>
					</div>
				))}
			</div>

			<!-- Result Preview Card -->
			<div class="mt-7 surface rounded-xl p-4 max-w-md border border-accent/20">
				<p class="text-[10px] font-bold uppercase tracking-wider text-accent mb-2.5">What You'll Receive</p>
				<div class="grid grid-cols-2 gap-x-4 gap-y-2">
					{features.map(item => (
						<div class="flex items-center gap-2">
							<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
							<span class="text-[11px] text-foreground font-medium">{item}</span>
						</div>
					))}
				</div>
			</div>

			<!-- Trust + Social Proof Strip -->
			<div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-muted-foreground">
				<span class="flex items-center gap-1.5 font-medium">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
					15+ Evidence-Based Calculators
				</span>
				<span class="flex items-center gap-1.5 font-medium">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					Research-Backed Formulas
				</span>
				<span class="flex items-center gap-1.5 font-medium">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
					Local-First &amp; Private
				</span>
				<span class="flex items-center gap-1.5 font-medium">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
					Educational Estimates
				</span>
			</div>

			<div class="mt-6 flex flex-wrap items-center gap-3">
				<a class="button-primary" href="/assess">Start Free Assessment</a>
				<a class="button-ghost text-sm" href="/body-composition-strategy-guide">
					How It Works
					<svg class="inline-block ml-1" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
				</a>
			</div>
	</div>

		<!-- Right Column: Simplified Interactive Calculator -->
		<div class="flex flex-col gap-4">
			<div class="surface rounded-2xl p-5">
				<div class="flex items-center justify-between border-b border-border pb-3">
					<div>
						<p class="eyebrow">Interactive Engine</p>
						<h2 class="text-base font-black text-foreground">Strategy Finder</h2>
					</div>
					<div class="segmented" role="group" aria-label="Measurement units">
						<button type="button" data-strategy-unit="metric" aria-pressed="true">Metric</button>
						<button type="button" data-strategy-unit="imperial" aria-pressed="false">Imperial</button>
					</div>
				</div>

				<form id="strategy-form" class="mt-3 grid gap-2.5 sm:grid-cols-2">
					<div class="sm:col-span-2">
						<p class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground">Personal</p>
						<div class="border-t border-border/30 mt-1"></div>
					</div>

					<div class="field">
						<label for="sex">Biological Sex</label>
						<div class="select-wrap">
							<select id="sex" required>
								<option value="male">Male</option>
								<option value="female">Female</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="age">Age</label>
						<input id="age" type="number" min="18" max="90" placeholder="e.g. 32" required />
					</div>
					<div class="field">
						<label for="height">Height <span data-strategy-height-unit>(cm)</span></label>
						<input id="height" type="number" min="120" max="230" placeholder="e.g. 175" required />
					</div>
					<div class="field">
						<label for="weight">Weight <span data-strategy-weight-unit>(kg)</span></label>
						<input id="weight" type="number" min="35" max="250" step="0.1" placeholder="e.g. 82" required />
					</div>

					<div class="sm:col-span-2 mt-0.5">
						<p class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground">Body Composition</p>
						<div class="border-t border-border/30 mt-1"></div>
					</div>

					<div class="field sm:col-span-2">
						<label for="bodyFat">Estimated Body Fat %</label>
						<input id="bodyFat" type="number" min="3" max="60" step="0.1" placeholder="e.g. 22" required />
						<p class="text-[11px] text-muted-foreground leading-relaxed mt-1">
							Body fat percentage estimates the proportion of your body weight from fat tissue.
							If you're unsure, you can estimate it using our
							<a href="/calculators/body-fat-calculator" class="text-accent underline font-medium hover:no-underline">Body Fat Calculator</a>.
						</p>
						<a href="/calculators/body-fat-calculator"
						   class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent hover:text-accent/80 transition-colors mt-1">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
							Estimate Body Fat
						</a>
					</div>

					<div class="sm:col-span-2 mt-0.5">
						<p class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground">Training &amp; Goals</p>
						<div class="border-t border-border/30 mt-1"></div>
					</div>

					<div class="field">
						<label for="activity">Activity Level</label>
						<div class="select-wrap">
							<select id="activity" required>
								<option value="sedentary">Sedentary (desk-job)</option>
								<option value="light">Lightly Active (active-job/walks)</option>
								<option value="moderate" selected>Moderately Active (trains 3-5x/week)</option>
								<option value="active">Highly Active (trains 6-7x/week)</option>
								<option value="athlete">Competitive Athlete</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="goalBias">Goal Direction</label>
						<div class="select-wrap">
							<select id="goalBias" required>
								<option value="fat-loss">Fat Loss Focused</option>
								<option value="recomp" selected>Body Recomposition</option>
								<option value="lean-bulk">Lean Muscle Bulk</option>
								<option value="aggressive-bulk">Aggressive Mass Gain</option>
								<option value="maintain">Weight Maintenance</option>
							</select>
						</div>
					</div>

					<button class="button-primary sm:col-span-2 mt-0.5" type="submit">Start Assessment</button>
				</form>

				<div id="strategy-result" class="result-container mt-4 border-t border-border pt-4" aria-live="polite" tabindex="-1">
					<div class="result-placeholder">
						<svg class="text-muted-foreground" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
						<p class="mt-2 text-sm font-semibold text-foreground">Awaiting Inputs</p>
						<p class="mt-1 text-xs text-muted-foreground">Enter stats to get your personalized strategy.</p>
					</div>
				</div>
			</div>

			<p class="text-center text-[10px] text-muted-foreground">
				Need more detail?
				<a href="/assess" class="underline hover:text-accent font-medium">Use the Full Assessment</a>
			</p>
		</div>
	</div>
</section>

<script>
	import {
		mifflin as engineMifflin,
		strategyRecommendation,
		calorieTarget,
		activityFactors,
		goalLabels,
		round,
		clamp,
		calculateNavyBodyFat,
	} from '../lib/engines';

	let strategyUnit = 'metric';

	(function() {
		const savedBf = localStorage.getItem('bodycompos.estimatedBodyFat');
		if (savedBf) {
			const input = document.getElementById('bodyFat') as HTMLInputElement;
			if (input && !input.dataset.autofilled) {
				input.value = savedBf;
				input.dataset.autofilled = 'true';
				const msg = document.createElement('p');
				msg.className = 'text-xs text-success font-medium mt-1.5';
				msg.textContent = 'Estimated body fat imported successfully.';
				input.parentElement?.appendChild(msg);
				setTimeout(() => msg.remove(), 4000);
			}
		}
	})();

	function safeJsonParse(value: string | null, fallback: any) {
		try { return value ? JSON.parse(value) : fallback; } catch { return fallback; }
	}

	function kgToLb(kg: number) { return kg * 2.2046226218; }
	function lbToKg(lb: number) { return lb / 2.2046226218; }
	function cmToIn(cm: number) { return cm / 2.54; }
	function inToCm(value: number) { return value * 2.54; }

	function setStrategyUnit(unit: string) {
		if (unit === strategyUnit) return;
		const form = document.querySelector('#strategy-form') as HTMLFormElement;
		if (!form) return;

		const height = Number(form.height.value);
		const weight = Number(form.weight.value);

		if (unit === 'imperial') {
			form.height.value = String(round(cmToIn(height), 1));
			form.weight.value = String(round(kgToLb(weight), 1));
			form.height.min = '47';
			form.height.max = '91';
			form.weight.min = '77';
			form.weight.max = '551';
		} else {
			form.height.value = String(round(inToCm(height), 1));
			form.weight.value = String(round(lbToKg(weight), 1));
			form.height.min = '120';
			form.height.max = '230';
			form.weight.min = '35';
			form.weight.max = '250';
		}

		strategyUnit = unit;
		document.querySelectorAll('[data-strategy-unit]').forEach((button) => button.setAttribute('aria-pressed', String(button.getAttribute('data-strategy-unit') === unit)));
		document.querySelectorAll('[data-strategy-height-unit]').forEach((label) => label.textContent = unit === 'metric' ? '(cm)' : '(in)');
		document.querySelectorAll('[data-strategy-weight-unit]').forEach((label) => label.textContent = unit === 'metric' ? '(kg)' : '(lb)');
	}

	document.querySelectorAll('[data-strategy-unit]').forEach((button) => {
		button.addEventListener('click', () => setStrategyUnit(button.getAttribute('data-strategy-unit') ?? 'metric'));
	});

	document.querySelector('#strategy-form')?.addEventListener('submit', (event) => {
		event.preventDefault();
		const form = event.currentTarget as HTMLFormElement;

		const rawInput = {
			sex: form.sex.value as 'male' | 'female',
			age: Number(form.age.value),
			heightCm: strategyUnit === 'metric' ? Number(form.height.value) : inToCm(Number(form.height.value)),
			weightKg: strategyUnit === 'metric' ? Number(form.weight.value) : lbToKg(Number(form.weight.value)),
			bodyFat: Number(form.bodyFat.value || 0),
			activity: form.activity.value as keyof typeof activityFactors,
			trainingAge: 'intermediate' as const,
			goalBias: form.goalBias.value as any,
			protein: 0,
		};

		const proteinAdequate = false;
		const rec = strategyRecommendation({ ...rawInput, proteinAdequate });
		const bmr = engineMifflin({ sex: rawInput.sex, age: rawInput.age, heightCm: rawInput.heightCm, weightKg: rawInput.weightKg });
		const maintenance = round(bmr * activityFactors[rawInput.activity]);
		const target = calorieTarget(maintenance, rec.recommended);
		const proteinLow = round(rawInput.weightKg * 1.6);
		const proteinHigh = round(rawInput.weightKg * 2.2);

		const saved = { ...rawInput, proteinAdequate, ...rec, maintenance, target, targetBasis: 'recommended', proteinLow, proteinHigh, createdAt: new Date().toISOString() };
		localStorage.setItem('bodycompos.latestAssessment', JSON.stringify(saved));
		localStorage.removeItem('bodycompos.estimatedBodyFat');

		const history = safeJsonParse(localStorage.getItem('bodycompos.assessments'), []);
		history.unshift(saved);
		localStorage.setItem('bodycompos.assessments', JSON.stringify(history.slice(0, 12)));

		// Compute pace text — respects unit toggle for display
		const rDecay = 0.99;
		let paceText = 'Flat Weight';
		let timelineText = 'Ongoing';

		if (rec.recommended === 'fat-loss') {
			const pace = rawInput.weightKg * 0.0075;
			const targetWC = rawInput.weightKg * 0.08;
			const term = (targetWC * (1 - rDecay)) / pace;
			const etaWeeks = term < 0.99 ? Math.log(1 - term) / Math.log(rDecay) : 16;
			const val = strategyUnit === 'metric' ? `${round(pace, 2)} kg` : `${round(kgToLb(pace), 2)} lb`;
			paceText = `Lose ~${val}/week`;
			timelineText = `~${round(etaWeeks, 1)} weeks to reach 8% reduction`;
		} else if (rec.recommended === 'lean-bulk') {
			const pace = rawInput.weightKg * 0.002;
			const targetWC = rawInput.weightKg * 0.04;
			const term = (targetWC * (1 - rDecay)) / pace;
			const etaWeeks = term < 0.99 ? Math.log(1 - term) / Math.log(rDecay) : 24;
			const val = strategyUnit === 'metric' ? `${round(pace, 2)} kg` : `${round(kgToLb(pace), 2)} lb`;
			paceText = `Gain ~${val}/week`;
			timelineText = `~${round(etaWeeks, 1)} weeks to build 4% lean mass`;
		} else if (rec.recommended === 'aggressive-bulk') {
			const pace = rawInput.weightKg * 0.004;
			const targetWC = rawInput.weightKg * 0.06;
			const term = (targetWC * (1 - rDecay)) / pace;
			const etaWeeks = term < 0.99 ? Math.log(1 - term) / Math.log(rDecay) : 16;
			const val = strategyUnit === 'metric' ? `${round(pace, 2)} kg` : `${round(kgToLb(pace), 2)} lb`;
			paceText = `Gain ~${val}/week`;
			timelineText = `~${round(etaWeeks, 1)} weeks to target weight`;
		} else if (rec.recommended === 'recomp') {
			paceText = 'Parity (Flat scale)';
			timelineText = '12 - 16 weeks (recommended phase block)';
		}

		const outputContainer = document.querySelector('#strategy-result');
		if (outputContainer) {
			outputContainer.classList.add('has-result');
			outputContainer.innerHTML = `
				<div class="result-content grid gap-3 text-left animate-fade-in-up">
					<div class="flex items-start justify-between gap-3">
						<div>
							<p class="text-xs font-bold uppercase text-accent tracking-wider">Assessment Result</p>
							<p class="mt-1 text-lg font-black text-foreground">${goalLabels[rec.recommended]}</p>
						</div>
						<span class="badge badge-accent shrink-0 mt-1">${rec.confidence}%</span>
					</div>

					<div class="grid gap-2.5 sm:grid-cols-2">
						<div class="result-card">
							<p class="text-xs font-bold uppercase text-muted-foreground">Alternative</p>
							<p class="mt-1 text-xs font-bold text-foreground">${goalLabels[rec.alternative]} (${rec.alternativeConfidence}%)</p>
						</div>
						<div class="result-card bg-accent/5 border-accent/20">
							<p class="text-xs font-bold uppercase text-accent tracking-wider">Calories</p>
							<p class="mt-1 text-base font-black text-foreground">${target} <span class="text-xs font-normal text-muted-foreground">kcal</span></p>
						</div>
					</div>

					<div class="grid gap-2.5 sm:grid-cols-2">
						<div class="result-card bg-success/5 border-success/20">
							<p class="text-xs font-bold uppercase text-success tracking-wider">Protein</p>
							<p class="mt-1 text-base font-black text-foreground">${proteinLow} - ${proteinHigh} <span class="text-xs font-normal text-muted-foreground">g</span></p>
						</div>
						<div class="result-card">
							<p class="text-xs font-bold uppercase text-muted-foreground">Timeline</p>
							<p class="mt-1 text-xs font-black text-foreground">${timelineText}</p>
						</div>
					</div>

					<div class="flex flex-col sm:flex-row gap-2.5 pt-0.5">
						<a class="button-primary flex-1 text-center text-xs" href="/dashboard">Track Progress</a>
						<a class="button-secondary flex-1 text-center text-xs" href="/assess">Full Assessment</a>
					</div>
				</div>
			`;

			outputContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			(outputContainer as HTMLElement).focus();
		}
	});
</script>
