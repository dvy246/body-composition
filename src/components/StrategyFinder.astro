<section class="site-container pb-8">
	<div class="trust-note">
		<strong>Educational Disclaimer:</strong> BodyCompOS provides calorie, protein, and body composition estimates for general informational purposes only. These are not medical, nutritional, or clinical recommendations. Consult a registered dietitian, physician, or certified sports nutritionist before making significant dietary or exercise changes.
		<a href="/disclaimer" class="ml-1 text-accent underline font-semibold hover:no-underline">Full Disclaimer →</a>
	</div>
</section>

<script>
	import {
		mifflin as engineMifflin,
		katch,
		strategyRecommendation,
		calorieTarget,
		activityFactors,
		goalLabels,
		round,
		paceAndTimeline,
	} from '../lib/engines';
	import { autoFillBodyFat, setStrategyUnit as setUnit, saveAssessment } from '../lib/strategyForm';
	import { rebuildWeightSelect } from '../lib/units';

	let strategyUnit = typeof localStorage !== 'undefined' ? localStorage.getItem('bodycompos.preferredUnit') || 'metric' : 'metric';
	autoFillBodyFat();

	function syncHeightFromFtIn() {
		const heightFtSelect = document.getElementById('sf-height-ft') as HTMLSelectElement | null;
		const heightInSelect = document.getElementById('sf-height-in') as HTMLSelectElement | null;
		const heightInput = document.getElementById('sf-height') as HTMLInputElement | null;
		if (heightFtSelect && heightInSelect && heightInput) {
			const totalInches = parseInt(heightFtSelect.value) * 12 + parseInt(heightInSelect.value);
			heightInput.value = String(totalInches);
			clearError('sf-height');
		}
	}

	function syncFtInFromHeight(inchesValue: number) {
		const heightFtSelect = document.getElementById('sf-height-ft') as HTMLSelectElement | null;
		const heightInSelect = document.getElementById('sf-height-in') as HTMLSelectElement | null;
		if (heightFtSelect && heightInSelect && inchesValue > 0) {
			const ft = Math.floor(inchesValue / 12);
			const inches = Math.round(inchesValue % 12);
			
			if (ft >= 3 && ft <= 8) {
				heightFtSelect.value = String(ft);
			} else if (ft < 3) {
				heightFtSelect.value = '3';
			} else {
				heightFtSelect.value = '8';
			}
			
			if (inches >= 0 && inches < 12) {
				heightInSelect.value = String(inches);
			} else {
				heightInSelect.value = '0';
			}
		}
	}

	// Attach change events to feet/inches selects
	(function() {
		const heightFtSelect = document.getElementById('sf-height-ft');
		const heightInSelect = document.getElementById('sf-height-in');
		if (heightFtSelect) heightFtSelect.addEventListener('change', syncHeightFromFtIn);
		if (heightInSelect) heightInSelect.addEventListener('change', syncHeightFromFtIn);
	})();

	// Initialize imperial values on load if saved preference is imperial
	const metricContainer = document.getElementById('sf-height-metric-container');
	const imperialContainer = document.getElementById('sf-height-imperial-container');
	if (strategyUnit === 'imperial') {
		if (metricContainer) metricContainer.classList.add('hidden');
		if (imperialContainer) imperialContainer.classList.remove('hidden');
		const form = document.querySelector('#strategy-form') as HTMLFormElement | null;
		const weightSelect = document.getElementById('sf-weight') as HTMLSelectElement | null;
		if (form && weightSelect) {
			form.height.min = '47';
			form.height.max = '91';
			form.height.placeholder = 'e.g. 70';
			form.height.value = '69';
			syncFtInFromHeight(69);
			document.querySelectorAll('[data-strategy-unit]').forEach(b => b.setAttribute('aria-pressed', String(b.getAttribute('data-strategy-unit') === strategyUnit)));
			document.querySelectorAll('[data-strategy-height-unit]').forEach(l => l.textContent = '(in)');
			document.querySelectorAll('[data-strategy-weight-unit]').forEach(l => l.textContent = '(lb)');
			rebuildWeightSelect(weightSelect, 'imperial', 180);
		}
	} else {
		if (metricContainer) metricContainer.classList.remove('hidden');
		if (imperialContainer) imperialContainer.classList.add('hidden');
	}

	// Visual Body Fat Estimator Interactivity
	const toggleBfBtn = document.getElementById('sf-toggle-visual-estimator');
	const bfDrawer = document.getElementById('sf-visual-estimator-drawer');
	const sexSelect = document.getElementById('sf-sex') as HTMLSelectElement | null;
	const maleGrid = document.getElementById('sf-visual-male');
	const femaleGrid = document.getElementById('sf-visual-female');
	const bfInput = document.getElementById('sf-bodyFat') as HTMLInputElement | null;

	function updateVisualGridSex() {
		const isFemale = sexSelect?.value === 'female';
		if (isFemale) {
			maleGrid?.classList.add('hidden');
			femaleGrid?.classList.remove('hidden');
		} else {
			maleGrid?.classList.remove('hidden');
			femaleGrid?.classList.add('hidden');
		}
	}

	toggleBfBtn?.addEventListener('click', () => {
		bfDrawer?.classList.toggle('hidden');
		updateVisualGridSex();
	});

	sexSelect?.addEventListener('change', updateVisualGridSex);

	document.querySelectorAll('.sf-bf-card').forEach(card => {
		card.addEventListener('click', () => {
			const bfVal = card.getAttribute('data-bf');
			if (bfInput && bfVal) {
				bfInput.value = bfVal;
				// Highlight selected card
				document.querySelectorAll('.sf-bf-card').forEach(c => c.classList.remove('border-accent', 'ring-1', 'ring-accent'));
				card.classList.add('border-accent', 'ring-1', 'ring-accent');
				// Hide drawer
				bfDrawer?.classList.add('hidden');
			}
		});
	});

	// Unit toggle
	document.querySelectorAll('[data-strategy-unit]').forEach((button) => {
		button.addEventListener('click', () => {
			const form = document.querySelector('#strategy-form') as HTMLFormElement;
			const targetUnit = button.getAttribute('data-strategy-unit') ?? 'metric';
			const sfWeightSelect = document.getElementById('sf-weight') as HTMLSelectElement | null;
			const currentWeightVal = sfWeightSelect ? Number(sfWeightSelect.value) : 0;

			strategyUnit = setUnit(targetUnit, strategyUnit, form);
			if (typeof localStorage !== 'undefined') {
				localStorage.setItem('bodycompos.preferredUnit', strategyUnit);
			}

			// Rebuild the weight select dropdown dynamically
			rebuildWeightSelect(sfWeightSelect, targetUnit as 'metric' | 'imperial', currentWeightVal);

			// Update height display containers
			const metricContainer = document.getElementById('sf-height-metric-container');
			const imperialContainer = document.getElementById('sf-height-imperial-container');
			const heightInput = document.getElementById('sf-height') as HTMLInputElement | null;
			if (strategyUnit === 'imperial') {
				if (metricContainer) metricContainer.classList.add('hidden');
				if (imperialContainer) imperialContainer.classList.remove('hidden');
				if (heightInput) {
					const inches = parseFloat(heightInput.value) || 69;
					syncFtInFromHeight(inches);
					heightInput.value = String(inches);
				}
			} else {
				if (metricContainer) metricContainer.classList.remove('hidden');
				if (imperialContainer) imperialContainer.classList.add('hidden');
			}

			document.querySelectorAll('[data-strategy-unit]').forEach(b => {
				b.setAttribute('aria-pressed', String(b.getAttribute('data-strategy-unit') === strategyUnit));
			});
		});
	});

	function lbToKg(lb: number) { return lb / 2.2046226218; }
	function inToCm(val: number) { return val * 2.54; }

	// Custom Inline Validation Checks
	function showError(inputId: string, errorMsg: string) {
		const input = document.getElementById(inputId) as HTMLInputElement | HTMLSelectElement;
		if (!input) return;
		input.classList.add('border-destructive');
		const parent = input.closest('.field');
		parent?.querySelector('.error-msg')?.remove();
		const span = document.createElement('p');
		span.className = 'error-msg text-xs text-destructive mt-1.5 font-medium';
		span.textContent = errorMsg;
		parent?.appendChild(span);
	}

	function clearError(inputId: string) {
		const input = document.getElementById(inputId) as HTMLInputElement | HTMLSelectElement;
		if (!input) return;
		input.classList.remove('border-destructive');
		input.closest('.field')?.querySelector('.error-msg')?.remove();
	}

	// Setup listeners to clear error on input change/type
	const validationFields = ['sf-age', 'sf-height', 'sf-weight', 'sf-bodyFat'];
	validationFields.forEach(fieldId => {
		const el = document.getElementById(fieldId);
		el?.addEventListener('input', () => clearError(fieldId));
		el?.addEventListener('change', () => clearError(fieldId));
	});

	function validateForm(): boolean {
		let isValid = true;
		const ageInput = document.getElementById('sf-age') as HTMLInputElement;
		const age = Number(ageInput.value);
		if (!ageInput.value || age < 15 || age > 90) {
			showError('sf-age', 'Please enter a valid age between 15 and 90.');
			isValid = false;
		} else {
			clearError('sf-age');
		}

		const heightInput = document.getElementById('sf-height') as HTMLInputElement;
		const height = Number(heightInput.value);
		const hMin = strategyUnit === 'metric' ? 120 : 47;
		const hMax = strategyUnit === 'metric' ? 230 : 91;
		if (!heightInput.value || height < hMin || height > hMax) {
			showError('sf-height', `Height must be between ${hMin} and ${hMax} ${strategyUnit === 'metric' ? 'cm' : 'inches'}.`);
			isValid = false;
		} else {
			clearError('sf-height');
		}

		const weightInput = document.getElementById('sf-weight') as HTMLInputElement;
		const weight = Number(weightInput.value);
		const wMin = strategyUnit === 'metric' ? 20 : 44;
		const wMax = strategyUnit === 'metric' ? 250 : 551;
		if (!weightInput.value || weight < wMin || weight > wMax) {
			showError('sf-weight', `Weight must be between ${wMin} and ${wMax} ${strategyUnit === 'metric' ? 'kg' : 'lbs'}.`);
			isValid = false;
		} else {
			clearError('sf-weight');
		}

		const bfInput = document.getElementById('sf-bodyFat') as HTMLInputElement;
		const bf = Number(bfInput.value);
		if (!bfInput.value || bf < 3 || bf > 60) {
			showError('sf-bodyFat', 'Please enter a valid body fat percentage between 3% and 60%.');
			isValid = false;
		} else {
			clearError('sf-bodyFat');
		}

		return isValid;
	}

	// Trigger unit toggler to clear errors
	document.querySelectorAll('[data-strategy-unit]').forEach((button) => {
		button.addEventListener('click', () => {
			validationFields.forEach(clearError);
		});
	});

	function animateCounter(element: HTMLElement, start: number, end: number, duration: number = 800) {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			element.textContent = String(end);
			return;
		}
		
		let startTime: number | null = null;
		
		function step(timestamp: number) {
			if (!startTime) startTime = timestamp;
			const progress = Math.min((timestamp - startTime) / duration, 1);
			const easeProgress = progress * (2 - progress); // outQuad
			const current = Math.floor(start + easeProgress * (end - start));
			element.textContent = String(current);
			if (progress < 1) {
				window.requestAnimationFrame(step);
			} else {
				element.textContent = String(end);
			}
		}
		
		window.requestAnimationFrame(step);
	}

	document.querySelector('#strategy-form')?.addEventListener('submit', (event) => {
		event.preventDefault();
		if (!validateForm()) {
			return;
		}
		const form = event.currentTarget as HTMLFormElement;
		const btn = document.querySelector('#sf-submit') as HTMLButtonElement;
		if (btn) { btn.disabled = true; btn.textContent = 'Calculating…'; }

		const rawInput = {
			sex: (form.querySelector('#sf-sex') as HTMLSelectElement).value as 'male' | 'female',
			age: Number((form.querySelector('#sf-age') as HTMLInputElement).value),
			heightCm: strategyUnit === 'metric'
				? Number((form.querySelector('#sf-height') as HTMLInputElement).value)
				: inToCm(Number((form.querySelector('#sf-height') as HTMLInputElement).value)),
			weightKg: strategyUnit === 'metric'
				? Number((form.querySelector('#sf-weight') as HTMLInputElement).value)
				: lbToKg(Number((form.querySelector('#sf-weight') as HTMLInputElement).value)),
			bodyFat: Number((form.querySelector('#sf-bodyFat') as HTMLInputElement).value || 0),
			activity: (form.querySelector('#sf-activity') as HTMLSelectElement).value as keyof typeof activityFactors,
			trainingAge: 'intermediate' as const,
			goalBias: (form.querySelector('#sf-goalBias') as HTMLSelectElement).value as any,
			protein: 0,
		};

		const proteinAdequate = false;
		const rec = strategyRecommendation({ ...rawInput, proteinAdequate });
		const hasBf = rawInput.bodyFat && rawInput.bodyFat > 0;
		const bmr = hasBf
			? katch(rawInput.weightKg, rawInput.bodyFat)
			: engineMifflin({ sex: rawInput.sex, age: rawInput.age, heightCm: rawInput.heightCm, weightKg: rawInput.weightKg });
		const maintenance = round(bmr * activityFactors[rawInput.activity]);
		const target = calorieTarget(maintenance, rec.recommended);
		const proteinLow = round(rawInput.weightKg * 1.6);
		const proteinHigh = round(rawInput.weightKg * 2.2);

		const saved = { ...rawInput, proteinAdequate, ...rec, maintenance, target, proteinLow, proteinHigh, createdAt: new Date().toISOString() };
		saveAssessment(saved);

		const { paceText, timelineText } = paceAndTimeline(rec.recommended, rawInput.weightKg, strategyUnit as 'metric' | 'imperial');

		const outputContainer = document.querySelector('#strategy-result');
		const placeholder = document.getElementById('sf-res-placeholder');
		const content = document.getElementById('sf-res-content');

		if (outputContainer && placeholder && content) {
			outputContainer.classList.add('has-result');
			placeholder.classList.add('hidden');
			content.classList.remove('hidden');

			// Recommended Strategy & Confidence
			const recEl = document.getElementById('sf-res-recommended');
			if (recEl) recEl.textContent = goalLabels[rec.recommended];

			const reasonsEl = document.getElementById('sf-res-reasons');
			if (reasonsEl) {
				reasonsEl.textContent = `${rec.reasons[0]} · ${rec.reasons[1]}`;
			}

			// Alternative Option
			const altEl = document.getElementById('sf-res-alternative');
			if (altEl) {
				altEl.textContent = `${goalLabels[rec.alternative]} · ${rec.alternativeConfidence}% match`;
			}

			// Pace & Timeline
			const paceEl = document.getElementById('sf-res-pace');
			if (paceEl) paceEl.textContent = paceText;

			const timelineEl = document.getElementById('sf-res-timeline');
			if (timelineEl) timelineEl.textContent = timelineText;

			// Animate Counters
			const caloriesEl = document.getElementById('sf-res-calories');
			if (caloriesEl) animateCounter(caloriesEl, 0, target, 800);

			const pLowEl = document.getElementById('sf-res-protein-low');
			if (pLowEl) animateCounter(pLowEl, 0, proteinLow, 800);

			const pHighEl = document.getElementById('sf-res-protein-high');
			if (pHighEl) animateCounter(pHighEl, 0, proteinHigh, 800);

			const confEl = document.getElementById('sf-res-confidence');
			if (confEl) animateCounter(confEl, 0, rec.confidence, 800);

			// Programmatic progress bars
			const caloriesBar = document.getElementById('sf-res-calories-bar');
			if (caloriesBar) {
				const pct = Math.min(100, Math.round((target / maintenance) * 100));
				setTimeout(() => {
					caloriesBar.style.width = `${pct}%`;
				}, 50);
			}

			const proteinBar = document.getElementById('sf-res-protein-bar');
			if (proteinBar) {
				const avgProtein = (proteinLow + proteinHigh) / 2;
				const pct = Math.min(100, Math.round((avgProtein / 220) * 100));
				setTimeout(() => {
					proteinBar.style.width = `${pct}%`;
				}, 50);
			}

			outputContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			(outputContainer as HTMLElement).focus();
		}

		if (btn) { btn.disabled = false; btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg> Get My Strategy'; }
	});
</script>
