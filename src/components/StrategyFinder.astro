---
const steps = [
	['1', 'Assess', 'Your stats & body composition'],
	['2', 'Analyze', 'Algorithm weighs all inputs'],
	['3', 'Recommend', 'Personalized phase direction'],
	['4', 'Track', 'Weekly check-ins & forecast'],
	['5', 'Improve', 'Reassess & adjust targets'],
];
---

<!-- ╔══ HERO SECTION ═══════════════════════════════════════════════╗ -->
<section class="site-container pt-10 pb-6 lg:pt-14">
	<div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-12 lg:items-start">

<!-- Left: Copy + CTA -->
		<div class="flex flex-col justify-center max-w-2xl animate-fade-in-up">
			<div class="inline-flex mb-5">
				<span class="badge badge-accent">
					<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
					Evidence-Based Strategy Engine
				</span>
			</div>

			<h1 class="text-4xl font-black leading-[1.07] tracking-tight text-foreground sm:text-5xl lg:text-6xl">
				Stop Guessing.<br/>
				<span style="background: linear-gradient(135deg, var(--accent), var(--success)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Start with a Strategy.</span>
			</h1>

			<p class="mt-6 text-base sm:text-lg leading-relaxed text-muted-foreground max-w-lg">
				BodyCompOS maps your body fat, training age, and goals to a science-backed phase recommendation — with calorie targets, protein ranges, and a real timeline. 100% private, no account needed.
			</p>

			<!-- Social Proof Strip -->
			<div class="mt-8 pt-6 border-t border-border flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-muted-foreground select-none">
				<span class="flex items-center gap-1.5 hover:text-foreground transition-colors">
					<svg class="text-accent shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
					Evidence-based
				</span>
				<span class="flex items-center gap-1.5 hover:text-foreground transition-colors">
					<svg class="text-accent shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="12" y2="16"/></svg>
					19 calculators
				</span>
				<span class="flex items-center gap-1.5 hover:text-foreground transition-colors">
					<svg class="text-accent shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
					Cited research
				</span>
				<span class="flex items-center gap-1.5 hover:text-foreground transition-colors">
					<svg class="text-accent shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
					No account required
				</span>
			</div>

			<!-- Body Fat Estimation Tagline Banner -->
			<div class="mt-6 p-4 rounded-xl border border-dashed border-accent/40 bg-accent/[0.02] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
				<div class="space-y-1">
					<h4 class="text-xs font-black uppercase text-accent tracking-wider font-sans">Body Fat Percentage Tool</h4>
					<p class="text-xs text-muted-foreground leading-relaxed">
						Don't know your fat percentage? Estimate it in easy steps using the most accurate US Navy circumference method and automatically send it to your strategy calculations.
					</p>
				</div>
				<a href="/calculators/body-fat-calculator" class="button-secondary text-center text-xs shrink-0 whitespace-nowrap px-3 py-2">Estimate Fat % ➔</a>
			</div>

			<!-- Workflow Diagram -->
			<div class="mt-8 p-4 rounded-xl border border-border bg-card shadow-sm hover:shadow-soft transition-all duration-300 overflow-hidden">
				<svg class="w-full h-auto" viewBox="0 0 540 120" fill="none" xmlns="http://www.w3.org/2000/svg">
					<defs>
						<linearGradient id="input-grad" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="var(--accent)" stop-opacity="0.12"/>
							<stop offset="100%" stop-color="var(--card)" stop-opacity="0.6"/>
						</linearGradient>
						<linearGradient id="engine-grad" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="var(--warning)" stop-opacity="0.12"/>
							<stop offset="100%" stop-color="var(--card)" stop-opacity="0.6"/>
						</linearGradient>
						<linearGradient id="output-grad" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="var(--success)" stop-opacity="0.12"/>
							<stop offset="100%" stop-color="var(--card)" stop-opacity="0.6"/>
						</linearGradient>
						<marker id="arrow-accent" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
							<path d="M 0 1.5 L 8 5 L 0 8.5 z" fill="var(--accent)"/>
						</marker>
						<marker id="arrow-success" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
							<path d="M 0 1.5 L 8 5 L 0 8.5 z" fill="var(--success)"/>
						</marker>
					</defs>
					<style>
						@keyframes flow {
							to {
								stroke-dashoffset: -20;
							}
						}
						.flow-line {
							stroke: var(--accent);
							stroke-dasharray: 6, 4;
							animation: flow 2s linear infinite;
						}
						.flow-line-success {
							stroke: var(--success);
							stroke-dasharray: 6, 4;
							animation: flow 2s linear infinite;
						}
						@media (prefers-reduced-motion: reduce) {
							.flow-line, .flow-line-success {
								animation: none;
								stroke-dasharray: none;
							}
						}
					</style>
					<rect x="5" y="10" width="145" height="100" rx="12" fill="url(#input-grad)" stroke="var(--border)" stroke-width="1.5"/>
					<text x="20" y="32" fill="var(--foreground)" font-family="var(--font-sans)" font-size="12" font-weight="bold">1. Input Stats</text>
					<text x="20" y="55" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Sex, Age, H/W</text>
					<text x="20" y="73" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Activity Level</text>
					<text x="20" y="91" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Body Fat %</text>
					<path d="M 150 60 L 200 60" stroke="var(--border)" stroke-width="1.5" marker-end="url(#arrow-accent)"/>
					<path d="M 150 60 L 200 60" stroke-width="1.5" class="flow-line"/>
					<rect x="205" y="10" width="145" height="100" rx="12" fill="url(#engine-grad)" stroke="var(--border)" stroke-width="1.5"/>
					<text x="220" y="32" fill="var(--foreground)" font-family="var(--font-sans)" font-size="12" font-weight="bold">2. Strategy Engine</text>
					<text x="220" y="55" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Mifflin-St Jeor</text>
					<text x="220" y="73" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Navy BF Method</text>
					<text x="220" y="91" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Strategy Matrix</text>
					<path d="M 350 60 L 380 60" stroke="var(--border)" stroke-width="1.5" marker-end="url(#arrow-success)"/>
					<path d="M 350 60 L 380 60" stroke-width="1.5" class="flow-line-success"/>
					<rect x="385" y="10" width="150" height="100" rx="12" fill="url(#output-grad)" stroke="var(--border)" stroke-width="1.5"/>
					<text x="400" y="32" fill="var(--foreground)" font-family="var(--font-sans)" font-size="12" font-weight="bold">3. Target Plan</text>
					<text x="400" y="55" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Recommended Phase</text>
					<text x="400" y="73" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Calories &amp; Protein</text>
					<text x="400" y="91" fill="var(--muted-foreground)" font-family="var(--font-sans)" font-size="10">• Timeline &amp; Pace</text>
				</svg>
			</div>

			<div class="mt-8 flex flex-wrap items-center gap-3">
				<a class="button-primary" href="/assess">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
					Start Free Assessment
				</a>
				<a class="button-ghost text-sm" href="/body-composition-strategy-guide">
					How It Works
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
				</a>
			</div>
		</div>

		<!-- Right: Interactive Strategy Finder widget -->
		<div class="flex flex-col gap-4 animate-fade-in" style="animation-delay: 100ms;">
			<div class="surface rounded-2xl overflow-hidden">
				<div class="px-5 pt-5 pb-4 border-b border-border flex items-center justify-between gap-3">
					<div>
						<p class="eyebrow">Interactive Engine</p>
						<h2 class="text-base font-black text-foreground mt-0.5">Strategy Finder</h2>
					</div>
					<div class="segmented" role="group" aria-label="Measurement units">
						<button type="button" data-strategy-unit="metric" aria-pressed="true">Metric</button>
						<button type="button" data-strategy-unit="imperial" aria-pressed="false">Imperial</button>
					</div>
				</div>

				<form id="strategy-form" class="p-5 grid gap-3 sm:grid-cols-2">
					<div class="sm:col-span-2">
						<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-2">Personal Stats</p>
					</div>
					<div class="field">
						<label for="sf-sex">Biological Sex</label>
						<div class="select-wrap">
							<select id="sf-sex" name="sex" required>
								<option value="male">Male</option>
								<option value="female">Female</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="sf-age">Age (years)</label>
						<div class="select-wrap">
							<select id="sf-age" name="age" required>
								<option value="">Select Age</option>
								{Array.from({ length: 76 }, (_, i) => i + 15).map(age => (
									<option value={age} selected={age === 28}>{age}</option>
								))}
							</select>
						</div>
					</div>
					<div class="field">
						<label for="sf-height">Height <span data-strategy-height-unit>(cm)</span></label>
						<div id="sf-height-metric-container">
							<input id="sf-height" name="height" type="number" min="120" max="230" step="0.1" placeholder="e.g. 175" required />
						</div>
						<div id="sf-height-imperial-container" class="hidden flex gap-2">
							<div class="flex-1 select-wrap">
								<select id="sf-height-ft" class="w-full">
									<option value="3">3 ft</option>
									<option value="4">4 ft</option>
									<option value="5" selected>5 ft</option>
									<option value="6">6 ft</option>
									<option value="7">7 ft</option>
									<option value="8">8 ft</option>
								</select>
							</div>
							<div class="flex-1 select-wrap">
								<select id="sf-height-in" class="w-full">
									{Array.from({ length: 12 }, (_, i) => (
										<option value={i} selected={i === 9}>{i} in</option>
									))}
								</select>
							</div>
						</div>
					</div>
					<div class="field">
						<label for="sf-weight">Weight <span data-strategy-weight-unit>(kg)</span></label>
						<div class="select-wrap">
							<select id="sf-weight" name="weight" required>
								<option value="0">Select Weight</option>
								{Array.from({ length: 231 }, (_, i) => i + 20).map(w => (
									<option value={w} selected={w === 82}>{w}</option>
								))}
							</select>
						</div>
					</div>

					<div class="sm:col-span-2 mt-1">
						<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-2">Body Composition & Goals</p>
					</div>
					<div class="field sm:col-span-2">
						<label for="sf-bodyFat">Estimated Body Fat %</label>
						<div class="flex gap-2">
							<input id="sf-bodyFat" name="bodyFat" type="number" min="3" max="60" step="0.1" placeholder="e.g. 22" required class="flex-1" />
							<button type="button" id="sf-toggle-visual-estimator" class="button-secondary text-xs px-3 py-2 flex items-center gap-1.5 shrink-0">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
								Estimate Visually
							</button>
						</div>
						<p class="text-[11px] text-muted-foreground mt-1">
							Not sure? Find it with this most accurate method across everywhere: <a href="/calculators/body-fat-calculator" class="text-accent font-semibold underline hover:no-underline">Estimate via Navy Method</a>.
						</p>

						<!-- Visual Body Fat Gallery Drawer -->
						<div id="sf-visual-estimator-drawer" class="hidden mt-4 border border-border/80 bg-muted/20 p-4 rounded-xl space-y-3 transition-all duration-300">
							<p class="text-xs font-bold text-foreground">Select your closest matching physique silhouette:</p>
							
							<!-- Male Silhouette Cards -->
							<div id="sf-visual-male" class="grid gap-2.5 grid-cols-2 sm:grid-cols-5">
								{[
									[10, 'Lean / Ripped', 'Visible abs, vascularity, high definition.'],
									[15, 'Fit / Athletic', 'Flat stomach, outline of abs, fit shape.'],
									[20, 'Average', 'Soft midsection, no visible abs, normal shape.'],
									[25, 'Soft / Excess', 'Waist outline soft, minimal definition.'],
									[30, 'High Fat', 'Full waistline, high adiposity.']
								].map(([bf, label, desc]) => (
									<button type="button" class="sf-bf-card p-2.5 rounded-lg border border-border bg-card text-left hover:border-accent transition-all flex flex-col justify-between" data-bf={bf}>
										<div>
											<span class="text-xs font-black text-accent">{bf}%</span>
											<p class="font-bold text-[11px] text-foreground mt-0.5 leading-snug">{label}</p>
											<p class="text-[9px] text-muted-foreground mt-1 leading-relaxed">{desc}</p>
										</div>
									</button>
								))}
							</div>

							<!-- Female Silhouette Cards -->
							<div id="sf-visual-female" class="grid gap-2.5 grid-cols-2 sm:grid-cols-5 hidden">
								{[
									[18, 'Lean / Ripped', 'Athletic shape, visible definition.'],
									[22, 'Fit / Athletic', 'Flat stomach, curves defined.'],
									[26, 'Average', 'Normal curves, soft hips, no abs.'],
									[30, 'Soft / Excess', 'Full waist and hips, rounder outline.'],
									[35, 'High Fat', 'Soft contours, high adiposity.']
								].map(([bf, label, desc]) => (
									<button type="button" class="sf-bf-card p-2.5 rounded-lg border border-border bg-card text-left hover:border-accent transition-all flex flex-col justify-between" data-bf={bf}>
										<div>
											<span class="text-xs font-black text-accent">{bf}%</span>
											<p class="font-bold text-[11px] text-foreground mt-0.5 leading-snug">{label}</p>
											<p class="text-[9px] text-muted-foreground mt-1 leading-relaxed">{desc}</p>
										</div>
									</button>
								))}
							</div>
						</div>
					</div>
					<div class="field">
						<label for="sf-activity">Activity Level</label>
						<div class="select-wrap">
							<select id="sf-activity" name="activity" required>
								<option value="sedentary">Sedentary (desk job)</option>
								<option value="light">Lightly Active (1-3x/week)</option>
								<option value="moderate" selected>Moderately Active (3-5x/week)</option>
								<option value="active">Highly Active (6-7x/week)</option>
								<option value="athlete">Competitive Athlete</option>
							</select>
						</div>
					</div>
					<div class="field">
						<label for="sf-goalBias">Goal Direction</label>
						<div class="select-wrap">
							<select id="sf-goalBias" name="goalBias" required>
								<option value="fat-loss">Fat Loss / Cut</option>
								<option value="recomp" selected>Body Recomposition</option>
								<option value="lean-bulk">Lean Muscle Bulk</option>
								<option value="aggressive-bulk">Aggressive Mass Gain</option>
								<option value="maintain">Weight Maintenance</option>
							</select>
						</div>
					</div>

					<button class="button-primary sm:col-span-2 mt-1" type="submit" id="sf-submit">
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
						Get My Strategy
					</button>
				</form>

				<!-- Result area -->
				<div id="strategy-result" class="result-container mx-5 mb-5" aria-live="polite" tabindex="-1">
					<!-- Placeholder (shown initially) -->
					<div id="sf-res-placeholder" class="result-placeholder">
						<svg class="text-muted-foreground" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
						<p class="mt-2 text-sm font-semibold text-foreground">Your strategy appears here</p>
						<p class="mt-1 text-xs text-muted-foreground">Fill in your stats above to get a free, personalized recommendation.</p>
					</div>

					<!-- Result Content (hidden initially) -->
					<div id="sf-res-content" class="result-content grid gap-4 text-left hidden animate-fade-in-up">
						<div class="flex items-start justify-between gap-3">
							<div>
								<p class="text-xs font-bold uppercase text-accent tracking-wider">Strategy Result</p>
								<p id="sf-res-recommended" class="mt-1 text-xl font-black text-foreground"></p>
								<p id="sf-res-reasons" class="mt-1 text-xs text-muted-foreground"></p>
							</div>
							<span class="badge badge-accent shrink-0 mt-1 text-sm select-none">
								<span id="sf-res-confidence">0</span>%
								<br/>
								<span class="font-normal text-[10px]">confidence</span>
							</span>
						</div>

						<!-- Metric grid -->
						<div class="grid grid-cols-2 gap-2">
							<div class="result-card bg-accent/5 border-accent/20 flex flex-col justify-between">
								<div>
									<p class="text-xs font-bold uppercase tracking-wider text-accent">Calorie Target</p>
									<p class="mt-1 text-base font-black text-foreground leading-tight"><span id="sf-res-calories">0</span> kcal</p>
								</div>
								<div class="mt-2">
									<div class="mini-bar"><span id="sf-res-calories-bar" style="width: 0%"></span></div>
								</div>
							</div>
							<div class="result-card bg-success/5 border-success/20 flex flex-col justify-between">
								<div>
									<p class="text-xs font-bold uppercase tracking-wider text-success">Protein Range</p>
									<p class="mt-1 text-base font-black text-foreground leading-tight"><span id="sf-res-protein-low">0</span>–<span id="sf-res-protein-high">0</span>g</p>
								</div>
								<div class="mt-2">
									<div class="mini-bar"><span id="sf-res-protein-bar" style="width: 0%"></span></div>
								</div>
							</div>
							<div class="result-card">
								<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground font-sans">Pace</p>
								<p id="sf-res-pace" class="mt-1 text-xs font-black text-foreground leading-tight"></p>
							</div>
							<div class="result-card">
								<p class="text-xs font-bold uppercase tracking-wider text-muted-foreground font-sans">Timeline</p>
								<p id="sf-res-timeline" class="mt-1 text-xs font-black text-foreground leading-tight"></p>
							</div>
						</div>

						<!-- Alternative -->
						<div class="result-card">
							<p class="text-xs font-bold text-muted-foreground uppercase tracking-wider font-sans">Alternative Option</p>
							<p id="sf-res-alternative" class="mt-1 text-xs font-semibold text-foreground"></p>
						</div>

						<!-- CTAs -->
						<div class="flex flex-col min-[350px]:flex-row gap-2">
							<a class="button-primary flex-1 text-center text-xs" href="/assess">Full Assessment</a>
							<a class="button-secondary flex-1 text-center text-xs" href="/dashboard">Track Progress</a>
						</div>

						<p class="text-[10px] text-muted-foreground leading-relaxed">
							Educational estimates — not medical advice. Consult a healthcare professional before altering your diet or exercise.
						</p>
					</div>
				</div>
			</div>

			<p class="text-center text-xs text-muted-foreground">
				Need more detail?
				<a href="/assess" class="underline hover:text-accent font-semibold transition-colors">Use the Full Assessment →</a>
			</p>
		</div>
	</div>
</section>

<!-- ╔══ OPERATING LOOP ═══════════════════════════════════════════╗ -->
<section class="site-container py-10 lg:py-14 border-t border-border mt-4">
	<div class="max-w-3xl mx-auto text-center mb-10">
		<p class="eyebrow">The BodyCompOS Loop</p>
		<h2 class="mt-3 text-3xl font-black text-foreground sm:text-4xl">A System, Not Just a Calculator</h2>
		<p class="mt-4 text-base text-muted-foreground leading-relaxed">
			Most fitness tools give you a number and stop. BodyCompOS connects assessment, targeting, tracking, and intelligent reassessment into one coherent strategy loop.
		</p>
	</div>

	<!-- Visual step flow -->
	<div class="relative">
		<!-- Connector line (desktop) -->
		<div class="hidden lg:block absolute top-8 left-[10%] right-[10%] h-px bg-border" aria-hidden="true"></div>
		<div class="grid gap-6 grid-cols-1 sm:grid-cols-5 stagger-children">
			{steps.map(([num, label, desc]) => (
				<div class="animate-fade-in-up flex flex-col items-center text-center gap-3">
					<div class="relative z-10 flex items-center justify-center w-16 h-16 rounded-2xl border border-border bg-card shadow-sm text-2xl font-black text-accent" style="box-shadow: 0 0 0 6px var(--muted);">
						{num}
					</div>
					<div>
						<p class="font-bold text-foreground text-sm">{label}</p>
						<p class="text-xs text-muted-foreground mt-1 leading-relaxed">{desc}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

