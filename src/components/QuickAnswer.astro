---
interface Props {
	title?: string;
	answer: string;
}

const { title = "Quick Answer", answer } = Astro.props;
---

<div class="my-6 border-l-4 border-accent bg-accent/5 p-5 rounded-r-xl border-y border-r border-border/60 shadow-sm">
	<div class="flex items-center gap-2 mb-2">
		<svg class="text-accent shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<circle cx="12" cy="12" r="10"/>
			<line x1="12" y1="16" x2="12" y2="12"/>
			<line x1="12" y1="8" x2="12.01" y2="8"/>
		</svg>
		<h4 class="text-xs font-black uppercase tracking-wider text-accent font-sans">{title}</h4>
	</div>
	<p class="text-sm font-medium text-foreground leading-relaxed font-sans">{answer}</p>
</div>
