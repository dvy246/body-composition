							</tr>
						`).join('')}
					</tbody>
				</table>
			` : '<p class="text-xs text-muted-foreground p-4">No check-in logs registered. Use the Log Weekly Check-In form to add entries.</p>';

			document.querySelectorAll('.delete-checkin-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const idx = Number(btn.getAttribute('data-idx'));
					const updated = getCheckins().filter((_, i) => i !== idx);
					setCheckins(updated);
					if (editingCheckinIdx === idx) editingCheckinIdx = -1;
					render();
				});
			});

			document.querySelectorAll('.edit-checkin-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const idx = Number(btn.getAttribute('data-idx'));
					const all = getCheckins();
					const entry = all[idx];
					if (!entry) return;
					editingCheckinIdx = idx;
					const form = document.querySelector('#checkin-form') as HTMLFormElement;
					if (!form) return;
					form.date.value = entry.date;
					form.weight.value = dashboardUnit === 'metric' ? entry.weight : round(kgToLb(entry.weight), 1);
					form.bodyFat.value = entry.bodyFat || '';
					form.adherence.value = entry.adherence || 80;
					const submitBtn = form.querySelector('button[type="submit"]');
					if (submitBtn) submitBtn.textContent = 'Update Check-In';
					const tabBtns = document.querySelectorAll('.tab-btn');
					tabBtns.forEach(b => b.classList.remove('active'));
					document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
					document.querySelector('[data-tab="logs"]')?.classList.add('active');
					document.getElementById('tab-logs')?.classList.remove('hidden');
					form.scrollIntoView({ behavior: 'smooth', block: 'center' });
				});
			});
		}

		// Render Adherence Heatmap Grid (Tab 2)
		const heatmapGrid = document.querySelector('#adherence-heatmap-grid');
		if (heatmapGrid) {
			if (checkins.length === 0) {
				heatmapGrid.innerHTML = '<p class="text-xs text-muted-foreground">Add check-ins to view the adherence heatmap.</p>';
			} else {
				// Let's generate 52 blocks (representing a full year progression)
				// Color them based on matching logs or default to gray
				let html = '';
				const checkinMap = new Map(checkins.map(c => [c.date, c.adherence]));
				
				// Get last 12 weeks of dates
				const now = new Date();
				const weeksToShow = 24;
				
				for (let w = weeksToShow - 1; w >= 0; w--) {
					const d = new Date();
					d.setDate(now.getDate() - (w * 7));
					const dateStr = d.toISOString().split('T')[0];
					
					// Find nearest logged checkin within +/- 3 days
					let matchedAdherence: number | null = null;
					let matchedDate = '';
					for (let i = 0; i < checkins.length; i++) {
						const cDate = new Date(checkins[i].date);
						const diffDays = Math.abs(cDate.getTime() - d.getTime()) / (1000 * 60 * 60 * 24);
						if (diffDays <= 3.5) {
							matchedAdherence = checkins[i].adherence;
							matchedDate = checkins[i].date;
							break;
						}
					}
					
					let colorClass = 'bg-muted';
					let tooltip = `Week of ${dateStr}: No Entry`;
					if (matchedAdherence !== null) {
						if (matchedAdherence >= 80) {
							colorClass = 'bg-success/20 border border-success/40 text-success';
						} else if (matchedAdherence >= 50) {
							colorClass = 'bg-warning/20 border border-warning/40 text-warning';
						} else {
							colorClass = 'bg-destructive/20 border border-destructive/40 text-destructive';
						}
						tooltip = `Log Date: ${matchedDate} | Adherence: ${matchedAdherence}%`;
					}
					
					html += `
						<div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold cursor-help ${colorClass}" title="${tooltip}">
							W${weeksToShow - w}
						</div>
					`;
				}
				heatmapGrid.innerHTML = html;
			}
		}

		// 8. Forecasting Panel Projections
		const fc = forecastProgress(checkins, goal);
		const predictionSummary = document.querySelector('#forecast-prediction-summary');
		if (predictionSummary) {
			predictionSummary.innerHTML = `
				<div class="metric-cell">
					<p class="text-xs font-bold uppercase text-muted-foreground tracking-wider">Velocity Pacing</p>
					<p class="mt-2 text-lg font-black text-foreground capitalize">${fc.pacePerWeek === 0 ? 'Need data' : `${fc.pacePerWeek > 0 ? '+' : ''}${formatWeight(fc.pacePerWeek, 2)}/week`}</p>
					<span class="text-xs text-muted-foreground mt-4 inline-block">Estimated rate of change</span>
				</div>
				<div class="metric-cell">
					<p class="text-xs font-bold uppercase text-muted-foreground tracking-wider">Completion ETA</p>
					<p class="mt-2 text-lg font-black text-foreground capitalize">${fc.etaWeeks ? `${fc.etaWeeks} weeks` : 'Needs Trend Direction'}</p>
					<span class="text-xs text-muted-foreground mt-4 inline-block">${fc.predictedCompletionDate ? `Est. Completion: ${fc.predictedCompletionDate}` : 'Adjust targets to see ETA'}</span>
				</div>
				<div class="metric-cell">
					<p class="text-xs font-bold uppercase text-muted-foreground tracking-wider">Completion Status</p>
					<p class="mt-2 text-lg font-black text-foreground capitalize">${fc.status}</p>
					<span class="text-xs text-muted-foreground mt-4 inline-block">Compared with target direction</span>
				</div>
			`;
		}

		// 9. Plateau Intelligence Diagnostics
		const plateauContainer = document.querySelector('#plateau-report-container');
		if (plateauContainer) {
			const diagnosis = analyzePlateau(checkins, latest ? latest.recommended : 'recomp', latest);
			
			let statusBadge = `<span class="badge">Awaiting Data</span>`;
			if (checkins.length >= 3) {
				statusBadge = diagnosis.plateauDetected 
					? `<span class="badge border-destructive bg-destructive/10 text-destructive font-bold">Plateau Detected</span>`
					: `<span class="badge border-success bg-success/10 text-success font-bold">Steady Progress</span>`;
			}

			// Trend Divergence Analysis
			let divergenceHtml = '';
			if (checkins.length >= 3 && latest) {
				const sorted = [...checkins].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
				const first = sorted[0];
				const last = sorted[sorted.length - 1];
				const days = Math.max(1, (new Date(last.date).getTime() - new Date(first.date).getTime()) / 86400000);
				const actualPacePerWeek = ((last.weight - first.weight) / days) * 7;

				let expectedPacePerWeek = 0;
				if (latest.recommended === 'fat-loss') expectedPacePerWeek = -latest.weightKg * 0.0075;
				else if (latest.recommended === 'lean-bulk') expectedPacePerWeek = latest.weightKg * 0.002;
				else if (latest.recommended === 'aggressive-bulk') expectedPacePerWeek = latest.weightKg * 0.004;

				if (expectedPacePerWeek !== 0) {
					const ratio = expectedPacePerWeek !== 0 ? actualPacePerWeek / expectedPacePerWeek : 0;
					const diverged = ratio < 0.4 || ratio > 1.6;
					divergenceHtml = `
						<div class="rounded-xl border ${diverged ? 'border-warning/20 bg-warning/5' : 'border-border bg-muted/10'} p-4 text-xs">
							<p class="font-bold text-foreground flex items-center gap-1.5 mb-2">
								${diverged ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>'}
								Trend Divergence Analysis
							</p>
							<div class="grid gap-2 sm:grid-cols-2 text-muted-foreground">
								<div>
									<p><span class="text-foreground font-semibold">Expected pace:</span> ${formatWeight(Math.abs(expectedPacePerWeek))}/week (${labels[latest.recommended]})</p>
									<p><span class="text-foreground font-semibold">Actual pace:</span> ${actualPacePerWeek !== 0 ? formatWeight(Math.abs(actualPacePerWeek)) + '/week' : 'Flat / No trend'}</p>
								</div>
								<div>
									<p class="font-semibold text-foreground">Verdict:</p>
									${diverged
										? `<span class="text-warning">Your actual progress pace differs significantly from the expected rate. ${actualPacePerWeek > 0 && expectedPacePerWeek < 0 ? 'You are gaining weight during a fat loss phase — consider a strategy adjustment.' : actualPacePerWeek < 0 && expectedPacePerWeek > 0 ? 'You are losing weight during a bulk phase — increase calories.' : 'Consider a strategy reassessment.'}</span>`
										: `<span class="text-success">Your actual pace aligns with the expected range. Stay the course.</span>`
									}
								</div>
							</div>
						</div>
					`;
				}
			}

			plateauContainer.innerHTML = `
				<div class="flex items-center justify-between border-b border-border pb-4 mb-4">
					<div>
						<p class="eyebrow">Plateau Intelligence Engine</p>
						<h2 class="text-xl font-black text-foreground">Diagnostic Report</h2>
					</div>
					${statusBadge}
				</div>

				<div class="space-y-4">
					${divergenceHtml}

					<div>
						<h3 class="text-sm font-bold text-foreground">Diagnostic Output</h3>
						<p class="text-xs text-muted-foreground mt-1.5 leading-relaxed">${diagnosis.message}</p>
					</div>

					<div class="rounded-xl border border-border bg-muted/20 p-4">
						<h3 class="text-sm font-bold text-foreground flex items-center gap-1.5">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
							Course Correction Suggestions
						</h3>
						<p class="text-xs text-muted-foreground mt-1.5 leading-relaxed">${diagnosis.actionPlan}</p>
					</div>

					${diagnosis.dietarySuggestions.length > 0 ? `
						<div>
							<h3 class="text-sm font-bold text-foreground mb-2">Adaptive Dietary Adjustments</h3>
							<ul class="space-y-1.5 pl-6 list-disc text-xs text-muted-foreground">
								${diagnosis.dietarySuggestions.map(s => `<li>${s}</li>`).join('')}
							</ul>
						</div>
					` : ''}
				</div>
			`;
		}

		renderDualChart(checkins, goal);
		renderBodyFatChart(checkins);
		renderDualChart(checkins, goal);
		renderBodyFatChart(checkins);
		renderReassessment();

		// Calculate streaks
		let streak = 0;
		if (checkins.length > 0) {
			const sorted = [...checkins].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
			let current = new Date();
			streak = 0;
			
			// Count consecutive weeks logged
			for (let i = 0; i < sorted.length; i++) {
				const checkinDate = new Date(sorted[i].date);
				const diffTime = Math.abs(current.getTime() - checkinDate.getTime());
				const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
				
				if (diffDays <= (i + 1) * 9) {
					streak++;
				} else {
					break;
				}
			}
		}

		// Update Streak counter elements
		const streakCounterText = document.getElementById('streak-counter-text');
		if (streakCounterText) {
			streakCounterText.textContent = `${streak} Week${streak !== 1 ? 's' : ''}`;
		}

		const atRiskWarning = document.getElementById('at-risk-warning');
		if (atRiskWarning) {
			if (checkins.length > 0) {
				const latestCheckin = [...checkins].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())[0];
				const elapsedDays = (new Date().getTime() - new Date(latestCheckin.date).getTime()) / 86400000;
				if (elapsedDays > 7.5 && elapsedDays < 14) {
					atRiskWarning.classList.remove('hidden');
				} else {
					atRiskWarning.classList.add('hidden');
				}
			} else {
				atRiskWarning.classList.add('hidden');
			}
		}

		// Render Milestone Badges
		const badgesContainer = document.getElementById('milestones-badges-container');
		if (badgesContainer) {
			const badges = [];
			
			// 1. Kickstart Badge
			if (checkins.length >= 1) {
				badges.push({ name: 'Kickstarter', desc: 'First check-in logged!', color: 'bg-accent/15 text-accent border border-accent/30' });
			}
			// 2. Consistency Champ
			if (streak >= 4) {
				badges.push({ name: 'Consistency Champ', desc: '4+ week streak!', color: 'bg-success/15 text-success border border-success/30' });
			}
			// 3. Goal Crusher
			if (latest) {
				const startW = latest.weightKg;
				const currentW = checkins.length > 0 ? checkins[0].weight : startW;
				const goalW = latest.goalWeight || goal;
				const span = Math.abs(startW - goalW);
				const progress = Math.abs(startW - currentW);
				if (span > 0 && (progress / span) >= 0.25) {
					badges.push({ name: 'Goal Getter', desc: '25% of goal weight achieved!', color: 'bg-warning/15 text-warning border border-warning/30' });
				}
			}
			
			if (badges.length === 0) {
				badgesContainer.innerHTML = '<p class="text-[10px] text-muted-foreground">Keep logging check-ins to unlock your first milestone badge!</p>';
			} else {
				badgesContainer.innerHTML = badges.map(b => `
					<div class="px-2.5 py-1.5 rounded-xl ${b.color} text-center flex flex-col justify-center max-w-[130px] shadow-sm">
						<span class="text-[10px] font-bold block">${b.name}</span>
						<span class="text-[8px] text-muted-foreground mt-0.5 leading-tight">${b.desc}</span>
					</div>
				`).join('');
			}
		}
	}

	// Canvas PNG Share Card Generator
	document.getElementById('generate-progress-card-btn')?.addEventListener('click', () => {
		const canvas = document.getElementById('share-card-canvas') as HTMLCanvasElement;
		if (!canvas) return;

		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const latest = getLatestAssessment();
		const checkins = getCheckins();

		canvas.width = 600;
		canvas.height = 400;

		// Draw Background Gradient
		const gradient = ctx.createLinearGradient(0, 0, 600, 400);
		gradient.addColorStop(0, '#0f172a');
		gradient.addColorStop(1, '#1e1b4b');
		ctx.fillStyle = gradient;
		ctx.fillRect(0, 0, 600, 400);

		// Draw Border Accent
		ctx.strokeStyle = '#3b82f6';
		ctx.lineWidth = 6;
		ctx.strokeRect(3, 3, 594, 394);

		// Draw App Name / Branding
		ctx.fillStyle = '#60a5fa';
		ctx.font = '800 14px sans-serif';
		ctx.fillText('BODYCOMPOS // STRATEGY PULSE', 30, 40);

		// Draw Title
		ctx.fillStyle = '#ffffff';
		ctx.font = '800 32px sans-serif';
		ctx.fillText('Body Composition Progress', 30, 85);

		// Current Strategy Details
		ctx.fillStyle = '#94a3b8';
		ctx.font = '500 12px sans-serif';
		ctx.fillText('ACTIVE STRATEGY', 30, 140);
		ctx.fillStyle = '#38bdf8';
		ctx.font = '800 18px sans-serif';
		ctx.fillText(latest ? latest.recommended.replace(/-/g, ' ').toUpperCase() : 'NO ASSESSMENT', 30, 165);

		// Stats Grid
		const unitLabel = dashboardUnit === 'metric' ? 'kg' : 'lb';
		const startWVal = latest ? latest.weightKg : 0;
		const currentWVal = lastCheck ? lastCheck.weight : (latest ? latest.weightKg : 0);
		const goalWVal = latest ? (latest.goalWeight || latest.targetWeight || 75) : 0;

		const dispCurrentW = currentWVal ? round(dashboardUnit === 'metric' ? currentWVal : kgToLb(currentWVal), 1) : null;
		const dispGoalW = goalWVal ? round(dashboardUnit === 'metric' ? goalWVal : kgToLb(goalWVal), 1) : null;

		ctx.fillStyle = '#94a3b8';
		ctx.font = '500 12px sans-serif';
		ctx.fillText(`CURRENT WEIGHT (${unitLabel})`, 30, 220);
		ctx.fillStyle = '#ffffff';
		ctx.font = '800 24px sans-serif';
		ctx.fillText(dispCurrentW ? `${dispCurrentW} ${unitLabel}` : '-', 30, 250);

		ctx.fillStyle = '#94a3b8';
		ctx.font = '500 12px sans-serif';
		ctx.fillText(`TARGET WEIGHT (${unitLabel})`, 220, 220);
		ctx.fillStyle = '#ffffff';
		ctx.font = '800 24px sans-serif';
		ctx.fillText(dispGoalW ? `${dispGoalW} ${unitLabel}` : '-', 220, 250);

		ctx.fillStyle = '#94a3b8';
		ctx.font = '500 12px sans-serif';
		ctx.fillText('COMPLIANCE STREAK', 410, 220);
		ctx.fillStyle = '#4ade80';
		ctx.font = '800 24px sans-serif';
		
		let streak = 0;
		if (checkins.length > 0) {
			const sorted = [...checkins].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
			let current = new Date();
			for (let i = 0; i < sorted.length; i++) {
				const checkinDate = new Date(sorted[i].date);
				if (Math.abs(current.getTime() - checkinDate.getTime()) / (1000*60*60*24) <= (i+1)*9) {
					streak++;
				} else break;
			}
		}
		ctx.fillText(`${streak} Weeks`, 410, 250);

		// Quote / Attributed review watermark
		ctx.fillStyle = '#64748b';
		ctx.font = 'italic 11px sans-serif';
		ctx.fillText('Reviewed by certified sports nutrition researchers (ISSN & CSCS)', 30, 360);

		// Trigger download
		const dataUrl = canvas.toDataURL('image/png');
		const downloadLink = document.createElement('a');
		downloadLink.href = dataUrl;
		downloadLink.download = `bodycompos_share_card_${new Date().toISOString().split('T')[0]}.png`;
		document.body.appendChild(downloadLink);
		downloadLink.click();
		downloadLink.remove();
	});

	// Body Fat Trend Chart
	function renderBodyFatChart(checkins) {
		const container = document.querySelector('#bf-trend-chart');
		const tableContainer = document.querySelector('#bf-data-table');
		if (!container) return;

		const withBf = checkins.filter(c => c.bodyFat != null).sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

		if (withBf.length < 2) {
			container.innerHTML = `
				<div class="flex flex-col items-center justify-center p-8 text-center min-h-[180px] rounded-2xl border border-dashed border-border bg-muted/5">
					<div class="w-10 h-10 rounded-full bg-success/10 flex items-center justify-center text-success mb-3">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>
					</div>
					<h4 class="font-bold text-sm text-foreground">Awaiting Body Fat Logs</h4>
					<p class="text-xs text-muted-foreground max-w-sm mt-1 leading-relaxed">
						Please log at least two check-ins with body fat % estimates to generate the composition timeline.
					</p>
				</div>
			`;
			if (tableContainer) tableContainer.classList.add('hidden');
			return;
		}

		const values = withBf.map(c => c.bodyFat);
		const minBf = Math.min(...values);
		const maxBf = Math.max(...values);
		const bfRange = Math.max(2, maxBf - minBf);

		const points = withBf.map((item, index) => {
			const x = 30 + (index / (withBf.length - 1)) * 340;
			const y = 140 - ((item.bodyFat - minBf) / bfRange) * 100;
			return { x, y, val: item.bodyFat, date: item.date };
		});

		const polylinePoints = points.map(p => `${p.x},${p.y}`).join(' ');
		const bfFirstX = points[0].x;
		const bfLastX = points[points.length - 1].x;
		const bfAreaPoints = `${bfFirstX},140 ${polylinePoints} ${bfLastX},140`;

		container.innerHTML = `
			<svg viewBox="0 0 400 180" role="img" aria-label="Body fat percentage trend chart" class="h-48 w-full overflow-visible">
				<defs>
					<linearGradient id="bf-chart-grad-only" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="var(--success)" stop-opacity="0.15" />
						<stop offset="100%" stop-color="var(--success)" stop-opacity="0" />
					</linearGradient>
				</defs>
				
				<line x1="30" y1="40" x2="370" y2="40" stroke="var(--border)" stroke-width="0.5" opacity="0.3" />
				<line x1="30" y1="90" x2="370" y2="90" stroke="var(--border)" stroke-width="0.5" opacity="0.3" />
				<line x1="30" y1="140" x2="370" y2="140" stroke="var(--border)" stroke-width="0.5" opacity="0.3" />

				<polygon points="${bfAreaPoints}" fill="url(#bf-chart-grad-only)"></polygon>
				<polyline points="${polylinePoints}" fill="none" stroke="var(--success)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></polyline>

				${points.map(p => `<circle cx="${p.x}" cy="${p.y}" r="4" fill="var(--card)" stroke="var(--success)" stroke-width="2.5"><title>${p.date}: Body Fat ${p.val}%</title></circle>`).join('')}

				<text x="30" y="174" fill="var(--muted-foreground)" font-size="9" font-weight="600" text-anchor="start">${points[0].date}</text>
				<text x="370" y="174" fill="var(--muted-foreground)" font-size="9" font-weight="600" text-anchor="end">${points[points.length - 1].date}</text>
				<text x="5" y="45" fill="var(--muted-foreground)" font-size="8">${round(maxBf, 1)}%</text>
				<text x="5" y="145" fill="var(--muted-foreground)" font-size="8">${round(minBf, 1)}%</text>
			</svg>
		`;

		if (tableContainer) {
			tableContainer.classList.remove('hidden');
			tableContainer.innerHTML = `
				<table class="w-full min-w-[400px] text-left text-xs">
					<caption class="text-xs font-semibold text-muted-foreground mb-2 text-left">Body Fat % Data Table</caption>
					<thead>
						<tr class="border-b border-border">
							<th class="py-1.5 text-foreground font-semibold">Date</th>
							<th class="py-1.5 text-foreground font-semibold">Body Fat %</th>
							<th class="py-1.5 text-foreground font-semibold">Change</th>
						</tr>
					</thead>
					<tbody>
						${withBf.map((item, idx) => {
							const change = idx === 0 ? '-' : `${item.bodyFat > withBf[idx - 1].bodyFat ? '+' : ''}${round(item.bodyFat - withBf[idx - 1].bodyFat, 1)}%`;
							return `<tr class="border-b border-border">
								<td class="py-1.5 text-muted-foreground">${item.date}</td>
								<td class="py-1.5 text-foreground font-semibold">${item.bodyFat}%</td>
								<td class="py-1.5 text-muted-foreground">${change}</td>
							</tr>`;
						}).join('')}
					</tbody>
				</table>
			`;
		}
	}

	// Monthly Reassessment Workflow
	const labels = engineGoalLabels;
	const activityFactors = engineActFactors;
	function renderReassessment() {
		const panel = document.querySelector('#reassessment-panel');
		const body = document.querySelector('#reassessment-body');
		const latest = JSON.parse(localStorage.getItem('bodycompos.latestAssessment') || 'null');
		const checkins = getCheckins();
		if (!panel || !body || !latest) return;

		const lastCheckin = checkins[0];
		const currentWeight = lastCheckin ? lastCheckin.weight : latest.weightKg;
		const currentBF = lastCheckin && lastCheckin.bodyFat ? lastCheckin.bodyFat : latest.bodyFat;

		body.innerHTML = `
			<div class="grid gap-4 sm:grid-cols-2 mb-4">
				<div class="rounded-lg border border-border bg-muted/10 p-3 text-xs">
					<p class="font-bold text-foreground mb-2">Original Assessment (${new Date(latest.createdAt).toLocaleDateString()})</p>
					<div class="space-y-1 text-muted-foreground">
						<p>Strategy: <span class="font-semibold text-foreground">${labels[latest.recommended] || latest.recommended}</span></p>
						<p>Weight: <span class="font-semibold text-foreground">${formatWeight(latest.weightKg)}</span></p>
						<p>Body Fat: <span class="font-semibold text-foreground">${latest.bodyFat}%</span></p>
						<p>Calories: <span class="font-semibold text-foreground">${latest.target} kcal</span></p>
					</div>
				</div>
				<div class="rounded-lg border border-border bg-accent/5 p-3 text-xs">
					<p class="font-bold text-foreground mb-2">Current Status (Latest Check-In)</p>
					<div class="space-y-1 text-muted-foreground">
						<p>Current Weight: <span class="font-semibold text-foreground">${formatWeight(currentWeight)}</span></p>
						<p>Current Body Fat: <span class="font-semibold text-foreground">${currentBF ? currentBF + '%' : 'Not logged'}</span></p>
						<p>Change: <span class="font-semibold ${currentWeight < latest.weightKg ? 'text-success' : currentWeight > latest.weightKg ? 'text-warning' : 'text-muted-foreground'}">${formatWeight(Math.abs(currentWeight - latest.weightKg))} ${currentWeight < latest.weightKg ? 'lost' : currentWeight > latest.weightKg ? 'gained' : 'stable'}</span></p>
					</div>
				</div>
			</div>
			<div class="rounded-xl border border-border bg-muted/20 p-4 text-xs">
				<p class="font-bold text-foreground mb-3">Run a Fresh Reassessment</p>
				<div class="grid gap-3 sm:grid-cols-2">
					<div class="field">
						<label for="reassess-weight">Current Weight <span data-dashboard-weight-unit>(${dashboardUnit === 'metric' ? 'kg' : 'lb'})</span></label>
						<input id="reassess-weight" type="number" step="0.1" value="${dashboardUnit === 'metric' ? currentWeight : round(kgToLb(currentWeight), 1)}" />
					</div>
					<div class="field">
						<label for="reassess-bf">Current Body Fat %</label>
						<input id="reassess-bf" type="number" step="0.1" min="3" max="60" value="${currentBF || ''}" placeholder="e.g. ${latest.bodyFat}" />
					</div>
				</div>
				<button id="run-reassessment-btn" class="button-primary text-xs mt-3">Run Reassessment & Compare</button>
			</div>
			<div id="reassessment-result" class="mt-4 hidden">
				<!-- Dynamic comparison result -->
			</div>
		`;
	}

	// Save check-in logic
	document.querySelector('#checkin-form')?.addEventListener('submit', (event) => {
		event.preventDefault();
		const f = event.currentTarget as HTMLFormElement;
		
		const weight = dashboardUnit === 'metric' ? Number(f.weight.value) : lbToKg(Number(f.weight.value));
		const item = { 
			date: f.date.value, 
			weight, 
			bodyFat: f.bodyFat.value ? Number(f.bodyFat.value) : null, 
			adherence: Number(f.adherence.value || 0) 
		};

		let items = getCheckins();
		if (editingCheckinIdx >= 0 && items[editingCheckinIdx]) {
			items[editingCheckinIdx] = item;
			editingCheckinIdx = -1;
		} else {
			items = items.filter((x) => x.date !== item.date);
			items.unshift(item);
		}
		setCheckins(items.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 60));
		
		f.reset();
		const dateInput = document.querySelector('#date') as HTMLInputElement;
		if (dateInput) dateInput.value = today;
		const submitBtn = f.querySelector('button[type="submit"]');
		if (submitBtn) submitBtn.textContent = 'Save Weekly Check-In';
		
		render();
	});

	// Print trigger
	document.getElementById('print-report-btn')?.addEventListener('click', () => {
		const latest = JSON.parse(localStorage.getItem('bodycompos.latestAssessment') || 'null');
		const checkins = getCheckins();
		const assessments = getAssessments();
		
		// Build print content into a hidden container
		let printContainer = document.getElementById('print-report-data');
		if (!printContainer) {
			printContainer = document.createElement('div');
			printContainer.id = 'print-report-data';
			printContainer.className = 'print-only';
			document.body.appendChild(printContainer);
		}

		const goal = Number((document.querySelector('#goalWeight') as HTMLInputElement)?.value || 75);
		const fc = forecastProgress(checkins, dashboardUnit === 'metric' ? goal : lbToKg(goal));

		printContainer.innerHTML = `
			<div class="print-report">
				<h1>BodyCompOS Progress Snapshot</h1>
				<p class="print-date">Generated ${today}</p>

				${latest ? `
					<section>
						<h2>Active Strategy</h2>
						<p><strong>Strategy:</strong> ${labels[latest.recommended] || latest.recommended}</p>
						<p><strong>Calories:</strong> ${latest.target} kcal/day</p>
						<p><strong>Protein:</strong> ${latest.proteinLow}-${latest.proteinHigh} g/day</p>
						<p><strong>Maintenance (TDEE):</strong> ${latest.maintenance} kcal</p>
						<p><strong>Body Fat:</strong> ${latest.bodyFat}%</p>
						<p><strong>Assessed:</strong> ${new Date(latest.createdAt).toLocaleDateString()}</p>
					</section>
				` : ''}

				<section>
					<h2>Progress Summary</h2>
					${checkins.length >= 2 ? `
						<p><strong>Start Weight:</strong> ${formatWeight(checkins[checkins.length - 1].weight)}</p>
						<p><strong>Current Weight:</strong> ${formatWeight(checkins[0].weight)}</p>
						<p><strong>Change:</strong> ${formatWeight(Math.abs(checkins[checkins.length - 1].weight - checkins[0].weight))} ${checkins[0].weight < checkins[checkins.length - 1].weight ? 'lost' : 'gained'}</p>
						<p><strong>Forecast ETA:</strong> ${fc.etaWeeks ? fc.etaWeeks + ' weeks' : 'Insufficient data'}</p>
					` : '<p>Insufficient check-in data for progress summary.</p>'}
				</section>

				<section>
					<h2>Check-In Log</h2>
					${checkins.length > 0 ? `
						<table>
							<thead>
								<tr>
									<th>Date</th>
									<th>Weight</th>
									<th>Body Fat %</th>
									<th>Adherence</th>
								</tr>
							</thead>
							<tbody>
								${checkins.map(c => `
									<tr>
										<td>${c.date}</td>
										<td>${formatWeight(c.weight)}</td>
										<td>${c.bodyFat ? c.bodyFat + '%' : '-'}</td>
										<td>${c.adherence}%</td>
									</tr>
								`).join('')}
							</tbody>
						</table>
					` : '<p>No check-in logs.</p>'}
				</section>

				<section>
					<h2>Assessment History</h2>
					${assessments.length > 0 ? `
						<table>
							<thead>
								<tr>
									<th>Date</th>
									<th>Strategy</th>
									<th>Calories</th>
									<th>BF %</th>
								</tr>
							</thead>
							<tbody>
								${assessments.slice(0, 5).map(a => `
									<tr>
										<td>${new Date(a.createdAt).toLocaleDateString()}</td>
										<td>${labels[a.recommended] || a.recommended}</td>
										<td>${a.target} kcal</td>
										<td>${a.bodyFat}%</td>
									</tr>
								`).join('')}
							</tbody>
						</table>
					` : '<p>No assessment history.</p>'}
				</section>

				<p class="print-footer">BodyCompOS — Educational estimates only. Generated from local browser data.</p>
			</div>
		`;

		window.print();
	});

	// Unified Data Administration System
	const importInput = document.getElementById('dashboard-import-file') as HTMLInputElement;
	
	document.getElementById('import-data-btn-header')?.addEventListener('click', () => importInput?.click());
	document.getElementById('import-data-btn-admin')?.addEventListener('click', () => importInput?.click());

	function handleExport() {
		const backup = {
			'bodycompos.preferredUnit': localStorage.getItem('bodycompos.preferredUnit'),
			'bodycompos.checkins': localStorage.getItem('bodycompos.checkins'),
			'bodycompos.assessments': localStorage.getItem('bodycompos.assessments'),
			'bodycompos.latestAssessment': localStorage.getItem('bodycompos.latestAssessment'),
		};
		const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(backup, null, 2));
		const downloadAnchor = document.createElement('a');
		downloadAnchor.setAttribute("href", dataStr);
		downloadAnchor.setAttribute("download", `bodycompos_backup_${new Date().toISOString().split('T')[0]}.json`);
		document.body.appendChild(downloadAnchor);
		downloadAnchor.click();
		downloadAnchor.remove();
	}

	document.getElementById('export-data-btn-header')?.addEventListener('click', handleExport);
	document.getElementById('export-data-btn-admin')?.addEventListener('click', handleExport);

	importInput?.addEventListener('change', (e) => {
		const target = e.target as HTMLInputElement;
		const file = target.files?.[0];
		if (!file) return;

		const reader = new FileReader();
		reader.onload = (event) => {
			try {
				const backup = JSON.parse(event.target?.result as string);
				if (backup.schemaVersion === 1) {
					if (backup.checkins) localStorage.setItem('bodycompos.checkins', JSON.stringify(backup.checkins));
					if (backup.assessments) localStorage.setItem('bodycompos.assessments', JSON.stringify(backup.assessments));
					if (backup.latestAssessment) localStorage.setItem('bodycompos.latestAssessment', JSON.stringify(backup.latestAssessment));
				} else {
					const keys = [
						'bodycompos.preferredUnit',
						'bodycompos.checkins',
						'bodycompos.assessments',
						'bodycompos.latestAssessment'
					];
					keys.forEach(key => {
						if (backup[key] !== undefined && backup[key] !== null) {
							localStorage.setItem(key, typeof backup[key] === 'string' ? backup[key] : JSON.stringify(backup[key]));
						}
					});
				}
				alert('Data profile imported successfully! Reloading workspace...');
				window.location.reload();
			} catch (err) {
				alert('Invalid file format. Please import a valid body composition backup JSON file.');
			}
		};
		reader.readAsText(file);
	});

	document.getElementById('clear-database-btn')?.addEventListener('click', () => {
		if (confirm('Are you absolutely sure you want to clear your local history? This deletes all check-ins and saved assessments.')) {
			localStorage.removeItem('bodycompos.checkins');
			localStorage.removeItem('bodycompos.assessments');
			localStorage.removeItem('bodycompos.latestAssessment');
			render();
		}
	});

	// Reassessment panel toggle
	document.getElementById('start-reassessment-btn')?.addEventListener('click', () => {
		const panel = document.querySelector('#reassessment-panel');
		if (panel) {
			panel.classList.remove('hidden');
			panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			renderReassessment();
		}
	});
	document.getElementById('close-reassessment-btn')?.addEventListener('click', () => {
		const panel = document.querySelector('#reassessment-panel');
		if (panel) panel.classList.add('hidden');
	});

	// Run reassessment or adaptation
	document.addEventListener('click', (e) => {
		const adaptationBtn = (e.target as HTMLElement).closest('#apply-adaptation-btn');
		if (adaptationBtn) {
			const latest = getLatestAssessment();
			const checkins = getCheckins();
			if (!latest || checkins.length === 0) return;
			const currentWeight = checkins[0].weight;
			const currentBF = checkins[0].bodyFat || latest.bodyFat;

			const bmr = currentBF && currentBF > 0
				? katch(currentWeight, currentBF)
				: engineMifflin({ 
					sex: latest.sex, 
					age: latest.age, 
					heightCm: latest.heightCm, 
					weightKg: currentWeight 
				});
			const activityFactor = engineActFactors[latest.activity] || 1.55;
			const maintenance = Math.round(bmr * activityFactor);
			const target = engineCalTarget(maintenance, latest.recommended);
			
			latest.target = target;
			latest.maintenance = maintenance;
			latest.proteinLow = Math.round(currentWeight * (latest.recommended === 'maintain' ? 1.6 : 1.7));
			latest.proteinHigh = Math.round(currentWeight * (latest.recommended === 'maintain' ? 1.8 : 2.2));
			latest.weightKg = currentWeight;
			latest.createdAt = new Date().toISOString();
			
			localStorage.setItem('bodycompos.latestAssessment', JSON.stringify(latest));
			
			const history = JSON.parse(localStorage.getItem('bodycompos.assessments') || '[]');
			if (history.length > 0) {
				history[0] = latest;
				localStorage.setItem('bodycompos.assessments', JSON.stringify(history));
			}
			
			alert('Plan targets adapted to current weight of ' + currentWeight.toFixed(1) + ' kg!');
			render();
			return;
		}

		const btn = (e.target as HTMLElement).closest('#run-reassessment-btn');
		if (!btn) return;
		const latest = JSON.parse(localStorage.getItem('bodycompos.latestAssessment') || 'null');
		if (!latest) return;
		const weightInput = document.getElementById('reassess-weight') as HTMLInputElement;
		const bfInput = document.getElementById('reassess-bf') as HTMLInputElement;
		if (!weightInput) return;

		const newWeight = dashboardUnit === 'metric' ? Number(weightInput.value) : lbToKg(Number(weightInput.value));
		const newBF = bfInput ? Number(bfInput.value) : latest.bodyFat;

		// Run strategy recommendation with current data but same preferences
		const proteinAdequate = latest.protein ? latest.protein >= newWeight * 1.6 : false;
		const rec = engineStrategyRec({
			bodyFat: newBF || latest.bodyFat,
			trainingAge: latest.trainingAge || 'intermediate',
			goalBias: latest.goalBias || 'recomp',
			proteinAdequate,
		});
		const activeBF = newBF || latest.bodyFat;
		const bmr = activeBF && activeBF > 0
			? katch(newWeight, activeBF)
			: engineMifflin({ sex: latest.sex, age: latest.age, heightCm: latest.heightCm, weightKg: newWeight });
		const maintenance = engineClamp(bmr * activityFactors[latest.activity], 1200, 5000);
		const target = engineCalTarget(maintenance, rec.recommended);

		const resultDiv = document.getElementById('reassessment-result');
		if (!resultDiv) return;
		resultDiv.classList.remove('hidden');

		const oldRec = labels[latest.recommended] || latest.recommended;
		const newRec = labels[rec.recommended];
		const changed = rec.recommended !== latest.recommended;

		resultDiv.innerHTML = `
			<div class="rounded-xl border ${changed ? 'border-warning/30 bg-warning/5' : 'border-success/30 bg-success/5'} p-4 text-xs mt-4">
				<p class="font-bold text-foreground mb-3 flex items-center gap-1.5">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
					Reassessment Result
				</p>
				<div class="grid gap-3 sm:grid-cols-2">
					<div class="rounded-lg border border-border bg-card p-3">
						<p class="text-muted-foreground">Previous Strategy</p>
						<p class="text-base font-bold text-foreground">${oldRec}</p>
						<p class="text-muted-foreground mt-1">${latest.target} kcal/day</p>
					</div>
					<div class="rounded-lg border ${changed ? 'border-warning/40' : 'border-success/40'} bg-card p-3">
						<p class="text-muted-foreground">Recommended Now</p>
						<p class="text-base font-bold ${changed ? 'text-warning' : 'text-success'}">${newRec}</p>
						<p class="text-muted-foreground mt-1">${target} kcal/day <span class="text-accent">(${rec.confidence}% confidence)</span></p>
					</div>
				</div>
				${changed ? `
					<div class="mt-3 rounded-lg border border-border bg-muted/20 p-3">
						<p class="font-bold text-foreground">Strategy Change Detected</p>
						<p class="text-muted-foreground mt-1">Your body composition has shifted enough to warrant a strategy change from <strong>${oldRec}</strong> to <strong>${newRec}</strong>. Consider updating your approach.</p>
						<a href="/assess" class="button-primary inline-block mt-3 text-xs">Run Full Strategy Finder</a>
					</div>
				` : `
					<div class="mt-3 rounded-lg border border-border bg-muted/20 p-3">
						<p class="font-bold text-foreground">Strategy Confirmed</p>
						<p class="text-muted-foreground mt-1">Your current strategy (<strong>${newRec}</strong>) remains appropriate. No changes needed.</p>
					</div>
				`}
			</div>
		`;
	});

	// Initial population of inputs and active unit state update on page load
	(function() {
		const form = document.querySelector('#checkin-form') as HTMLFormElement | null;
		if (form) {
			const weightInput = form.querySelector('#weight') as HTMLInputElement | null;
			const goalWeightInput = form.querySelector('#goalWeight') as HTMLInputElement | null;
			const latest = getLatestAssessment();
			const checkins = getCheckins();

			const lastCheckin = checkins[0];
			const rawCurrentWeight = lastCheckin ? lastCheckin.weight : (latest ? latest.weightKg : 80);
			const rawGoalWeight = latest && latest.goalWeight ? latest.goalWeight : 75;

			const currentWeightVal = dashboardUnit === 'metric' ? rawCurrentWeight : round(kgToLb(rawCurrentWeight), 1);
			const goalWeightVal = dashboardUnit === 'metric' ? rawGoalWeight : round(kgToLb(rawGoalWeight), 1);

			if (weightInput) {
				weightInput.value = String(currentWeightVal);
				weightInput.min = dashboardUnit === 'imperial' ? '44' : '20';
				weightInput.max = dashboardUnit === 'imperial' ? '550' : '250';
			}
			if (goalWeightInput) {
				goalWeightInput.value = String(goalWeightVal);
				goalWeightInput.min = dashboardUnit === 'imperial' ? '44' : '20';
				goalWeightInput.max = dashboardUnit === 'imperial' ? '550' : '250';
			}
		}

		document.querySelectorAll('[data-dashboard-unit]').forEach((button) => {
			button.setAttribute('aria-pressed', String(button.getAttribute('data-dashboard-unit') === dashboardUnit));
		});
		document.querySelectorAll('[data-dashboard-weight-unit]').forEach((label) => {
			label.textContent = dashboardUnit === 'metric' ? '(kg)' : '(lb)';
		});
	})();

	render();
</script>

<style>
	.tab-btn {
		background: transparent;
		color: var(--muted-foreground);
		border: none;
		padding: 0.65rem 1rem;
		font-size: 0.85rem;
		font-weight: 680;
		cursor: pointer;
		border-bottom: 2px solid transparent;
		transition: color 180ms ease, border-color 180ms ease;
		white-space: nowrap;
	}
	
	.tab-btn:hover {
		color: var(--foreground);
	}
	
	.tab-btn.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.tab-panel {
		animation: fadeIn 0.3s ease-out both;
	}

	.metric-cell {
		min-height: 100px;
	}

	.print-only { display: none; }

	/* Print Report Styles */
	@media print {
		body * { visibility: hidden; }
		#print-report-data, #print-report-data * { visibility: visible; }
		#print-report-data { position: absolute; left: 0; top: 0; width: 100%; padding: 40px; max-width: 800px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; display: block; }
		.print-report h1 { font-size: 24px; font-weight: 800; margin-bottom: 4px; color: #0f172a; }
		.print-report .print-date { font-size: 12px; color: #6b7280; margin-bottom: 24px; }
		.print-report section { margin-bottom: 24px; page-break-inside: avoid; }
		.print-report h2 { font-size: 16px; font-weight: 700; color: #0f172a; border-bottom: 2px solid #e5e7eb; padding-bottom: 6px; margin-bottom: 12px; }
		.print-report p { font-size: 12px; color: #374151; margin: 4px 0; }
		.print-report table { width: 100%; border-collapse: collapse; font-size: 11px; }
		.print-report th { background: #f3f4f6; padding: 8px; text-align: left; font-weight: 700; color: #0f172a; border: 1px solid #e5e7eb; }
		.print-report td { padding: 6px 8px; border: 1px solid #e5e7eb; color: #374151; }
		.print-report .print-footer { margin-top: 32px; font-size: 10px; color: #9ca3af; text-align: center; border-top: 1px solid #e5e7eb; padding-top: 12px; }
	}
</style>
