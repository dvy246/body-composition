							<th class="py-2 text-foreground font-semibold">Weight</th>
							<th class="py-2 text-foreground font-semibold">Body Fat (%)</th>
							<th class="py-2 text-foreground font-semibold">Adherence</th>
							<th class="py-2 text-foreground font-semibold">Action</th>
						</tr>
					</thead>
					<tbody>
						${checkins.map((i, idx) => `
							<tr class="border-b border-border hover:bg-muted/10">
								<td class="py-3 text-muted-foreground font-medium">${i.date}</td>
								<td class="py-3 text-foreground font-semibold">${formatWeight(i.weight)}</td>
								<td class="py-3 text-muted-foreground">${i.bodyFat ? i.bodyFat + '%' : '-'}</td>
								<td class="py-3 text-muted-foreground">${i.adherence}%</td>
								<td class="py-3">
									<div class="flex gap-1">
										<button class="button-ghost text-xs py-1 min-h-6 edit-checkin-btn" data-idx="${idx}">Edit</button>
										<button class="button-ghost text-destructive text-xs py-1 min-h-6 delete-checkin-btn" data-idx="${idx}">Delete</button>
									</div>
