				if (score >= 4) {
					statusText.className = 'text-xs font-bold text-success';
					statusText.textContent = 'Excellent Candidate (High probability of recomp)';
				} else if (score >= 2) {
					statusText.className = 'text-xs font-bold text-accent';
					statusText.textContent = 'Moderate Candidate (Recomp is viable)';
				} else if (score > 0) {
					statusText.className = 'text-xs font-semibold text-warning';
					statusText.textContent = 'Low-Viability Candidate (Slow/negligible progress)';
				} else if (score < 0) {
