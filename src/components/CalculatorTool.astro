---
interface Props {
	mode: string;
	title: string;
	description: string;
	primaryInputs?: string[];
	formula?: string;
	interpretation?: string;
}

const { mode, title, description, primaryInputs = [], formula = 'Uses the standard formulas described in the methodology page.', interpretation = 'Use the result as a starting estimate and adjust after monitoring trends.' } = Astro.props;

// Map fields to modes to control display
const fieldGroups = {
	sex: ['tdee', 'maintenance', 'bmr', 'bodyfat', 'composition', 'ideal', 'maintenance-calories', 'deficit-calories', 'surplus-calories', 'target-calories', 'daily-needs', 'weight-loss-calories', 'weight-gain-calories'],
	age: ['tdee', 'maintenance', 'bmr', 'bodyfat', 'composition', 'maintenance-calories', 'deficit-calories', 'surplus-calories', 'target-calories', 'daily-needs', 'weight-loss-calories', 'weight-gain-calories'],
	height: ['tdee', 'maintenance', 'bodyfat', 'ffmi', 'ideal', 'bmi', 'whtr', 'composition', 'bmr', 'maintenance-calories', 'deficit-calories', 'surplus-calories', 'target-calories', 'daily-needs', 'weight-loss-calories', 'weight-gain-calories'],
	weight: ['tdee', 'calorie', 'protein', 'timeline', 'bodyfat', 'ffmi', 'lbm', 'macro', 'maintenance', 'bmi', 'composition', 'deficit', 'surplus', 'target', 'muscle', 'recomp', 'bmr', 'maintenance-calories', 'deficit-calories', 'surplus-calories', 'target-calories', 'daily-needs', 'weight-loss-calories', 'weight-gain-calories'],
	bodyFat: ['tdee', 'ffmi', 'lbm', 'composition', 'target', 'recomp', 'bmr', 'maintenance-calories', 'deficit-calories', 'surplus-calories', 'target-calories', 'daily-needs', 'weight-loss-calories', 'weight-gain-calories'],
	waist: ['bodyfat', 'whtr'],
	neck: ['bodyfat'],
	hip: ['bodyfat'],
	activity: ['tdee', 'calorie', 'maintenance', 'deficit', 'surplus', 'muscle', 'recomp', 'maintenance-calories', 'deficit-calories', 'surplus-calories', 'target-calories', 'daily-needs', 'weight-loss-calories', 'weight-gain-calories'],
	goal: ['calorie', 'macro', 'deficit', 'surplus', 'timeline', 'muscle', 'recomp', 'target-calories'],
	targetWeight: ['timeline'],
	targetBodyFat: ['target'],
};

function isFieldVisible(key: keyof typeof fieldGroups) {
	return fieldGroups[key].includes(mode);
}

function fieldClass(key: keyof typeof fieldGroups) {
	return `field ${isFieldVisible(key) ? '' : 'hidden'}`;
}

const categoryLabels: Record<string, string> = {
	tdee: 'Energy Balance',
	calorie: 'Diet Planning',
	protein: 'Macronutrients',
	timeline: 'Goal Forecasting',
	bodyfat: 'Body Composition Index',
	ffmi: 'Body Composition Index',
	lbm: 'Body Composition Index',
	macro: 'Macronutrients',
	maintenance: 'Energy Balance',
	ideal: 'Body Metrics',
	bmi: 'Body Metrics',
	whtr: 'Body Metrics',
	composition: 'Body Composition Index',
	'maintenance-calories': 'Energy Balance',
	'deficit-calories': 'Energy Balance',
	'surplus-calories': 'Energy Balance',
	'target-calories': 'Diet Planning',
	'daily-needs': 'Energy Balance',
	'weight-loss-calories': 'Energy Balance',
	'weight-gain-calories': 'Energy Balance',
	surplus: 'Diet Planning',
	deficit: 'Diet Planning',
	target: 'Goal Forecasting',
	muscle: 'Goal Forecasting',
	recomp: 'Diet Planning',
	bmr: 'Energy Balance',
};

const category = categoryLabels[mode] || 'Calculator';

const buttonLabels: Record<string, string> = {
	tdee: 'Calculate TDEE & Maintenance',
	calorie: 'Calculate Daily Calorie Target',
	protein: 'Calculate Daily Protein Target',
	timeline: 'Forecast Weight Goal Timeline',
	bodyfat: 'Calculate Body Fat Percentage',
	ffmi: 'Calculate Fat-Free Mass Index',
	lbm: 'Calculate Lean Body Mass',
	macro: 'Calculate Macro Distribution',
	maintenance: 'Calculate Maintenance Calories',
	ideal: 'Calculate Ideal Weight Range',
	bmi: 'Calculate Body Mass Index',
	whtr: 'Calculate Waist-to-Height Ratio',
	composition: 'Calculate Body Composition Snapshot',
	surplus: 'Calculate Calorie Surplus Target',
	deficit: 'Calculate Calorie Deficit Target',
	target: 'Calculate Target Weight Goal',
	muscle: 'Calculate Muscle Gain Rate',
	recomp: 'Calculate Recomposition Targets',
	bmr: 'Calculate Basal Metabolic Rate',
};

const btnLabel = buttonLabels[mode] || 'Calculate Estimates';
---

<div class="surface overflow-hidden rounded-2xl border border-border" data-calculator={mode}>
	<!-- Header -->
	<div class="grid gap-6 border-b border-border p-6 lg:grid-cols-[1fr_auto] lg:items-start">
		<div>
			<p class="eyebrow">{category}</p>
			<h1 class="mt-2 text-3xl font-black text-foreground sm:text-4xl flex items-center gap-3">
				{category === 'Energy Balance' && <svg class="text-accent shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>}
				{category === 'Diet Planning' && <svg class="text-accent shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>}
				{category === 'Macronutrients' && <svg class="text-accent shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
				{category === 'Goal Forecasting' && <svg class="text-accent shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
				{category === 'Body Composition Index' && <svg class="text-accent shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>}
				{category === 'Body Metrics' && <svg class="text-accent shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>}
				{title}
			</h1>
			<p class="mt-3 max-w-3xl text-sm leading-relaxed text-muted-foreground">{description}</p>
			{primaryInputs.length > 0 && (
				<div class="mt-4 flex flex-wrap gap-1.5">
					{primaryInputs.map((input) => <span class="text-xs font-semibold bg-muted px-2 py-0.5 rounded text-muted-foreground">{input}</span>)}
				</div>
			)}
		</div>
		<div>
			<p class="mb-2 text-xs font-bold uppercase text-muted-foreground">System Units</p>
			<div class="segmented" role="group" aria-label="Measurement units">
				<button type="button" data-unit="metric" aria-pressed="true">Metric</button>
				<button type="button" data-unit="imperial" aria-pressed="false">Imperial</button>
			</div>
		</div>
	</div>
	<!-- Form -->
	<div class="calculator-layout-wrapper">
		{mode === 'tdee' && (
			<!-- Wizard flow indicator -->
			<div class="px-6 pt-4 flex items-center justify-between border-b border-border/40 pb-3 bg-muted/10">
				<div class="flex items-center gap-2">
					<span class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Step:</span>
					<div class="flex items-center gap-1.5" id="tdee-wizard-steps">
						<span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold bg-accent text-white" data-step="1">1</span>
						<span class="w-3 h-[2px] bg-border"></span>
						<span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold bg-muted text-muted-foreground" data-step="2">2</span>
						<span class="w-3 h-[2px] bg-border"></span>
						<span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold bg-muted text-muted-foreground" data-step="3">3</span>
					</div>
				</div>
				<span class="text-xs font-bold text-accent" id="tdee-wizard-step-label">Step 1: Body Metrics</span>
			</div>
		)}

		{mode === 'recomp' && (
			<!-- Recomposition Eligibility Quiz Banner -->
			<div class="p-6 bg-muted/20 border-b border-border/60">
				<p class="text-xs font-bold text-accent uppercase tracking-widest mb-1.5">Pre-Screen: Are You a Good Candidate for Recomp?</p>
				<p class="text-xs text-muted-foreground mb-4">Body recomposition (building muscle and losing fat simultaneously) is highly effective for specific physiological states. Check all that apply to you:</p>
				<div class="grid gap-2 sm:grid-cols-2 text-xs" id="recomp-eligibility-checklist">
					<label class="flex items-start gap-2.5 p-2.5 rounded-lg border border-border bg-card cursor-pointer hover:border-accent transition-colors">
						<input type="checkbox" class="mt-0.5 accent-accent" data-points="3" />
						<div>
							<p class="font-bold text-foreground">Beginner Lifter</p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Less than 1 year of consistent strength training.</p>
						</div>
					</label>
					<label class="flex items-start gap-2.5 p-2.5 rounded-lg border border-border bg-card cursor-pointer hover:border-accent transition-colors">
						<input type="checkbox" class="mt-0.5 accent-accent" data-points="2" />
						<div>
							<p class="font-bold text-foreground">Returning from Break</p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Detrained but have muscle memory advantages.</p>
						</div>
					</label>
					<label class="flex items-start gap-2.5 p-2.5 rounded-lg border border-border bg-card cursor-pointer hover:border-accent transition-colors">
						<input type="checkbox" class="mt-0.5 accent-accent" data-points="2" />
						<div>
							<p class="font-bold text-foreground">Moderate/Higher Body Fat</p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Plenty of stored energy to fuel muscle growth.</p>
						</div>
					</label>
					<label class="flex items-start gap-2.5 p-2.5 rounded-lg border border-border bg-card cursor-pointer hover:border-accent transition-colors">
						<input type="checkbox" class="mt-0.5 accent-accent" data-points="-2" />
						<div>
							<p class="font-bold text-foreground">Already Lean & Advanced</p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Very difficult to recomp. Defined cut/bulk cycles are recommended.</p>
						</div>
					</label>
				</div>
				<div class="mt-4 p-3 rounded-lg bg-accent/5 border border-accent/20 flex items-center justify-between" id="recomp-status-bar">
					<span class="text-xs font-semibold text-muted-foreground">Select criteria to assess eligibility</span>
					<span class="text-xs font-black text-accent" id="recomp-eligibility-score">Score: 0</span>
				</div>
			</div>
		)}

		<form id="calc-form" class="grid gap-4 p-6 sm:grid-cols-2 relative" novalidate>
			<!-- TDEE STEP 1 -->
			<div class="tdee-step-panel sm:col-span-2 grid gap-4 sm:grid-cols-2" id="tdee-step-1-panel">
				<div class={fieldClass('sex')}>
					<label for="sex">Biological Sex</label>
					<div class="select-wrap">
						<select id="sex"><option value="male">Male</option><option value="female">Female</option></select>
					</div>
				</div>
				<div class={fieldClass('age')}>
					<label for="age">Age (years)</label>
					<div class="select-wrap">
						<select id="age">
							<option value="0" selected>Select Age</option>
							{Array.from({ length: 76 }, (_, i) => i + 15).map(age => (
								<option value={age}>{age}</option>
							))}
						</select>
					</div>
				</div>
				<div class={fieldClass('height')}>
					<label for="height">Height <span data-height-unit>(cm)</span></label>
					<div id="height-metric-container">
						<input id="height" type="number" min="120" max="230" step="0.1" value="0" />
					</div>
					<div id="height-imperial-container" class="hidden flex gap-2">
						<div class="flex-1 select-wrap">
							<select id="height-ft" class="w-full">
								<option value="3">3 ft</option>
								<option value="4">4 ft</option>
								<option value="5" selected>5 ft</option>
								<option value="6">6 ft</option>
								<option value="7">7 ft</option>
								<option value="8">8 ft</option>
							</select>
						</div>
						<div class="flex-1 select-wrap">
							<select id="height-in" class="w-full">
								{Array.from({ length: 12 }, (_, i) => (
									<option value={i} selected={i === 9}>{i} in</option>
								))}
							</select>
						</div>
					</div>
				</div>
				<div class={fieldClass('weight')}>
					<label for="weight">Weight <span data-weight-unit>(kg)</span></label>
					<div class="select-wrap">
						<select id="weight">
							<option value="0" selected>Select Weight</option>
							{Array.from({ length: 231 }, (_, i) => i + 20).map(w => (
								<option value={w}>{w}</option>
							))}
						</select>
					</div>
				</div>
				
				{mode === 'tdee' && (
					<div class="sm:col-span-2 flex justify-end mt-2">
						<button type="button" class="button-primary" id="tdee-next-to-2">Continue to Step 2 ➔</button>
					</div>
				)}
			</div>

			<!-- TDEE STEP 2 -->
			<div class={`tdee-step-panel sm:col-span-2 grid gap-4 sm:grid-cols-2 ${mode === 'tdee' ? 'hidden' : ''}`} id="tdee-step-2-panel">
				<div class={fieldClass('bodyFat')}>
					<label for="bodyFat">Body Fat Percentage (%)</label>
					<div class="flex gap-2">
						<input id="bodyFat" type="number" min="3" max="60" step="0.1" value="0" class="flex-1" />
						{mode !== 'bodyfat' && mode !== 'composition' && (
							<button type="button" id="calc-toggle-visual-estimator" class="button-secondary text-xs px-3 py-2 flex items-center gap-1.5 shrink-0">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
								Estimate Visually
							</button>
						)}
					</div>
					{mode !== 'bodyfat' && mode !== 'composition' && (
						<p class="text-[11px] text-muted-foreground mt-1.5 leading-normal font-sans">
							Don't know your fat percentage? Find it with this most accurate method across everywhere: <a href="/calculators/body-fat-calculator" class="text-accent font-semibold underline hover:text-accent/80 transition-colors">Estimate via Navy Method ➔</a>
						</p>
					)}

					<!-- Visual Body Fat Estimator Drawer -->
					<div id="calc-visual-estimator-drawer" class="hidden mt-4 border border-border/85 bg-muted/20 p-4 rounded-xl space-y-3 transition-all duration-300">
						<p class="text-xs font-bold text-foreground">Select your closest matching physique silhouette:</p>
						
						<!-- Male Silhouette Cards -->
						<div id="calc-visual-male" class="grid gap-2.5 grid-cols-2 sm:grid-cols-5">
							{[
								[10, 'Lean / Ripped', 'Visible abs, vascularity, high definition.'],
								[15, 'Fit / Athletic', 'Flat stomach, outline of abs, fit shape.'],
								[20, 'Average', 'Soft midsection, no visible abs, normal shape.'],
								[25, 'Soft / Excess', 'Waist outline soft, minimal definition.'],
								[30, 'High Fat', 'Full waistline, high adiposity.']
							].map(([bf, label, desc]) => (
								<button type="button" class="calc-bf-card p-2.5 rounded-lg border border-border bg-card text-left hover:border-accent transition-all flex flex-col justify-between" data-bf={bf}>
									<div>
										<span class="text-xs font-black text-accent">{bf}%</span>
										<p class="font-bold text-[11px] text-foreground mt-0.5 leading-snug">{label}</p>
										<p class="text-[9px] text-muted-foreground mt-1 leading-relaxed">{desc}</p>
									</div>
								</button>
							))}
						</div>

						<!-- Female Silhouette Cards -->
						<div id="calc-visual-female" class="grid gap-2.5 grid-cols-2 sm:grid-cols-5 hidden">
							{[
								[18, 'Lean / Ripped', 'Athletic shape, visible definition.'],
								[22, 'Fit / Athletic', 'Flat stomach, curves defined.'],
								[26, 'Average', 'Normal curves, soft hips, no abs.'],
								[30, 'Soft / Excess', 'Full waist and hips, rounder outline.'],
								[35, 'High Fat', 'Soft contours, high adiposity.']
							].map(([bf, label, desc]) => (
								<button type="button" class="calc-bf-card p-2.5 rounded-lg border border-border bg-card text-left hover:border-accent transition-all flex flex-col justify-between" data-bf={bf}>
									<div>
										<span class="text-xs font-black text-accent">{bf}%</span>
										<p class="font-bold text-[11px] text-foreground mt-0.5 leading-snug">{label}</p>
										<p class="text-[9px] text-muted-foreground mt-1 leading-relaxed">{desc}</p>
									</div>
								</button>
							))}
						</div>
					</div>
				</div>

				<div class={fieldClass('activity')}>
					<label for="activity">Daily Activity Level</label>
					<div class="select-wrap">
						<select id="activity">
							<option value="1.2">Sedentary (desk job)</option>
							<option value="1.375">Lightly Active (moderate walks)</option>
							<option value="1.55" selected>Moderately Active (trains 3-5x/week)</option>
							<option value="1.725">Highly Active (heavy training/sports)</option>
							<option value="1.9">Very Active (demanding labor/athlete)</option>
						</select>
					</div>
				</div>

				{mode === 'tdee' && (
					<div class="sm:col-span-2 flex justify-between mt-2">
						<button type="button" class="button-secondary" id="tdee-back-to-1">Back</button>
						<button type="button" class="button-primary" id="tdee-next-to-3">Confirm Details ➔</button>
					</div>
				)}
			</div>

			<!-- TDEE STEP 3 -->
			<div class={`tdee-step-panel sm:col-span-2 grid gap-4 sm:grid-cols-2 ${mode === 'tdee' ? 'hidden' : ''}`} id="tdee-step-3-panel">
				<!-- Goal and target weight parameters (for other modes, visible directly if enabled) -->
				{mode === 'calorie' && (
					<div class="sm:col-span-2">
						<label class="mb-2 block">Choose Strategy Target</label>
						<div class="grid gap-3 sm:grid-cols-4" id="goal-cards-selector">
							<button type="button" class="goal-card-btn text-left p-3 rounded-xl border border-border bg-card hover:border-accent transition-all flex flex-col justify-between" data-goal="fat-loss">
								<span class="text-xs font-bold text-accent">CUT</span>
								<span class="font-bold text-sm text-foreground mt-2">Fat Loss</span>
							</button>
							<button type="button" class="goal-card-btn text-left p-3 rounded-xl border border-border bg-card hover:border-accent transition-all flex flex-col justify-between" data-goal="maintain">
								<span class="text-xs font-bold text-success">MAINTAIN</span>
								<span class="font-bold text-sm text-foreground mt-2">Maintenance</span>
							</button>
							<button type="button" class="goal-card-btn text-left p-3 rounded-xl border border-border bg-card hover:border-accent transition-all flex flex-col justify-between" data-goal="lean-bulk">
								<span class="text-xs font-bold text-indigo-500">GROW</span>
								<span class="font-bold text-sm text-foreground mt-2">Lean Bulk</span>
							</button>
							<button type="button" class="goal-card-btn text-left p-3 rounded-xl border border-border bg-card hover:border-accent transition-all flex flex-col justify-between" data-goal="recomp">
								<span class="text-xs font-bold text-warning">RECOMP</span>
								<span class="font-bold text-sm text-foreground mt-2">Body Recomp</span>
							</button>
						</div>
						<select id="goal" class="hidden">
							<option value="fat-loss">Moderate Fat Loss (Cut)</option>
							<option value="maintain" selected>Weight Maintenance</option>
							<option value="lean-bulk">Lean Muscle Bulk</option>
							<option value="recomp">Body Recomposition</option>
						</select>
					</div>
				)}

				{mode !== 'calorie' && isFieldVisible('goal') && (
					<div class={fieldClass('goal')}>
						<label for="goal">Goal Strategy</label>
						<div class="select-wrap">
							<select id="goal">
								<option value="fat-loss">Moderate Fat Loss (Cut)</option>
								<option value="maintain">Weight Maintenance</option>
								<option value="lean-bulk">Lean Muscle Bulk</option>
								<option value="recomp">Body Recomposition</option>
							</select>
						</div>
					</div>
				)}

				{isFieldVisible('targetWeight') && (
					<div class={fieldClass('targetWeight')}>
						<label for="targetWeight">Target Body Weight <span data-weight-unit>(kg)</span></label>
						<div class="select-wrap">
							<select id="targetWeight">
								<option value="0" selected>Select Weight</option>
								{Array.from({ length: 231 }, (_, i) => i + 20).map(w => (
									<option value={w}>{w}</option>
								))}
							</select>
						</div>
					</div>
				)}

				{isFieldVisible('targetBodyFat') && (
					<div class={fieldClass('targetBodyFat')}>
						<label for="targetBodyFat">Target Body Fat (%)</label>
						<input id="targetBodyFat" type="number" min="3" max="50" step="0.1" value="0" />
					</div>
				)}

				{/* Protein range slider */}
				{mode === 'protein' && (
					<div class="sm:col-span-2 mt-2 bg-muted/10 p-4 rounded-xl border border-border/60">
						<label class="flex justify-between items-center mb-1">
							<span>Live Weight Adjustment</span>
							<span class="font-black text-accent" id="protein-slider-weight-val">82 kg</span>
						</label>
						<input type="range" id="protein-live-weight-slider" min="40" max="180" value="82" class="w-full h-2 rounded-lg bg-border accent-accent cursor-pointer" />
					</div>
				)}

				{/* Body Composition measurement silhouette guide */}
				{mode === 'composition' && (
					<div class="sm:col-span-2 grid gap-6 md:grid-cols-[1fr_200px] border-b border-border pb-6 mb-2">
						<div class="space-y-4">
							<p class="text-xs font-bold text-accent uppercase tracking-widest">Navy Method Silhouette Guide</p>
							<div class={fieldClass('waist')}>
								<label for="waist" class="flex justify-between">
									<span>Waist Circumference <span data-height-unit>(cm)</span></span>
									<span class="text-xs text-muted-foreground">Across belly button, exhaled</span>
								</label>
								<input id="waist" type="number" min="40" max="220" step="0.1" value="88" />
							</div>
							<div class={fieldClass('neck')}>
								<label for="neck" class="flex justify-between">
									<span>Neck Circumference <span data-height-unit>(cm)</span></span>
									<span class="text-xs text-muted-foreground">Below Adam's apple, relaxed</span>
								</label>
								<input id="neck" type="number" min="20" max="80" step="0.1" value="38" />
							</div>
							<div id="hip-field" class={fieldClass('hip')}>
								<label for="hip" class="flex justify-between">
									<span>Hip Circumference <span data-height-unit>(cm)</span></span>
									<span class="text-xs text-muted-foreground">Widest point of glutes (females only)</span>
								</label>
								<input id="hip" type="number" min="40" max="220" step="0.1" value="95" />
							</div>
						</div>
						
						<!-- Visual SVG Silhouette illustration -->
						<div class="hidden md:flex flex-col items-center justify-center bg-muted/30 rounded-xl border border-border/40 p-4">
							<svg width="80" height="150" viewBox="0 0 100 200" fill="none" class="text-muted-foreground/60">
								<!-- Head -->
								<circle cx="50" cy="22" r="14" stroke="currentColor" stroke-width="2" class="opacity-60"/>
								<!-- Neck measurement line -->
								<line x1="43" y1="39" x2="57" y2="39" stroke="var(--accent)" stroke-width="3" stroke-linecap="round"/>
								<!-- Torso -->
								<path d="M35 55 C35 55, 30 110, 40 125 C45 130, 55 130, 60 125 C70 110, 65 55, 65 55 Z" stroke="currentColor" stroke-width="2"/>
								<!-- Waist measurement line -->
								<line x1="33" y1="90" x2="67" y2="90" stroke="var(--accent)" stroke-width="3" stroke-linecap="round"/>
								<!-- Hip measurement line -->
								<line x1="31" y1="120" x2="69" y2="120" stroke="var(--success)" stroke-width="3" stroke-linecap="round" id="svg-hip-line"/>
								<!-- Arms -->
								<path d="M35 55 C28 65, 24 95, 26 115" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="opacity-40"/>
								<path d="M65 55 C72 65, 76 95, 74 115" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="opacity-40"/>
							</svg>
							<div class="mt-2 text-[10px] text-center font-bold text-muted-foreground uppercase tracking-wider">Navy Metrics</div>
						</div>
					</div>
				)}

				{mode === 'tdee' && (
					<div class="sm:col-span-2 flex justify-between mt-2">
						<button type="button" class="button-secondary" id="tdee-back-to-2">Back</button>
						<button class="button-primary flex-1 ml-3" type="submit" id="calc-submit">Calculate Energy Balance ➔</button>
					</div>
				)}
			</div>

			{mode !== 'tdee' && (
				<button class="button-primary sm:col-span-2 mt-2" type="submit" id="calc-submit">{btnLabel}</button>
			)}
		</form>
	</div>

	<!-- Output Results Screen -->
	<div id="calc-result" class="result-container border-t border-border bg-muted/20 p-6" aria-live="polite" tabindex="-1">
		<div class="result-placeholder">
			<svg class="text-muted-foreground" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
			<p class="mt-3 text-sm font-semibold text-foreground">Awaiting Calculator Inputs</p>
			<p class="mt-1 text-xs text-muted-foreground max-w-xs">Fill in the fields above and hit Calculate to generate your body composition targets.</p>
		</div>
	</div>
</div>

<!-- Supporting Content cards -->
<section class="mt-8 grid gap-4 md:grid-cols-3">
	<div class="app-card">
		<h3 class="font-bold text-sm text-foreground font-sans">Formula & Math</h3>
		<p class="mt-2 text-xs leading-relaxed text-muted-foreground font-sans">{formula}</p>
	</div>
	<div class="app-card">
		<h3 class="font-bold text-sm text-foreground font-sans">How to Interpret</h3>
		<p class="mt-2 text-xs leading-relaxed text-muted-foreground font-sans">{interpretation}</p>
	</div>
	<div class="app-card">
		<h3 class="font-bold text-sm text-foreground font-sans">Plan Integration</h3>
		<p class="mt-2 text-xs leading-relaxed text-muted-foreground font-sans">
			Take these estimations back to the main Strategy Finder assessment, or save them in your tracking logs in the local dashboard.
		</p>
	</div>
</section>


<script>
	import {
		round as r,
		mifflin,
		bmi,
		katch,
		kgToLb,
		lbToKg,
		cmToIn,
		inToCm,
		clamp,
		calculateNavyBodyFat,
		strategyMultiplier,
		macros,
		idealWeightRange,
		targetWeightFromBodyFat,
		whtrCategory,
		formatWeight as fmtWeight,
		formatLength as fmtLength,
	} from '../lib/engines';
	import { convertFormUnits, updateUnitLabels, rebuildWeightSelect } from '../lib/units';

	const container = document.querySelector('[data-calculator]') as HTMLElement | null;
	const mode = container?.getAttribute('data-calculator') || 'tdee';

	let currentUnit = typeof localStorage !== 'undefined' ? localStorage.getItem('bodycompos.preferredUnit') || 'metric' : 'metric';

	function formatWeight(kg, digits = 1) {
		return fmtWeight(kg, currentUnit, digits);
	}

	function formatLength(cm, digits = 1) {
		return fmtLength(cm, currentUnit, digits);
	}
	
	function toMetric(values) {
		if (currentUnit === 'metric') return values;
		return {
			...values,
			h: inToCm(values.h),
			w: lbToKg(values.w),
			waist: values.waist ? inToCm(values.waist) : 0,
			neck: values.neck ? inToCm(values.neck) : 0,
			hip: values.hip ? inToCm(values.hip) : 0,
			targetWeight: lbToKg(values.targetWeight),
		};
	}
	
	
	
	function formatAnimatedValue(str) {
		if (typeof str !== 'string') str = String(str);
		const match = str.match(/^([+-]?\d+(?:\.\d+)?)(.*)$/);
		if (match) {
			const num = parseFloat(match[1]);
			const suffix = match[2];
			return `<span class="animate-calc-val" data-target="${num}" data-suffix="${suffix.replace(/"/g, '&quot;')}">${str}</span>`;
		}
		return str;
	}

	function makeRows(values) {
		return `<div class="grid gap-3 sm:grid-cols-3">${values.map(([k, v, width = 64]) => `
			<div class="result-card">
				<p class="text-xs font-bold uppercase text-muted-foreground font-sans">${k}</p>
				<p class="mt-1 text-xl font-black text-foreground">${formatAnimatedValue(v)}</p>
				<div class="mini-bar mt-3"><span class="calc-progress-bar" style="width:0%" data-width="${width}"></span></div>
			</div>
		`).join('')}</div>`;
	}

	function animateCounter(element: HTMLElement, start: number, end: number, duration: number = 800, suffix: string = '') {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			element.textContent = `${end}${suffix}`;
			return;
		}
		
		let startTime: number | null = null;
		const isFloat = !Number.isInteger(end);
		
		function step(timestamp: number) {
			if (!startTime) startTime = timestamp;
			const progress = Math.min((timestamp - startTime) / duration, 1);
			const easeProgress = progress * (2 - progress); // outQuad
			const current = start + easeProgress * (end - start);
			const formatted = isFloat ? current.toFixed(1) : Math.floor(current);
			element.textContent = `${formatted}${suffix}`;
			if (progress < 1) {
				window.requestAnimationFrame(step);
			} else {
				element.textContent = `${isFloat ? end.toFixed(1) : end}${suffix}`;
			}
		}
		
		window.requestAnimationFrame(step);
	}
	
	function fieldVisible(el) {
		if (!el) return false;
		const parent = el.closest('.field');
		return parent && !parent.classList.contains('hidden');
	}

	function readRawForm(f) {
		return {
			sex: fieldVisible(f.sex) ? (f.sex?.value || 'male') : 'male',
			age: fieldVisible(f.age) ? Number(f.age?.value || 32) : 0,
			h: fieldVisible(f.height) ? Number(f.height?.value || 175) : 0,
			w: fieldVisible(f.weight) ? Number(f.weight?.value || 82) : 0,
			bf: fieldVisible(f.bodyFat) ? Number(f.bodyFat?.value || 0) : 0,
			waist: fieldVisible(f.waist) ? Number(f.waist?.value || 0) : 0,
			neck: fieldVisible(f.neck) ? Number(f.neck?.value || 0) : 0,
			hip: fieldVisible(f.hip) ? Number(f.hip?.value || 0) : 0,
			activity: fieldVisible(f.activity) ? Number(f.activity?.value || 1.55) : 1.55,
			goal: fieldVisible(f.goal) ? (f.goal?.value || 'maintain') : 'maintain',
			targetWeight: fieldVisible(f.targetWeight) ? Number(f.targetWeight?.value || f.weight?.value || 82) : 0,
			targetBodyFat: fieldVisible(f.targetBodyFat) ? Number(f.targetBodyFat?.value || 0) : 0,
		};
	}
	
	const formEl = document.querySelector('#calc-form') as HTMLFormElement | null;

	function showError(inputId: string, errorMsg: string) {
		if (!formEl) return;
		const input = formEl.querySelector(`#${inputId}`) as HTMLInputElement | HTMLSelectElement | null;
		if (!input) return;
		
		input.classList.add('border-destructive');
		
		const parent = input.closest('.field');
		parent?.querySelector('.error-msg')?.remove();

		const span = document.createElement('p');
		span.className = 'error-msg text-xs text-destructive mt-1.5 font-medium';
		span.textContent = errorMsg;
		parent?.appendChild(span);
	}

	function clearError(inputId: string) {
		if (!formEl) return;
		const input = formEl.querySelector(`#${inputId}`) as HTMLInputElement | HTMLSelectElement | null;
		if (!input) return;
		input.classList.remove('border-destructive');
		input.closest('.field')?.querySelector('.error-msg')?.remove();
	}

	// Setup listeners to clear error on input change/type
	const validationFields = ['age', 'height', 'weight', 'bodyFat', 'waist', 'neck', 'hip', 'targetWeight', 'targetBodyFat'];
	validationFields.forEach(fieldId => {
		const el = formEl?.querySelector(`#${fieldId}`);
		el?.addEventListener('input', () => clearError(fieldId));
		el?.addEventListener('change', () => clearError(fieldId));
	});

	function validateStep(stepIndex: number): boolean {
		let isValid = true;
		if (!formEl) return true;

		if (stepIndex === 1) {
			const ageInput = formEl.querySelector('#age') as HTMLInputElement | null;
			if (ageInput && fieldVisible(ageInput)) {
				const age = Number(ageInput.value);
				if (!ageInput.value || age < 15 || age > 90) {
					showError('age', 'Please enter a valid age between 15 and 90.');
					isValid = false;
				} else {
					clearError('age');
				}
			}

			const heightInput = formEl.querySelector('#height') as HTMLInputElement | null;
			if (heightInput && fieldVisible(heightInput)) {
				const height = Number(heightInput.value);
				const hMin = currentUnit === 'metric' ? 120 : 47;
				const hMax = currentUnit === 'metric' ? 230 : 91;
				if (!heightInput.value || height < hMin || height > hMax) {
					showError('height', `Height must be between ${hMin} and ${hMax} ${currentUnit === 'metric' ? 'cm' : 'inches'}.`);
					isValid = false;
				} else {
					clearError('height');
				}
			}

			const weightInput = formEl.querySelector('#weight') as HTMLInputElement | null;
			if (weightInput && fieldVisible(weightInput)) {
				const weight = Number(weightInput.value);
				const wMin = currentUnit === 'metric' ? 20 : 44;
				const wMax = currentUnit === 'metric' ? 250 : 551;
				if (!weightInput.value || weight < wMin || weight > wMax) {
					showError('weight', `Weight must be between ${wMin} and ${wMax} ${currentUnit === 'metric' ? 'kg' : 'lbs'}.`);
					isValid = false;
				} else {
					clearError('weight');
				}
			}
		} else if (stepIndex === 2) {
			const bfInput = formEl.querySelector('#bodyFat') as HTMLInputElement | null;
			if (bfInput && fieldVisible(bfInput)) {
				const bf = Number(bfInput.value);
				if (bfInput.value && bf !== 0 && (bf < 3 || bf > 60)) {
					showError('bodyFat', 'Body fat must be between 3% and 60% (or 0 for fallback).');
					isValid = false;
				} else {
					clearError('bodyFat');
				}
			}
		} else if (stepIndex === 3) {
			const waistInput = formEl.querySelector('#waist') as HTMLInputElement | null;
			let isWaistValid = true;
			let waist = 0;
			if (waistInput && fieldVisible(waistInput)) {
				waist = Number(waistInput.value);
				const waMin = currentUnit === 'metric' ? 40 : 16;
				const waMax = currentUnit === 'metric' ? 220 : 87;
				if (!waistInput.value || waist < waMin || waist > waMax) {
					showError('waist', `Waist must be between ${waMin} and ${waMax} ${currentUnit === 'metric' ? 'cm' : 'inches'}.`);
					isValid = false;
					isWaistValid = false;
				} else {
					clearError('waist');
				}
			}

			const neckInput = formEl.querySelector('#neck') as HTMLInputElement | null;
			let isNeckValid = true;
			let neck = 0;
			if (neckInput && fieldVisible(neckInput)) {
				neck = Number(neckInput.value);
				const nMin = currentUnit === 'metric' ? 20 : 8;
				const nMax = currentUnit === 'metric' ? 80 : 31;
				if (!neckInput.value || neck < nMin || neck > nMax) {
					showError('neck', `Neck must be between ${nMin} and ${nMax} ${currentUnit === 'metric' ? 'cm' : 'inches'}.`);
					isValid = false;
					isNeckValid = false;
				} else {
					clearError('neck');
				}
			}

			const hipInput = formEl.querySelector('#hip') as HTMLInputElement | null;
			let isHipValid = true;
			let hip = 0;
			if (hipInput && fieldVisible(hipInput) && !hipInput.closest('.field')?.classList.contains('hidden')) {
				hip = Number(hipInput.value);
				const hiMin = currentUnit === 'metric' ? 40 : 16;
				const hiMax = currentUnit === 'metric' ? 220 : 87;
				if (!hipInput.value || hip < hiMin || hip > hiMax) {
					showError('hip', `Hip must be between ${hiMin} and ${hiMax} ${currentUnit === 'metric' ? 'cm' : 'inches'}.`);
					isValid = false;
					isHipValid = false;
				} else {
					clearError('hip');
				}
			}

			if (waistInput && neckInput && fieldVisible(waistInput) && fieldVisible(neckInput) && isWaistValid && isNeckValid) {
				const sexSelect = formEl.querySelector('#sex') as HTMLSelectElement | null;
				const sex = sexSelect?.value || 'male';
				if (sex === 'male') {
					if (waist <= neck) {
						showError('waist', 'Waist circumference must be larger than neck circumference.');
						isValid = false;
					}
				} else if (isHipValid && hipInput && fieldVisible(hipInput) && !hipInput.closest('.field')?.classList.contains('hidden')) {
					if (waist + hip <= neck) {
						showError('waist', 'Waist + Hip circumference must be larger than neck circumference.');
						isValid = false;
					}
				}
			}

			const targetWeightInput = formEl.querySelector('#targetWeight') as HTMLInputElement | null;
			if (targetWeightInput && fieldVisible(targetWeightInput)) {
				const targetWeight = Number(targetWeightInput.value);
				const wMin = currentUnit === 'metric' ? 20 : 44;
				const wMax = currentUnit === 'metric' ? 250 : 551;
				if (!targetWeightInput.value || targetWeight < wMin || targetWeight > wMax) {
					showError('targetWeight', `Target weight must be between ${wMin} and ${wMax} ${currentUnit === 'metric' ? 'kg' : 'lbs'}.`);
					isValid = false;
				} else {
					clearError('targetWeight');
				}
			}

			const targetBodyFatInput = formEl.querySelector('#targetBodyFat') as HTMLInputElement | null;
			if (targetBodyFatInput && fieldVisible(targetBodyFatInput)) {
				const targetBodyFat = Number(targetBodyFatInput.value);
				if (!targetBodyFatInput.value || targetBodyFat < 3 || targetBodyFat > 50) {
					showError('targetBodyFat', 'Target body fat must be between 3% and 50%.');
					isValid = false;
				} else {
					clearError('targetBodyFat');
				}
			}
		}
		return isValid;
	}

	function syncHeightFromFtIn() {
		const heightFtSelect = document.getElementById('height-ft') as HTMLSelectElement | null;
		const heightInSelect = document.getElementById('height-in') as HTMLSelectElement | null;
		const heightInput = document.getElementById('height') as HTMLInputElement | null;
		if (heightFtSelect && heightInSelect && heightInput) {
			const totalInches = parseInt(heightFtSelect.value) * 12 + parseInt(heightInSelect.value);
			heightInput.value = String(totalInches);
			clearError('height');
		}
	}

	function syncFtInFromHeight(inchesValue: number) {
		const heightFtSelect = document.getElementById('height-ft') as HTMLSelectElement | null;
		const heightInSelect = document.getElementById('height-in') as HTMLSelectElement | null;
		if (heightFtSelect && heightInSelect && inchesValue > 0) {
			const ft = Math.floor(inchesValue / 12);
			const inches = Math.round(inchesValue % 12);
			
			if (ft >= 3 && ft <= 8) {
				heightFtSelect.value = String(ft);
			} else if (ft < 3) {
				heightFtSelect.value = '3';
			} else {
				heightFtSelect.value = '8';
			}
			
			if (inches >= 0 && inches < 12) {
				heightInSelect.value = String(inches);
			} else {
				heightInSelect.value = '0';
			}
		}
	}

	// Attach change events to feet/inches selects
	(function() {
		const heightFtSelect = document.getElementById('height-ft');
		const heightInSelect = document.getElementById('height-in');
		if (heightFtSelect) heightFtSelect.addEventListener('change', syncHeightFromFtIn);
		if (heightInSelect) heightInSelect.addEventListener('change', syncHeightFromFtIn);
	})();

	function setUnit(unit) {
		if (unit === currentUnit) return;
		const f = document.querySelector('#calc-form') as HTMLFormElement | null;
		if (!f) return;

		const weightSelect = f.querySelector('#weight') as HTMLSelectElement | null;
		const targetWeightSelect = f.querySelector('#targetWeight') as HTMLSelectElement | null;
		const currentWeightVal = weightSelect ? Number(weightSelect.value) : 0;
		const currentTargetWeightVal = targetWeightSelect ? Number(targetWeightSelect.value) : 0;

		const fields: (keyof typeof import('../lib/units').FormFields)[] = ['height', 'waist', 'neck', 'hip'];
		convertFormUnits(f, currentUnit, unit, fields);

		// Rebuild select dropdowns dynamically
		rebuildWeightSelect(weightSelect, unit, currentWeightVal);
		rebuildWeightSelect(targetWeightSelect, unit, currentTargetWeightVal);

		currentUnit = unit;
		if (typeof localStorage !== 'undefined') {
			localStorage.setItem('bodycompos.preferredUnit', unit);
		}

		// Update height display containers
		const metricContainer = document.getElementById('height-metric-container');
		const imperialContainer = document.getElementById('height-imperial-container');
		const heightInput = document.getElementById('height') as HTMLInputElement | null;
		if (unit === 'imperial') {
			if (metricContainer) metricContainer.classList.add('hidden');
			if (imperialContainer) imperialContainer.classList.remove('hidden');
			if (heightInput) {
				const inches = parseFloat(heightInput.value) || 69;
				syncFtInFromHeight(inches);
				heightInput.value = String(inches);
			}
		} else {
			if (metricContainer) metricContainer.classList.remove('hidden');
			if (imperialContainer) imperialContainer.classList.add('hidden');
		}

		updateUnitLabels(unit, { unitBtn: 'data-unit', heightLabel: 'data-height-unit', weightLabel: 'data-weight-unit' });
		validationFields.forEach(clearError);
	}
	
	document.querySelectorAll('[data-unit]').forEach((button) => button.addEventListener('click', () => setUnit(button.getAttribute('data-unit'))));

	// TDEE Wizard Navigation
	if (mode === 'tdee') {
		const step1Btn = document.getElementById('tdee-next-to-2');
		const step2Btn = document.getElementById('tdee-next-to-3');
		const back1Btn = document.getElementById('tdee-back-to-1');
		const back2Btn = document.getElementById('tdee-back-to-2');

		const panel1 = document.getElementById('tdee-step-1-panel');
		const panel2 = document.getElementById('tdee-step-2-panel');
		const panel3 = document.getElementById('tdee-step-3-panel');

		const setWizardStep = (stepNum) => {
			document.querySelectorAll('#tdee-wizard-steps [data-step]').forEach(span => {
				const sVal = Number(span.getAttribute('data-step'));
				if (sVal < stepNum) {
					span.className = 'w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold bg-success text-white';
				} else if (sVal === stepNum) {
					span.className = 'w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold bg-accent text-white';
				} else {
					span.className = 'w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold bg-muted text-muted-foreground';
				}
			});
			const labels = {
				1: 'Step 1: Physical Metrics',
				2: 'Step 2: Activity & Body Fat',
				3: 'Step 3: Confirm Details'
			};
			const lbl = document.getElementById('tdee-wizard-step-label');
			if (lbl) lbl.textContent = labels[stepNum];
		};

		step1Btn?.addEventListener('click', () => {
			if (validateStep(1)) {
				panel1?.classList.add('hidden');
				panel2?.classList.remove('hidden');
				setWizardStep(2);
			}
		});
		back1Btn?.addEventListener('click', () => {
			panel2?.classList.add('hidden');
			panel1?.classList.remove('hidden');
			setWizardStep(1);
		});
		step2Btn?.addEventListener('click', () => {
			if (validateStep(2)) {
				panel2?.classList.add('hidden');
				panel3?.classList.remove('hidden');
				setWizardStep(3);
			}
		});
		back2Btn?.addEventListener('click', () => {
			panel3?.classList.add('hidden');
			panel2?.classList.remove('hidden');
			setWizardStep(2);
		});
	}

	// Calorie Goal Card Selectors
	if (mode === 'calorie') {
		const select = document.getElementById('goal') as HTMLSelectElement;
		const cards = document.querySelectorAll('.goal-card-btn');
		const form = document.getElementById('calc-form');

		const updateActiveCard = (targetGoal) => {
			cards.forEach(btn => {
				const isSelected = btn.getAttribute('data-goal') === targetGoal;
				btn.className = `goal-card-btn text-left p-3 rounded-xl border transition-all flex flex-col justify-between ${isSelected ? 'border-accent bg-accent/5 ring-1 ring-accent' : 'border-border bg-card hover:border-accent'}`;
			});
		};

		cards.forEach(btn => {
			btn.addEventListener('click', () => {
				const gVal = btn.getAttribute('data-goal');
				if (gVal && select) {
					select.value = gVal;
					updateActiveCard(gVal);
					// auto-submit form for snappy preview
					form?.dispatchEvent(new Event('submit', { cancelable: true }));
				}
			});
		});

		// initialize active state
		if (select) updateActiveCard(select.value);
	}

	// Live Protein Slider Handler
	if (mode === 'protein') {
		const weightInput = document.getElementById('weight') as HTMLInputElement;
		const slider = document.getElementById('protein-live-weight-slider') as HTMLInputElement;
		const sliderVal = document.getElementById('protein-slider-weight-val');
		const form = document.getElementById('calc-form');

		// Sync form weight input to slider weight input
		const syncWeight = (val) => {
			if (sliderVal) {
				const displayVal = currentUnit === 'metric' ? `${r(val)} kg` : `${r(kgToLb(val))} lb`;
				sliderVal.textContent = displayVal;
			}
			if (weightInput) {
