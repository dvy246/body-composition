		}
		else if (mode === 'ideal') {
			const ideal = idealWeightRange(sex, h);
			rows = [
				['Low range', formatWeight(ideal.low), 44],
				['Midpoint', formatWeight(ideal.midpoint), 60],
				['High range', formatWeight(ideal.high), 76]
			];
			
			// Build ideal range horizontal bar widget
			const currentWeightText = formatWeight(w);
			const percentPos = clamp(Math.round(((w - ideal.low) / (ideal.high - ideal.low)) * 100), 5, 95);
			
			snapshotHtml = `
				<div class="result-card">
					<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans mb-3">Skeletal Weight Range</p>
					<div class="relative pt-6 pb-2 px-1">
						<!-- Horizontal line -->
						<div class="h-1.5 w-full bg-muted rounded-full relative">
							<!-- Ideal zone colored green -->
							<div class="absolute top-0 bottom-0 left-[10%] right-[10%] bg-success/20 rounded-full"></div>
							<!-- User position indicator -->
							<div class="absolute -top-1 w-3.5 h-3.5 rounded-full bg-accent border-2 border-card -ml-1.5 cursor-help" style="left: ${percentPos}%" title="Your Weight: ${currentWeightText}"></div>
						</div>
						<!-- Labels -->
						<div class="flex justify-between text-[9px] text-muted-foreground mt-2 font-mono">
							<span>${formatWeight(ideal.low)} (Low)</span>
							<span>${formatWeight(ideal.high)} (High)</span>
						</div>
					</div>
					<p class="mt-2 text-[10px] leading-relaxed text-muted-foreground font-sans">Skeletal reference range using healthy BMI base. Athletes with high muscle mass regularly exceed this range safely.</p>
				</div>
			`;
		}
		else if (mode === 'whtr') {
			const ratio = waist / h;
			rows = [
				['Waist-to-height', r(ratio, 2), clamp(ratio * 120, 10, 95)],
				['Waist', formatLength(waist), 52],
				['Category', whtrCategory(ratio), ratio <= 0.5 ? 70 : 45]
			];
			
			// Traffic light gauge widget
			let color = 'bg-success';
			let txt = 'Generally Healthy';
			if (ratio > 0.5 && ratio <= 0.6) { color = 'bg-warning'; txt = 'Elevated adiposity'; }
			else if (ratio > 0.6) { color = 'bg-destructive'; txt = 'High risk'; }
			
			snapshotHtml = `
				<div class="result-card">
					<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans mb-3">Cardiovascular Risk Screen</p>
					<div class="flex items-center gap-3 p-3 rounded-lg bg-muted/40 border border-border/40 mb-3">
						<span class="w-3 h-3 rounded-full ${color} shrink-0 animate-pulse"></span>
						<div>
							<p class="text-xs font-bold text-foreground">${txt}</p>
							<p class="text-[10px] text-muted-foreground mt-0.5">Ratio: ${r(ratio, 2)} (healthy standard <= 0.5)</p>
						</div>
					</div>
					<p class="text-[10px] leading-relaxed text-muted-foreground font-sans">WHtR evaluates visceral fat levels more effectively than BMI by focusing directly on waist measurements relative to height.</p>
				</div>
			`;
		}
		else if (mode === 'target') {
			const target = targetWeightFromBodyFat(w, bfVal, targetBodyFat);
			rows = [
				['Target Weight', formatWeight(target.targetWeight), 64],
				['Required Change', `${target.change >= 0 ? '+' : ''}${formatWeight(target.change)}`, 48],
				['Lean Mass Held', formatWeight(target.leanMass), 68]
			];
			snapshotHtml = `
				<div class="result-card">
					<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans">Delta Target Strategy</p>
					<div class="mt-4 p-3 rounded-lg border border-border/40 bg-muted/30 text-xs font-mono space-y-1">
						<div class="flex justify-between"><span>Current Weight</span><span>${formatWeight(w)}</span></div>
						<div class="flex justify-between"><span>Target Weight</span><span>${formatWeight(target.targetWeight)}</span></div>
						<div class="flex justify-between font-bold text-accent"><span>Target Delta</span><span>${target.change >= 0 ? '+' : ''}${formatWeight(target.change)}</span></div>
					</div>
				</div>
			`;
		}
		else if (['bodyfat', 'ffmi', 'lbm', 'composition', 'bmi'].includes(mode) || mode.includes('composition') || mode.includes('fat') || mode.includes('mass')) {
			rows = [
				['BMI scale', b, Math.min(92, b * 2.7)],
				['Lean Mass', lean ? formatWeight(lean) : 'BF% needed', 68],
				['Fat Mass', fatMass ? formatWeight(fatMass) : 'BF% needed', 42]
			];
			if (['bodyfat', 'composition'].includes(mode)) {
				rows = [
					['Body Fat', `${bfVal}%`, clamp(bfVal * 1.6, 10, 95)],
					['Lean Mass', lean ? formatWeight(lean) : 'N/A', 68],
					['Fat Mass', fatMass ? formatWeight(fatMass) : 'N/A', 42]
				];
			}
			if (mode === 'ffmi' && lean) {
				const ffmiVal = r(lean / ((h / 100) ** 2), 2);
				const normFfmiVal = r(ffmiVal + 6.1 * (1.8 - (h / 100)), 2);
				rows = [
					['Raw FFMI', ffmiVal, clamp((ffmiVal - 12) * 6, 10, 95)],
					['Normalized FFMI', normFfmiVal, clamp((normFfmiVal - 12) * 6, 10, 95)],
					['Lean Mass', formatWeight(lean), 66]
				];
				
				// Percentile gauge for FFMI with natural ceiling
				let status = 'Average';
				if (normFfmiVal >= 25) status = 'Theoretical Genetic Limit';
				else if (normFfmiVal >= 22) status = 'Excellent/Very Muscular';
				else if (normFfmiVal >= 20) status = 'Above Average';
				
				snapshotHtml = `
					<div class="result-card">
						<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans mb-3">FFMI Percentile Scale</p>
						<div class="p-3 bg-muted/40 border border-border/40 rounded-lg text-xs font-sans space-y-2">
							<div class="flex justify-between font-bold"><span>Normal FFMI</span><span>${normFfmiVal}</span></div>
							<div class="flex justify-between text-muted-foreground text-[10px]"><span>Muscle Tier</span><span>${status}</span></div>
							<div class="relative h-1.5 w-full bg-muted rounded-full overflow-hidden mt-1">
								<div class="absolute top-0 bottom-0 left-0 bg-accent rounded-full" style="width: ${clamp((normFfmiVal - 12) * 6.5, 5, 98)}%"></div>
								<div class="absolute top-0 bottom-0 w-0.5 bg-destructive cursor-help" style="left: 84.6%" title="Natural FFMI Ceiling (25)"></div>
							</div>
							<div class="flex justify-between text-[8px] text-muted-foreground font-mono"><span>12 (Low)</span><span>22 (High)</span><span>25+ (Ceiling)</span></div>
						</div>
					</div>
				`;
			} else {
				snapshotHtml = `
					<div class="result-card">
						<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans">Body Index Composition</p>
						<div class="mt-4 space-y-2 text-xs text-muted-foreground font-mono">
							<div class="flex justify-between font-bold text-foreground"><span>BMI score</span><span>${b}</span></div>
							${lean ? `<div class="flex justify-between font-bold text-foreground"><span>Lean Mass share</span><span>${formatWeight(lean)} (${r(100 - bfVal, 1)}%)</span></div>` : ''}
							${fatMass ? `<div class="flex justify-between font-bold text-foreground"><span>Fat Mass share</span><span>${formatWeight(fatMass)} (${bfVal}%)</span></div>` : ''}
						</div>
					</div>
				`;
			}
		}
		else if (mode === 'macro') {
			rows = [
				['Protein (30%)', `${m.protein} g`, 60],
				['Fat (28%)', `${m.fat} g`, 40],
				['Carbohydrates (42%)', `${m.carbs} g`, 76]
			];
			// Visual macro pie chart (SVG)
			snapshotHtml = `
				<div class="result-card flex flex-col items-center">
					<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans w-full text-left">Macro Split Ratio</p>
					<div class="relative w-32 h-32 my-4">
						<svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
							<!-- Protein: 30% (dasharray 30 70) -->
							<circle cx="18" cy="18" r="15.915" fill="transparent" stroke="var(--accent)" stroke-width="4.2" stroke-dasharray="30 70" stroke-dashoffset="0"></circle>
							<!-- Fat: 28% (dasharray 28 72, offset starts at -30) -->
							<circle cx="18" cy="18" r="15.915" fill="transparent" stroke="var(--success)" stroke-width="4.2" stroke-dasharray="28 72" stroke-dashoffset="-30"></circle>
							<!-- Carbs: 42% (dasharray 42 58, offset starts at -58) -->
							<circle cx="18" cy="18" r="15.915" fill="transparent" stroke="var(--warning)" stroke-width="4.2" stroke-dasharray="42 58" stroke-dashoffset="-58"></circle>
						</svg>
						<div class="absolute inset-0 flex flex-col items-center justify-center font-mono">
							<span class="text-xs font-bold text-foreground">${targetCal}</span>
							<span class="text-[9px] text-muted-foreground">kcal</span>
						</div>
					</div>
					<div class="w-full space-y-2 text-xs text-muted-foreground font-mono">
						<div class="flex justify-between font-bold text-foreground">
							<span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-accent inline-block"></span>Protein</span>
							<span>${m.protein} g (${r(m.protein*4)} kcal)</span>
						</div>
						<div class="flex justify-between font-bold text-foreground">
							<span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-success inline-block"></span>Fats</span>
							<span>${m.fat} g (${r(m.fat*9)} kcal)</span>
						</div>
						<div class="flex justify-between font-bold text-foreground">
							<span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-warning inline-block"></span>Carbs</span>
							<span>${m.carbs} g (${r(m.carbs*4)} kcal)</span>
						</div>
					</div>
				</div>
			`;
		}
		else if (mode === 'cycling') {
			const trainingDays = 4;
			const restDays = 7 - trainingDays;
			// High/Low day math: Training days = Maintenance + 200, Rest days balanced to hit targetCal weekly average
			const highDay = targetCal + 200;
			const totalWeeklyTarget = targetCal * 7;
			const lowDay = Math.round((totalWeeklyTarget - (highDay * trainingDays)) / restDays);

			rows = [
				['Weekly Average Target', `${targetCal} kcal/day`, 60],
				['Training Day Target (4 days)', `${highDay} kcal/day`, 75],
				['Rest Day Target (3 days)', `${lowDay} kcal/day`, 45]
			];
			snapshotHtml = `
				<div class="result-card">
					<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans">Calorie Cycling Projections</p>
					<div class="mt-4 space-y-4 text-xs text-muted-foreground">
						<div>
							<div class="flex justify-between font-bold text-foreground mb-1">
								<span>Training Days (${trainingDays} days/wk)</span>
								<span>${highDay} kcal</span>
							</div>
							<div class="relative h-2 w-full bg-border rounded-full overflow-hidden">
								<div class="absolute inset-y-0 left-0 bg-success rounded-full" style="width: 85%"></div>
							</div>
						</div>
						<div>
							<div class="flex justify-between font-bold text-foreground mb-1">
								<span>Rest Days (${restDays} days/wk)</span>
								<span>${lowDay} kcal</span>
							</div>
							<div class="relative h-2 w-full bg-border rounded-full overflow-hidden">
								<div class="absolute inset-y-0 left-0 bg-accent rounded-full" style="width: 60%"></div>
							</div>
						</div>
					</div>
				</div>
			`;
		}
		else {
			rows = [
				['Maintenance', `${maintenance} kcal`, 60],
				['Target intake', `${targetCal} kcal`, 70],
				['Protein', `${m.protein} g`, 64]
			];
			snapshotHtml = `
				<div class="result-card">
					<p class="text-xs font-bold uppercase text-accent tracking-wider font-sans">Calculation Details</p>
					<p class="mt-3 text-xs leading-relaxed text-muted-foreground font-sans">Use this estimate as a starting point. Recalculate if your activity or body weight diverges.</p>
				</div>
			`;
		}
		
		const mathHtml = getStepByStepMathHtml(mode, sex, age, h, w, bfVal, waist, neck, hip, activity, goal, targetCal, maintenance);
		
		
		if (calcResult) {
			let themeClass = 'border-border bg-muted/20';
			if (['deficit', 'calorie-deficit-calculator', 'deficit-calculator'].includes(mode) || (mode === 'calorie' && goal === 'fat-loss')) {
				themeClass = 'border-cyan-500/20 bg-cyan-500/[0.03]';
			} else if (['surplus', 'muscle', 'calorie-surplus-calculator', 'surplus-calculator'].includes(mode) || (mode === 'calorie' && goal.includes('bulk'))) {
				themeClass = 'border-emerald-500/20 bg-emerald-500/[0.03]';
			} else if (['recomp', 'composition', 'bodyfat'].includes(mode) || (mode === 'calorie' && goal === 'recomp')) {
				themeClass = 'border-indigo-500/20 bg-indigo-500/[0.03]';
			} else if (['timeline', 'target'].includes(mode)) {
				themeClass = 'border-amber-500/20 bg-amber-500/[0.03]';
			}

			calcResult.className = `result-container border-t ${themeClass} p-6 has-result`;
			const formulaNote = bfVal
				? 'Katch-McArdle formula (uses body fat)'
				: 'Mifflin-St Jeor formula (no body fat provided)';
			calcResult.innerHTML = `
				<div class="result-content grid gap-6 lg:grid-cols-[1.2fr_0.8fr] text-left animate-fade-in-up">
					<div>
						${makeRows(rows)}
						<p class="mt-2 text-xs text-muted-foreground font-sans">Formula: ${formulaNote}</p>
						${mathHtml}
						<p class="mt-4 text-xs leading-relaxed text-muted-foreground font-sans">
							Calculated starting point estimates. Energy output and metabolic speed fluctuate weekly. Reassess after tracking actual trend weight changes.
						</p>
						<div class="mt-4 flex flex-wrap gap-3 font-sans">
							<a class="button-secondary text-sm" href="/assess">Plug into Strategy Finder</a>
							<a class="button-ghost text-sm" href="/dashboard">Open Local Log</a>
						</div>
					</div>
					<div>
						${snapshotHtml}
						<p class="mt-3 text-xs font-medium text-warning font-sans">These are educational estimates. Consult a healthcare professional before starting any diet or exercise program.</p>
					</div>
				</div>
			`;

			// Animate value counters
			calcResult.querySelectorAll('.animate-calc-val').forEach(el => {
				const target = parseFloat(el.getAttribute('data-target') || '0');
				const suffix = el.getAttribute('data-suffix') || '';
				animateCounter(el as HTMLElement, 0, target, 800, suffix);
			});

			// Animate progress bars
			calcResult.querySelectorAll('.calc-progress-bar').forEach(bar => {
				const width = bar.getAttribute('data-width') || '0';
				setTimeout(() => {
					(bar as HTMLElement).style.width = `${width}%`;
				}, 50);
			});

			calcResult.focus();
			calcResult.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
		}
	});
</script>
