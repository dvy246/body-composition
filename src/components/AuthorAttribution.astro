---
interface Props {
	role?: string;
	references?: string;
	published?: string;
	reviewed?: string;
}

const {
	role = 'Reviewed by certified sports nutrition researcher',
	references = '',
	published = 'June 2026',
	reviewed = 'June 27, 2026',
} = Astro.props;
---

<div class="mt-6 flex items-center gap-3 text-xs text-muted-foreground border-t border-border pt-4">
	<div class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/10 text-accent shrink-0 shadow-sm" aria-hidden="true">
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
	</div>
	<div>
		<p><span class="font-semibold text-foreground hover:text-accent transition-colors"><a href="/about">D. Yadav, CSCS</a></span> · {role}</p>
		<p class="mt-0.5">Published {published} · Last reviewed {reviewed}{references && ` · References: ${references}`}</p>
	</div>
</div>

