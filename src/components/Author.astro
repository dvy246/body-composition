---
interface Props {
	className?: string;
}

const { className = '' } = Astro.props;
---

<div class={`app-card border border-border p-6 rounded-2xl flex flex-col sm:flex-row items-center sm:items-start gap-5 bg-card/50 backdrop-blur-sm ${className}`}>
	<!-- Verified credential badge icon -->
	<div class="w-16 h-16 rounded-full shrink-0 flex items-center justify-center text-white shadow-md" style="background: linear-gradient(135deg, var(--accent), var(--success));">
		<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
	</div>
	<div class="flex-1 text-center sm:text-left">
		<div class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mb-1">
			<h3 class="text-base font-black text-foreground">BodyCompOS Editorial Board</h3>
			<span class="text-xs font-bold text-accent bg-accent/10 px-2 py-0.5 rounded-full">Scientific Review</span>
		</div>
		<p class="text-xs font-semibold text-muted-foreground mb-3">Sports Science Researchers · Certified Strength & Conditioning Specialists</p>
		<p class="text-sm text-muted-foreground leading-relaxed">
			Content on BodyCompOS is developed and reviewed by a certified sports performance and nutrition specialist. All recommendations are grounded in peer-reviewed research from ISSN, ACSM, and primary literature sources.
		</p>
		<!-- Trust signals -->
		<div class="mt-4 flex flex-wrap justify-center sm:justify-start gap-4 text-xs font-semibold text-muted-foreground">
			<span class="trust-strip-item">
				<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
				Credentials Verified
			</span>
			<a href="/methodology" class="hover:text-accent flex items-center gap-1 transition-colors">
				<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
				Methodology
			</a>
			<span class="text-muted-foreground/30">|</span>
			<span class="text-xs text-muted-foreground">Last reviewed: June 27, 2026</span>
		</div>
	</div>
</div>
